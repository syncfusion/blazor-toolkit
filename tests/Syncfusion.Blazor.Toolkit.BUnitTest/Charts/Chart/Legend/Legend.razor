<SfFixture @ref="fixture3" TestAsync="CheckingLegendProps1" Description="Checking ChartLegendSettings (EnableHighlight, Accessibility, Inversed, Reverse, Overflow, Wrap, MaxWidth, Focusable)">
    <ComponentUnderTest>
        <SfChart ID="container3" Title="Olympic Medals">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
            <ChartSeriesCollection>
                <ChartSeries DataSource="@MedalDetails" Name="Gold" XName="Country" YName="Gold" />
                <ChartSeries DataSource="@MedalDetails" Name="Silver" XName="Country" YName="Silver" />
            </ChartSeriesCollection>

            <ChartLegendSettings Visible="true"
                                 EnableHighlight="true"
                                 AccessibilityDescriptionFormat="Custom legend item: ${value}"
                                 AccessibilityRole="region"
                                 Focusable="false"
                                 IsInversed="true"
                                 Reverse="true"
                                 TextOverflow="LabelOverflow.Clip"
                                 TextWrap="TextWrap.Wrap"
                                 MaximumLabelWidth="60">
            </ChartLegendSettings>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {
    SfFixture fixture3 { get; set; }

    async Task CheckingLegendProps1(Fixture fixture3)
    {
        var cut = fixture3.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var legend = cut.FindComponent<ChartLegendSettings>().Instance;

        Assert.True(legend.EnableHighlight, "EnableHighlight should be true");
        Assert.Equal("Custom legend item: ${value}", legend.AccessibilityDescriptionFormat);
        Assert.Equal("region", legend.AccessibilityRole);
        Assert.False(legend.Focusable, "Focusable should be false");
        Assert.True(legend.IsInversed, "IsInversed should be true");
        Assert.True(legend.Reverse, "Reverse should be true");
        Assert.Equal(LabelOverflow.Clip, legend.TextOverflow);
        Assert.Equal(TextWrap.Wrap, legend.TextWrap);
        Assert.Equal(60, legend.MaximumLabelWidth);

        cut.SetParametersAndRender();
        await legend.DisposeAsync();
    }
}

