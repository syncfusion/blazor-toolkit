@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Charts.Internal
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Charts.Internal;
@using Syncfusion.Blazor.Toolkit.Data
@using Bunit
@using Xunit

@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="CrossMarkerCheck" Description="Chart With Cross Marker Shape">
    <ComponentUnderTest>
        <SfChart ID="container" Width="700">             
            <ChartPrimaryXAxis Title="PrimaryXAxis" ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTimeCategory"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYAxis"></ChartPrimaryYAxis>
            <ChartSeriesCollection>
                <ChartSeries DataSource="@columns" Type="ChartSeriesType.Column" XName="x" YName="y" Name="Column Series">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                    <ChartMarker Visible="true" Width="20" Height="20" Fill="Green" Opacity="0.1" Shape="ChartShape.Cross">
                        <ChartDataLabel Visible="true" Position="ChartLabelPosition.Top" Fill="#404041"></ChartDataLabel>
                        <ChartMarkerBorder Width="4" Color="Red"></ChartMarkerBorder>
                        <ChartMarkerOffset X="0" Y="0"></ChartMarkerOffset>
                    </ChartMarker>
                </ChartSeries>
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {

    SfFixture fixture { get; set; }
    async Task CrossMarkerCheck(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var point = cut.Find("#container_Series_0_Point_0_Symbol");
        // Note: Values may vary slightly depending on screen resolution.
        Assert.True(point.GetAttribute("d") == "M 41.525 162.625 L 61.525 182.625 M 41.525 182.625 L 61.525 162.625");
        cut.SetParametersAndRender();
    }
    public class ColumnData
    {
        public DateTime x { get; set; }
        public double y { get; set; }
    }
    public List<ColumnData> columns = new List<ColumnData>
        {
           new ColumnData{ x = new DateTime(2000, 06, 11), y = 10 },
           new ColumnData{ x = new DateTime(2002, 03, 07), y = -30 },
           new ColumnData{ x = new DateTime(2004, 03, 06), y = 15 },
           new ColumnData{ x = new DateTime(2006, 03, 30), y = -65 },
           new ColumnData{ x = new DateTime(2008, 03, 08), y = 0 },
           new ColumnData{ x = new DateTime(2010, 03, 08), y = 85 }
        };
}