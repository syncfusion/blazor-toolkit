@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="CheckingDefaultpoints" Description="CheckingDefaultpoints">
    <ComponentUnderTest>
        <SfChart ID="container" Title="x wise Sales Report" Width="800">
            <ChartPrimaryXAxis Title="PrimaryXAxis" RangePadding="ChartRangePadding.Normal"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis"></ChartPrimaryYAxis>
            
                <ChartSeries DataSource="@Sales" XName="x" YName="y" Type="ChartSeriesType.StackingBar" Name="Gold" Fill="rgba(135,206,235,1)">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
                <ChartSeries DataSource="@Sales" XName="x" YName="y1" Type="ChartSeriesType.StackingBar" Name="Silver" Fill="rgba(135,206,235,1)">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
                <ChartSeries DataSource="@Sales" XName="x" YName="y1" Type="ChartSeriesType.StackingBar" Name="Ruby" Fill="rgba(135,206,235,1)">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            
        </SfChart>
    </ComponentUnderTest>
</SfFixture>


@code {

    SfFixture fixture { get; set; }
    async Task CheckingDefaultpoints(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var series1 = cut.Find("#container_Series_0_Point_0");
        Assert.True(series1.GetAttribute("fill") == "rgba(135,206,235,1)");
        var series2 = cut.Find("#container_Series_1_Point_1");
        Assert.True(series1.GetAttribute("fill") == "rgba(135,206,235,1)");
        var series3 = cut.Find("#container_Series_2_Point_1");
        Assert.True(series1.GetAttribute("fill") == "rgba(135,206,235,1)");
        cut.SetParametersAndRender();
    }
    public class BarData
    {
        public double x { get; set; }
        public double y { get; set; }
        public double y1 { get; set; }
    }

    public List<BarData> Sales = new List<BarData>
{
        new BarData { x = 1000, y = 70, y1 = 73 },
        new BarData { x = 2000, y = 40, y1 = 40 },
        new BarData { x = 3000, y = 70, y1 = 75 },
        new BarData { x = 4000, y = 60, y1 = 30 },
        new BarData { x = 5000, y = 50, y1 = 56 },
        new BarData { x = 6000, y = 40, y1 = 60 },
        new BarData { x = 7000, y = 40, y1 = 41 },
        new BarData { x = 8000, y = 70, y1 = 45 }
    };
}


