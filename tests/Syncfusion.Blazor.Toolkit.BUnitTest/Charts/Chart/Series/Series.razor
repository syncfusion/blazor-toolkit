@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Bunit
@using Xunit

@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="CheckingLineSeriesWithData" Description="CheckingLineSeriesWithData">
    <ComponentUnderTest>
        <SfChart ID="container" Height="600">
            <ChartBorder Width="1" Color="Red"></ChartBorder>
            <ChartPrimaryXAxis Title="PrimaryXAxis" MinorTicksPerInterval="4">
                <ChartAxisLineStyle Color="Blue" Width="2"></ChartAxisLineStyle>
                <ChartAxisMinorGridLines Width="0"></ChartAxisMinorGridLines>
                <ChartAxisMinorTickLines Width="1"></ChartAxisMinorTickLines>
            </ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis">
                <ChartAxisLineStyle Color="Blue" Width="2"></ChartAxisLineStyle>
            </ChartPrimaryYAxis>
            
                <ChartSeries DataSource="@Sales" XName="x" YName="y" Type="ChartSeriesType.Line" Name="Gold" Fill="#ACE5FF" Width="3">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
                <ChartSeries DataSource="@Sales" XName="x" YName="y1" Type="ChartSeriesType.Line" Name="Gold1" Fill="#F6B53F" Width="2">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {

    SfFixture fixture { get; set; }
    async Task CheckingLineSeriesWithData(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#container_Series_0");
        Assert.True(svg.GetAttribute("stroke") == "#ACE5FF");
        Assert.True(svg.GetAttribute("stroke-width") == "3");
        var svg1 = cut.Find("#container_Series_1");
        Assert.True(svg1.GetAttribute("stroke") == "#F6B53F");
        Assert.True(svg1.GetAttribute("stroke-width") == "2");
        cut.SetParametersAndRender();
    }
    public class SalesInfo
    {
        public double x { get; set; }
        public double y { get; set; }
        public double y1 { get; set; }
    }

    public List<SalesInfo> Sales = new List<SalesInfo>
{
       new SalesInfo{ x = 1, y = 18, y1 = 2},
       new SalesInfo{ x = 2, y = 29, y1 = 7},
       new SalesInfo{ x = 3, y = 30, y1 = 11},
       new SalesInfo{ x = 4, y = 41, y1 = 13},
       new SalesInfo{ x = 5, y = 52, y1 = 16},
       new SalesInfo{ x = 6, y = 62, y1 = 19},
       new SalesInfo{ x = 7, y = 74, y1 = 22},
       new SalesInfo{ x = 8, y = 85, y1 = 28},
       new SalesInfo{ x = 9, y = 96, y1 = 33},
       new SalesInfo{ x = 10, y = 102, y1 = 41}
    };
}






