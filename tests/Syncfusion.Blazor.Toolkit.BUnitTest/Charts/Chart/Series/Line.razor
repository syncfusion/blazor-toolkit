@code {
    SfFixture fixtureMultiLine;
    double SeriesStrokeWidth = 2;
    double SeriesOpacity = 0.6;
    string SeriesDashArray = "5, 5";
    string SeriesBorderColor = "red";
    double SeriesBorderWidth = 3;

    async Task CheckingDynamicUpdateProperties_MultiColoredLine(Fixture fixtureMultiLine)
    {
        var cut = fixtureMultiLine.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);

        var segment = cut.Find("#container_Series_0_Point_0");
        Assert.NotNull(segment);

        Assert.Equal("red", segment.GetAttribute("stroke"));
        Assert.Equal("0.6", segment.GetAttribute("opacity"));

        var seriesRenderer = cut.Instance._visibleSeriesRenderers[0];
        Assert.Equal(0.6, seriesRenderer.Series.Opacity);
        Assert.Equal(2, seriesRenderer.Series.Width);
        Assert.Equal("5, 5", seriesRenderer.Series.DashArray);
        Assert.Equal("red", seriesRenderer.Series.Border.Color);
        Assert.Equal(3, seriesRenderer.Series.Border.Width);

        SeriesStrokeWidth = 3;
        SeriesOpacity = 0.5;
        SeriesDashArray = "3, 2";
        SeriesBorderColor = "green";
        SeriesBorderWidth = 2;

        cut.SetParametersAndRender();
        await Task.Delay(250);

        var updatedSegment = cut.Find("#container_Series_0_Point_1");
        Assert.NotNull(updatedSegment);

        var updatedSeriesRenderer = cut.Instance._visibleSeriesRenderers[0];
        Assert.Equal(0.5, updatedSeriesRenderer.Series.Opacity);
        Assert.Equal(3, updatedSeriesRenderer.Series.Width);
        Assert.Equal("3, 2", updatedSeriesRenderer.Series.DashArray);
        Assert.Equal("green", updatedSeriesRenderer.Series.Border.Color);
        Assert.Equal(2, updatedSeriesRenderer.Series.Border.Width);

        cut.SetParametersAndRender();
    }

