    <ComponentUnderTest>
        <SfChart ID="container" Title="MultiColoredLine Chart">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"></ChartPrimaryXAxis>
        
            <ChartSeries DataSource="@SalesDetails" XName="X" YName="Y"
                        Type="ChartSeriesType.MultiColoredLine"
                        Name="India"
                        PointColorMapping="PointColor"
                        Width="@SeriesStrokeWidth"
                        Opacity="@SeriesOpacity"
                        DashArray="@SeriesDashArray">
            <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
            <ChartSeriesBorder Width="@SeriesBorderWidth" Color="@SeriesBorderColor"></ChartSeriesBorder>
            </ChartSeries>
        
        </SfChart>
    </ComponentUnderTest>
