    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var series1 = cut.Find("#container_Series_0_Point_0");
        Assert.True(series1.GetAttribute("fill") == "rgba(135,206,235,1)");
        var series2 = cut.Find("#container_Series_1_Point_1");
        Assert.True(series2.GetAttribute("fill") == "Blue");
        cut.SetParametersAndRender();
    }
    public class BarData
    {
        public double x { get; set; }
        public double y { get; set; }
        public double y1 { get; set; }
    }

    public List<BarData> Sales = new List<BarData>
{
        new BarData { x = 1000, y = 70, y1 = 73 },
        new BarData { x = 2000, y = 40, y1 = 40 },
        new BarData { x = 3000, y = 70, y1 = 75 },
        new BarData { x = 4000, y = 60, y1 = 30 },
        new BarData { x = 5000, y = 50, y1 = 56 },
        new BarData { x = 6000, y = 40, y1 = 60 },
        new BarData { x = 7000, y = 40, y1 = 41 },
        new BarData { x = 8000, y = 70, y1 = 45 }
    };
}


