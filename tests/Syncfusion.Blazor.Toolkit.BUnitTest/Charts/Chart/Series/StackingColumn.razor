<SfFixture @ref="fixture" TestAsync="CheckingDefaultpoints" Description="CheckingDefaultpoints">
    <ComponentUnderTest>
        <SfChart ID="container" Title="x wise Sales Report" Width="800">
            <ChartPrimaryXAxis Title="PrimaryXAxis" RangePadding="ChartRangePadding.Normal"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis"></ChartPrimaryYAxis>
