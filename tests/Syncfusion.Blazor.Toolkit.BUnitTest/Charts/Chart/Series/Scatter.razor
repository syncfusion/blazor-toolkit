<SfFixture @ref="fixture26" TestAsync="CheckingDynamicUpdateProperties_Scatter" Description="CheckingDynamicUpdateProperties_Scatter">
<ComponentUnderTest>
<SfChart ID="container" Title="ChartTitle">
    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"></ChartPrimaryXAxis>
    <ChartSeriesCollection>
        <ChartSeries DataSource="@ChartDataList" XName="X" YName="YValue" Type="ChartSeriesType.Scatter"
                     Name="Series1" Fill="@SeriesFill" Opacity="@SeriesOpacity" Width="@SeriesWidth" DashArray="@SeriesDashArray">
            <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
            <ChartSeriesBorder Width="@SeriesBorderWidth" Color="@SeriesBorderColor"></ChartSeriesBorder>
            <ChartMarker Visible="true" Height="10" Width="10"></ChartMarker>
        </ChartSeries>
    </ChartSeriesCollection>
</SfChart>
</ComponentUnderTest>
</SfFixture>

@code {
    SfFixture fixture26;

    string SeriesFill = "blue";
    double SeriesOpacity = 1;
    double SeriesWidth = 2;
    string SeriesBorderColor = "red";
    double SeriesBorderWidth = 2;
    string SeriesDashArray = "5, 5";

    public class ChartData
    {
        public string X { get; set; }
        public double YValue { get; set; }
        public double YValue1 { get; set; }
    }

    public List<ChartData> ChartDataList = new List<ChartData>
    {
        new ChartData { X= "USA", YValue= 46, YValue1=56 },
        new ChartData { X= "GBR", YValue= 27, YValue1=17 },
        new ChartData { X= "CHN", YValue= 26, YValue1=36 },
        new ChartData { X= "UK",  YValue= 56, YValue1=16 },
        new ChartData { X= "AUS", YValue= 12, YValue1=46 },
        new ChartData { X= "IND", YValue= 26, YValue1=16 },
        new ChartData { X= "DEN", YValue= 26, YValue1=12 },
        new ChartData { X= "MEX", YValue= 34, YValue1=32},
    };

    async Task CheckingDynamicUpdateProperties_Scatter(Fixture fixture26)
    {
        var cut = fixture26.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var point = cut.Find("#container_Series_0_Point_1");
        Assert.NotNull(point);
        Assert.Equal(SeriesFill, point.GetAttribute("fill"));
        Assert.Equal(SeriesOpacity.ToString(), point.GetAttribute("opacity"));
        var renderer = cut.Instance._visibleSeriesRenderers[0].Series;
        Assert.Equal(SeriesFill, renderer.Fill);
        Assert.Equal(SeriesOpacity, renderer.Opacity);
        Assert.Equal(SeriesWidth, renderer.Width);
        Assert.Equal(SeriesBorderColor, renderer.Border.Color);
        Assert.Equal(SeriesBorderWidth, renderer.Border.Width);
        Assert.Equal(SeriesDashArray, renderer.DashArray);
        SeriesFill = "purple";
        SeriesOpacity = 0.5;
        SeriesWidth = 3;
        SeriesBorderColor = "green";
        SeriesBorderWidth = 3;
        SeriesDashArray = "3, 2";
        cut.SetParametersAndRender();
        await Task.Delay(250);
        var updatedPoint = cut.Find("#container_Series_0_Point_1");
        Assert.NotNull(updatedPoint);
        var updatedRenderer = cut.Instance._visibleSeriesRenderers[0].Series;
        Assert.Equal("purple", updatedRenderer.Fill);
        Assert.Equal(0.5, updatedRenderer.Opacity);
        Assert.Equal(3, updatedRenderer.Width);
        Assert.Equal("green", updatedRenderer.Border.Color);
        Assert.Equal(3, updatedRenderer.Border.Width);
        Assert.Equal("3, 2", updatedRenderer.DashArray);
        Assert.Equal("purple", updatedPoint.GetAttribute("fill"));
        Assert.Equal("0.5", updatedPoint.GetAttribute("opacity"));
        cut.SetParametersAndRender();
    }
}