@code {
    SfFixture fixture78;
    string SeriesFill = "blue";
    double SeriesOpacity = 1;
    double SeriesWidth = 2;
    string SeriesBorderColor = "red";
    double SeriesBorderWidth = 5;
    string SeriesDashArray = "3, 2";
    async Task CheckingDyanmicUpdateProperties_ColumnBase(Fixture fixture5)
    {
        var cut = fixture5.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);

        var point = cut.Find("#container_Series_0_Point_0");
        Assert.NotNull(point);

        Assert.Equal("blue", point.GetAttribute("fill"));
        Assert.Equal("1", point.GetAttribute("opacity"));

        Assert.Equal("blue", cut.Instance._visibleSeriesRenderers[0].Series.Fill);
        Assert.Equal(1, cut.Instance._visibleSeriesRenderers[0].Series.Opacity);
        Assert.Equal(2, cut.Instance._visibleSeriesRenderers[0].Series.Width);
        Assert.Equal("red", cut.Instance._visibleSeriesRenderers[0].Series.Border.Color);
        Assert.Equal(5, cut.Instance._visibleSeriesRenderers[0].Series.Border.Width);
        Assert.Equal("3, 2", cut.Instance._visibleSeriesRenderers[0].Series.DashArray);

        SeriesFill = "purple";
        SeriesOpacity = 0.5;
        SeriesWidth = 3;
        SeriesBorderColor = "green";
        SeriesBorderWidth = 3;
        SeriesDashArray = "5, 5";

        cut.SetParametersAndRender();
        await Task.Delay(250);

        var updatedPoint = cut.Find("#container_Series_0_Point_0");
        Assert.NotNull(updatedPoint);
        var seriesRenderer = cut.Instance._visibleSeriesRenderers[0];
        Assert.Equal("purple", seriesRenderer.Series.Fill);
        Assert.Equal(0.5, seriesRenderer.Series.Opacity);
        Assert.Equal(3, seriesRenderer.Series.Width);
        Assert.Equal("green", seriesRenderer.Series.Border.Color);
        Assert.Equal(3, seriesRenderer.Series.Border.Width);
        Assert.Equal("5, 5", seriesRenderer.Series.DashArray);

        cut.SetParametersAndRender();
    }

