@using AngleSharp.Dom
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Bunit
@using Xunit

@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="checkingSeriesWithoutDatapoints" Description="checkingSeriesWithoutDatapoints">
    <ComponentUnderTest>
        <SfChart ID="container" Title="Chart TS Title" Width="800">
            <ChartPrimaryXAxis Title="PrimaryXAxis" LabelFormat="C"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis" RangePadding="ChartRangePadding.Normal"></ChartPrimaryYAxis>
            
                <ChartSeries Type="ChartSeriesType.Column" Name="Gold" Fill="rgba(135,206,235,1)">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {

    SfFixture fixture { get; set; }
    async Task checkingSeriesWithoutDatapoints(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);      
        var xaxislabelcollection = cut.Find("#containerAxisLabels0");
        Assert.True(xaxislabelcollection.ChildNodes.Length == 11);
        var yaxislabelcollection = cut.Find("#containerAxisLabels1");
        Assert.True(yaxislabelcollection.ChildNodes.Length == 7);
        cut.SetParametersAndRender();
    }
}


