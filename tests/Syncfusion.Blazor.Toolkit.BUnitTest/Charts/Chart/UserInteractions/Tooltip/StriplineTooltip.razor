<SfFixture @ref="fixture9" TestAsync="CheckingStriplineTooltipRendering" Description="CheckingStriplineTooltipRendering">
    <ComponentUnderTest>
        <SfChart @ref="sfChart" ID="container" Title="Weather Report" ChartMouseMove="MouseMove">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
            <ChartPrimaryYAxis>
                <ChartStriplines>
                    <ChartStripline Start="20" End="30" Color="red">
                        <ChartStriplineTooltip Enable="true" Header="Temperature Range" Content="20-30°C" Fill="#7bb4eb">
                            <ChartStriplineTooltipTextStyle Color="White" Size="14px" />
                        </ChartStriplineTooltip>
                    </ChartStripline>
                </ChartStriplines>
            </ChartPrimaryYAxis>

            <ChartSeriesCollection>
                <ChartSeries Type="ChartSeriesType.Column" DataSource="@WeatherReports9" XName="X" YName="Y">
                </ChartSeries>
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {
    SfFixture fixture9 { get; set; }
    SfChart sfChart { get; set; }
    bool isTooltipRendered = false;

    async Task CheckingStriplineTooltipRendering(Fixture fixture9)
    {
        var cut = fixture9.GetComponentUnderTest<SfChart>();
        await Task.Delay(300);

        var striplineTooltip = cut.FindComponent<ChartStriplineTooltip>();
        Assert.NotNull(striplineTooltip);
        Assert.True(striplineTooltip.Instance.Enable == true);
        Assert.True(striplineTooltip.Instance.Header == "Temperature Range");
        Assert.True(striplineTooltip.Instance.Content == "20-30°C");
        Assert.True(striplineTooltip.Instance.Fill == "#7bb4eb");

        ChartInternalMouseEventArgs args = new ChartInternalMouseEventArgs
        {
            MouseX = 150,
            MouseY = 250,
            PointerId = 0,
            PointerType = "",
            Target = "container_stripline_Behind_rect_PrimaryYAxis_0",
            Type = "mousemove"
        };

        sfChart.OnZoomingMouseMove(args);

        Assert.True(cut.Find("#container_stripline_tooltip") != null);
        Assert.Equal(args.MouseX, 150);
        Assert.Equal(args.MouseY, 250);
        Assert.Equal(args.Target, "container_stripline_Behind_rect_PrimaryYAxis_0");
        Assert.Equal(args.Type, "mousemove");

        Assert.True(isTooltipRendered);

        cut.SetParametersAndRender();
        await cut.Instance.DisposeAsync();
    }

    void MouseMove(ChartMouseEventArgs args)
    {
        isTooltipRendered = true;
    }

    public class ChartData9
    {
        public string X { get; set; }
        public double Y { get; set; }
    }

    public List<ChartData9> WeatherReports9 = new List<ChartData9>
    {
        new ChartData9 { X = "Sun", Y = 28 },
        new ChartData9 { X = "Mon", Y = 27 },
        new ChartData9 { X = "Tue", Y = 33 },
        new ChartData9 { X = "Wed", Y = 36 },
        new ChartData9 { X = "Thu", Y = 28 },
        new ChartData9 { X = "Fri", Y = 30 },
        new ChartData9 { X = "Sat", Y = 31 }
    };
}