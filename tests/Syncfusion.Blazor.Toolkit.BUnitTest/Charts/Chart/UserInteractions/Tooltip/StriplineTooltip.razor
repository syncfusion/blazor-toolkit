<SfFixture @ref="fixture" TestAsync="CheckingTooltipTextStyle" Description="CheckingTooltipTextStyle">
    <ComponentUnderTest>
        <SfChart ID="container" Title="Weather Report">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
            <ChartPrimaryYAxis>
                <ChartStriplines>
                    <ChartStripline Start="20" End="30" Color="red">
                        <ChartStriplineTooltip Enable="true">
                            <ChartStriplineTooltipTextStyle Color="Black" FontFamily="Aerial" Size="12px" FontWeight="600" />
                        </ChartStriplineTooltip>
                    </ChartStripline>
                </ChartStriplines>
            </ChartPrimaryYAxis>

            <ChartSeriesCollection>
                <ChartSeries Type="ChartSeriesType.Column" DataSource="@WeatherReports" XName="X" YName="Y">
                </ChartSeries>
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {
    SfFixture fixture { get; set; }
    async Task CheckingTooltipTextStyle(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var striplineTooltipTextStyle = cut.FindComponent<ChartStriplineTooltipTextStyle>();
        Assert.True(striplineTooltipTextStyle.Instance.Size != "" && striplineTooltipTextStyle.Instance.GetFontSize(cut.Instance._chartThemeStyle) == "12px");
        Assert.True(striplineTooltipTextStyle.Instance.FontFamily != "" && striplineTooltipTextStyle.Instance.GetFontFamily(cut.Instance._chartThemeStyle) == "Aerial");
        Assert.True(striplineTooltipTextStyle.Instance.FontWeight != "" && striplineTooltipTextStyle.Instance.GetFontWeight(cut.Instance._chartThemeStyle) == "600");
        Assert.True(striplineTooltipTextStyle.Instance.Color != "" && striplineTooltipTextStyle.Instance.Color == "Black");
        cut.SetParametersAndRender();
        striplineTooltipTextStyle.Instance.ComponentDispose();
    }

    public class ChartData
    {
        public string X { get; set; }
        public double Y { get; set; }
    }

    public List<ChartData> WeatherReports = new List<ChartData>
	{
		new ChartData { X = "Sun", Y = 28 },
		new ChartData { X = "Mon", Y = 27 },
		new ChartData { X = "Tue", Y = 33 },
		new ChartData { X = "Wed", Y = 36 },
		new ChartData { X = "Thu", Y = 28 },
		new ChartData { X = "Fri", Y = 30 },
		new ChartData { X = "Sat", Y = 31 }
    };
}

