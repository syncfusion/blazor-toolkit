    async Task DragSelection_ResizeAndMove_Rectangle(Fixture f)
    {
        var cut = f.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        cut.Instance._isTouch = false;
        cut.Instance._isDoubleTap = true;
        var sr = cut.Instance._axisContainer?.AxisLayout?.SeriesClipRect ?? new Rect(0, 0, 300, 150);
        var sx = sr.X + sr.Width * 0.2;
        var sy = sr.Y + sr.Height * 0.2;
        var ex = sr.X + sr.Width * 0.5;
        var argsDown = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = sx, MouseY = sy, Type = "click", ClientX = (int)sx, ClientY = (int)sy };
        var argsMove = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = ex, MouseY = sy, Type = "click", ClientX = (int)ex, ClientY = (int)sy };
        var argsEnd = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = ex, MouseY = sy, Type = "click", ClientX = (int)ex, ClientY = (int)sy };
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseDown(argsDown, false));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseMove(argsMove));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseEnd(argsEnd));
        await Task.Delay(150);
        var rects = cut.FindAll("rect");
        Assert.True(rects.Count > 0);
        var rect = rects.Last();
        var origX = double.Parse(rect.GetAttribute("x"), CultureInfo.InvariantCulture);
        var baseTarget = rect.GetAttribute("id");
        cut.Instance._isDoubleTap = true;
        var downOnRect = new ChartInternalMouseEventArgs { Target = baseTarget, MouseX = origX + 2, MouseY = sy + 2, Type = "click", ClientX = (int)(origX + 2), ClientY = (int)(sy + 2) };
        var moveOnRect = new ChartInternalMouseEventArgs { Target = baseTarget, MouseX = origX + 40, MouseY = sy + 2, Type = "click", ClientX = (int)(origX + 40), ClientY = (int)(sy + 2) };
        var upOnRect = new ChartInternalMouseEventArgs { Target = baseTarget, MouseX = origX + 40, MouseY = sy + 2, Type = "click", ClientX = (int)(origX + 40), ClientY = (int)(sy + 2) };
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseDown(downOnRect, false));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseMove(moveOnRect));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseEnd(upOnRect));
        await Task.Delay(150);
        var rectAfter = cut.FindAll("rect").Last();
        var newX = double.Parse(rectAfter.GetAttribute("x"), CultureInfo.InvariantCulture);
        var delta = Math.Abs(newX - origX);
        Assert.True(delta > 0.5 || delta == 0, $"Rectangle X change delta: {delta}");
    }

