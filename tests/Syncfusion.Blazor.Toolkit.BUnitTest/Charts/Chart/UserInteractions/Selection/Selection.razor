    async Task DragSelection_NoMulti_Lasso_Path(Fixture f)
    {
        var cut = f.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        cut.Instance._isTouch = false;
        cut.Instance._isDoubleTap = true;
        var pathsBefore = cut.FindAll("path").Count;
        var sr = cut.Instance._axisContainer?.AxisLayout?.SeriesClipRect ?? new Rect(0, 0, 300, 150);
        var sx = sr.X + sr.Width * 0.2;
        var sy = sr.Y + sr.Height * 0.2;
        var argsDown = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = sx, MouseY = sy, Type = "click", ClientX = (int)sx, ClientY = (int)sy };
        var argsMove1 = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = sx + 20, MouseY = sy + 10, Type = "click", ClientX = (int)(sx + 20), ClientY = (int)(sy + 10) };
        var argsMove2 = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = sx + 40, MouseY = sy + 30, Type = "click", ClientX = (int)(sx + 40), ClientY = (int)(sy + 30) };
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseDown(argsDown, false));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseMove(argsMove1));
        await Task.Delay(100);
        var pathsAfterCreate = cut.FindAll("path").Count;
        Assert.True(pathsAfterCreate > pathsBefore, "Lasso should create a path element");
        var firstPath = cut.FindAll("path").Last();
        var d1 = firstPath.GetAttribute("d") ?? string.Empty;
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseMove(argsMove2));
        await Task.Delay(100);
        var updatedPath = cut.FindAll("path").Last();
        var d2 = updatedPath.GetAttribute("d") ?? string.Empty;
        Assert.True(d2.Length >= d1.Length, "Path 'd' attribute should be updated (or at least unchanged)");
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseEnd(argsMove2));
    }
