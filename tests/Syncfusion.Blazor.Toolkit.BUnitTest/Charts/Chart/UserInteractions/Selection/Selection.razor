    async Task CheckingSelectionViaCodeBehind(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var selectedDataIndex = cut.FindComponent<ChartSelectedDataIndex>();
        var selectedDataIndexes = cut.FindComponent<ChartSelectedDataIndexes>();
        Assert.True(cut.Find("#container_Series_0_Point_1").GetAttribute("fill") == "#6200EE");
        Assert.True(cut.Find("#container_Series_1_Point_3").GetAttribute("fill") == "#09AF74");
        selectedDataIndexes.Instance.SelectedData = new List<ChartSelectedDataIndex>() { ChartSelectedDataIndex.CreateSelectedData(2, 1) };
        cut.SetParametersAndRender();
        await selectedDataIndex.Instance.DisposeAsync();
        await selectedDataIndexes.Instance.DisposeAsync();
    }
