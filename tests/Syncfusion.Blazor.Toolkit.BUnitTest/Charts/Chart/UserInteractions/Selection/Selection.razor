    async Task DragSelection_DragX_DrawsRectangle(Fixture f)
    {
        var cut = f.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svgBefore = cut.FindAll("rect").Count;
        cut.Instance._isTouch = false;
        cut.Instance._isDoubleTap = true;
        var seriesRect = cut.Instance._axisContainer?.AxisLayout?.SeriesClipRect ?? new Rect(0, 0, 300, 150);
        var startX = seriesRect.X + seriesRect.Width * 0.25;
        var startY = seriesRect.Y + seriesRect.Height * 0.5;
        var endX = seriesRect.X + seriesRect.Width * 0.75;
        var endY = startY;
        var argsDown = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = startX, MouseY = startY, Type = "click", ClientX = (int)startX, ClientY = (int)startY };
        var argsMove = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = endX, MouseY = endY, Type = "click", ClientX = (int)endX, ClientY = (int)endY };
        var argsEnd = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_", MouseX = endX, MouseY = endY, Type = "click", ClientX = (int)endX, ClientY = (int)endY };
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseDown(argsDown, false));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseMove(argsMove));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseEnd(argsEnd));
        await Task.Delay(100);
        var svgAfter = cut.FindAll("rect").Count;
        Assert.True(svgAfter > svgBefore, "DragX should create/update selection rectangle");

        var lastRect = cut.FindAll("rect").Last();
        var rx = double.Parse(lastRect.GetAttribute("x"), CultureInfo.InvariantCulture);
        var ry = double.Parse(lastRect.GetAttribute("y"), CultureInfo.InvariantCulture);
        var rw = double.Parse(lastRect.GetAttribute("width"), CultureInfo.InvariantCulture);
        var closeX = rx + rw;
        var closeY = ry;
        var closeDown = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_ej2_drag_closecross_0", MouseX = closeX, MouseY = closeY, Type = "click", ClientX = (int)closeX, ClientY = (int)closeY };
        var closeUp = new ChartInternalMouseEventArgs { Target = cut.Instance.ID + "_ej2_drag_closecross_0", MouseX = closeX, MouseY = closeY, Type = "click", ClientX = (int)closeX, ClientY = (int)closeY };
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseDown(closeDown, false));
        await cut.InvokeAsync(() => cut.Instance.OnZoomingMouseEnd(closeUp));
        await Task.Delay(150);
        var final = cut.FindAll("rect").Count;
        Assert.True(final < svgAfter, "Clicking close icon should remove the selection rectangle");
    }

