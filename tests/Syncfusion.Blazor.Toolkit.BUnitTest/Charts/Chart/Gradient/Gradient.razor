                            <ChartGradientColorStop Offset="100" Color="#1E88E5" Opacity="1" Brighten="1" Lighten="0" />
                        </ChartGradientColorStops>
                    </ChartLinearGradient>
                </ChartSeries>
                <ChartSeries Name="Series2" Type="ChartSeriesType.Area" DataSource="@SalesData6B" XName="X" YName="Y">
                    <ChartLinearGradient X1="0" Y1="0" X2="0" Y2="1">
                        <ChartGradientColorStops>
                            <ChartGradientColorStop Offset="0" Color="#FF7F50" Opacity="0.8" Brighten="0.7" Lighten="-0.1" />
