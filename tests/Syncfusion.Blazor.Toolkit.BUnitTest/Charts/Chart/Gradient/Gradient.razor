@code {
    SfFixture fixture6 { get; set; }
    async Task CheckingMultipleSeriesGradients(Fixture fixture6)
    {
        var cut = fixture6.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var gradients = cut.FindComponents<ChartLinearGradient>();
        Assert.True(gradients.Count == 2);
        var series1Gradient = gradients[0];
        Assert.True(series1Gradient.Instance.X1 == 0);
        Assert.True(series1Gradient.Instance.Y1 == 0);
        Assert.True(series1Gradient.Instance.X2 == 1);
        Assert.True(series1Gradient.Instance.Y2 == 0);
        var s1Stops = series1Gradient.FindComponents<ChartGradientColorStop>();
        Assert.True(s1Stops.Count == 3);
        Assert.True(s1Stops[0].Instance.Offset == 0);
        Assert.True(s1Stops[0].Instance.Color == "#42A5F5");
        Assert.True(s1Stops[0].Instance.Opacity == 1);
        Assert.True(s1Stops[0].Instance.Brighten == 1);
        Assert.True(s1Stops[0].Instance.Lighten == 0);
        Assert.True(s1Stops[1].Instance.Offset == 50);
        Assert.True(s1Stops[1].Instance.Color == "#66BB6A");
        Assert.True(s1Stops[1].Instance.Opacity == 0.9);
        Assert.True(s1Stops[1].Instance.Brighten == 0.8);
        Assert.True(s1Stops[1].Instance.Lighten == 0.1);
        Assert.True(s1Stops[2].Instance.Offset == 100);
        Assert.True(s1Stops[2].Instance.Color == "#1E88E5");
        Assert.True(s1Stops[2].Instance.Opacity == 1);
        Assert.True(s1Stops[2].Instance.Brighten == 1);
        Assert.True(s1Stops[2].Instance.Lighten == 0);
        var series2Gradient = gradients[1];
        Assert.True(series2Gradient.Instance.X1 == 0);
        Assert.True(series2Gradient.Instance.Y1 == 0);
        Assert.True(series2Gradient.Instance.X2 == 0);
        Assert.True(series2Gradient.Instance.Y2 == 1);
        var s2Stops = series2Gradient.FindComponents<ChartGradientColorStop>();
        Assert.True(s2Stops.Count == 2);
        Assert.True(s2Stops[0].Instance.Offset == 0);
        Assert.True(s2Stops[0].Instance.Color == "#FF7F50");
        Assert.True(s2Stops[0].Instance.Opacity == 0.8);
        Assert.True(s2Stops[0].Instance.Brighten == 0.7);
        Assert.True(s2Stops[0].Instance.Lighten == -0.1);
        Assert.True(s2Stops[1].Instance.Offset == 100);
        Assert.True(s2Stops[1].Instance.Color == "#FFD700");
        Assert.True(s2Stops[1].Instance.Opacity == 1);
        Assert.True(s2Stops[1].Instance.Brighten == 1);
        Assert.True(s2Stops[1].Instance.Lighten == 0.2);
        cut.SetParametersAndRender();
        await cut.Instance.DisposeAsync();
