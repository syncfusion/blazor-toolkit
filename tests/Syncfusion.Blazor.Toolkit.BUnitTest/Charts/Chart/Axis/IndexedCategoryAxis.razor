@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Bunit
@using Xunit

@inherits TestComponentBase


<SfFixture @ref="fixture" TestAsync="CheckingSingleSerieslabel" Description="CheckingSingleSerieslabel">
    <ComponentUnderTest>
        <SfChart ID="container" Height="400" Width="900">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" IsIndexed="true" LabelIntersectAction="LabelIntersectAction.Hide"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis" RangePadding="ChartRangePadding.None"></ChartPrimaryYAxis>
            
                <ChartSeries DataSource="@Sales" XName="x" YName="y" Type="ChartSeriesType.Column" Name="Gold">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            
        </SfChart>
    </ComponentUnderTest>
</SfFixture>
@code {

    SfFixture fixture { get; set; }
    async Task CheckingSingleSerieslabel(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#containerAxisLabels0");
        Assert.True(svg.ChildNodes.Length == 7);
        var svg1 = cut.Find("#container0_AxisLabel_0");
        Assert.True(svg1.TextContent == "Monday\n    ");
        var svg2 = cut.Find("#container0_AxisLabel_6");
        Assert.True(svg2.TextContent == "Monday\n    ");
        cut.SetParametersAndRender();
    }
    public class SalesInfo
    {
        public string x { get; set; }
        public double y { get; set; }
    }

    public List<SalesInfo> Sales = new List<SalesInfo>
{
        new SalesInfo { x = "Monday", y = 50 },
        new SalesInfo { x = "Tuesday", y = 40 },
        new SalesInfo { x = "Wednesday", y = 70 },
        new SalesInfo { x = "Thursday", y = 60 },
        new SalesInfo { x = "Friday", y = 50 },
        new SalesInfo { x = "Monday", y = 40 },
        new SalesInfo { x = "Monday", y = 30 }
    };
}


