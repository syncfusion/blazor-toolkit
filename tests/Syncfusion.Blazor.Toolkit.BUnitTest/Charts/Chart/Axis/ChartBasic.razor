@code {
    SfFixture fixture2 { get; set; }
    SfChart chartObj;
    string customClass = "custom_chart";
    string backgroundImage = "../Images/cloud.png";
    public Query ChartQuery { get; set; }
    public IEnumerable<object> dataSource;
    string[] palettes = new string[] { "green", "red", "blue" };

    async Task CheckingChartPropertiesAndMethods(Fixture fixture2)
    {
        var cut = fixture2.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#container_svg");
        Assert.True(svg.GetAttribute("height") == "400px");
        Assert.True(svg.GetAttribute("width") == "900px");
        cut.SetParametersAndRender(parameters =>
        {
            parameters.Add(p => p.Title, "Chart Title");
            parameters.Add(p => p.IsTransposed, true);
        });
        Assert.True(chartObj._chartRender == null);
        Assert.True(chartObj._isDoubleTap == false);
        Assert.True(chartObj._delayRedraw == false);
        Assert.True(chartObj._startMove == false);
        Assert.True(chartObj._mouseDownX == 0);
        Assert.True(chartObj._mouseDownY == 0);
        Assert.True(chartObj._previousMouseMoveX == 0);
        Assert.True(chartObj._previousMouseMoveY == 0);
        ChartSeries series1 = new ChartSeries { DataSource = MedalDetails, Name = "Gold2", XName = "Country", Width = 2, Opacity = 1, YName = "Gold", Type = ChartSeriesType.Column };
        chartObj.AddSeries(series1);
        List<ChartSeries> seriescollection = new List<ChartSeries>
        {
            series1,
            new ChartSeries{DataSource = MedalDetails, Name ="Silver2", XName="Country", Width=2, Opacity=1, YName="Silver", Type=ChartSeriesType.StepLine}
        };
        await chartObj.AddSeriesAsync(seriescollection);
        chartObj.RemoveSeries(chartObj._visibleSeriesRenderers[1].Series);
        chartObj.RemoveSeries(1);
        chartObj.RemoveStripline((ChartStripline)chartObj._striplineBehindContainer.Elements[0], ZIndexPosition.Behind);
        chartObj.OnChartLongPress();
        List<PointXY> pointList = new List<PointXY> { new PointXY { PointIndex = 2, SeriesIndex = 0 } };
        chartObj.OnSelectionChange(pointList);
        chartObj.RemoveTemplateTooltip();
        chartObj.RefreshLiveData();
        await chartObj.ShowTooltipAsync("USA", 50);
        await chartObj.HideTooltipAsync();
        await chartObj.ShowCrosshairAsync(100, 40);
        await chartObj.HideCrosshairAsync();
        chartObj.Sort("Gold", ListSortDirection.Descending);
        chartObj.ClearSort();
        SfChart.AddAxes(null);
        await chartObj.GetBooleanValuesAsync();
        await chartObj.PerformRedrawAnimationAsync();
        VisibleRangeModel axisRange = new VisibleRangeModel()
        {
            Min = chartObj._axisContainer.Axes["PrimaryXAxis"].Renderer.VisibleRange.Start,
            Max = chartObj._axisContainer.Axes["PrimaryXAxis"].Renderer.VisibleRange.End,
            Delta = chartObj._axisContainer.Axes["PrimaryXAxis"].Renderer.VisibleRange.Delta,
            Interval = chartObj._axisContainer.Axes["PrimaryXAxis"].Renderer.VisibleInterval
        };
        List<AxisData> axisCollection = new List<AxisData>
        {
            new AxisData{ AxisName = "PrimaryXAxis", AxisRange = axisRange, ZoomFactor = 1, ZoomPosition = 1 }
        };
        chartObj.UpdateAxisZoomValues(axisCollection);
        ZoomingEventArgs zoomArgs = new ZoomingEventArgs { AxisCollection = axisCollection };
        chartObj.InvokeZoomingEvents(zoomArgs);
        await chartObj.DelayLayoutChangeAsync();
        chartObj.ClearSeries();
        await chartObj.RefreshAsync();
        await chartObj.DisposeAsync();
    }

    protected void OnInitialized()
    {
        ChartQuery = new Query().Take(10).Where("SalesValue", "GreaterThan", 30, false);
    }

