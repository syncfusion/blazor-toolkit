@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="CheckingYear" Description="DateTime CheckingYear">
    <ComponentUnderTest>
        <SfChart ID="container" Height="600" Width="900">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" Title="Sales Across Years" IntervalType="IntervalType.Years"
                               Minimum="new DateTime(2000, 06, 01)" Maximum="new DateTime(2010, 06, 01)" Interval="1"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="Sales Amount in millions(USD)" RangePadding="ChartRangePadding.Additional"></ChartPrimaryYAxis>
            
                <ChartSeries DataSource="@DateValue" XName="X" YName="Y" Name="series1" Type="ChartSeriesType.Line" Fill="#ACE5FF" Width="2">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            
            <ChartLegendSettings Visible="false"></ChartLegendSettings>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code{
    SfFixture fixture { get; set; }

    async Task CheckingYear(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#containerAxisLabels0");
        Assert.True(svg.ChildNodes.Length == 11);
        Assert.True(svg.ChildNodes[0].TextContent == "2000\n    ");
        Assert.True(svg.ChildNodes[1].TextContent == "2001\n    ");
        Assert.True(svg.ChildNodes[2].TextContent == "2002\n    ");
        Assert.True(svg.ChildNodes[3].TextContent == "2003\n    ");
        Assert.True(svg.ChildNodes[4].TextContent == "2004\n    ");
        Assert.True(svg.ChildNodes[5].TextContent == "2005\n    ");
        Assert.True(svg.ChildNodes[6].TextContent == "2006\n    ");
        Assert.True(svg.ChildNodes[7].TextContent == "2007\n    ");
        Assert.True(svg.ChildNodes[8].TextContent == "2008\n    ");
        Assert.True(svg.ChildNodes[9].TextContent == "2009\n    ");
        Assert.True(svg.ChildNodes[10].TextContent == "2010\n    ");
        cut.SetParametersAndRender();
    }
    public class DateTimeData
    {
        public DateTime X { get; set; }
        public double Y { get; set; }
    }
    public List<DateTimeData> DateValue = new List<DateTimeData>
{
        new DateTimeData{ X = new DateTime(2000, 06, 11), Y = 10},
        new DateTimeData{ X = new DateTime(2002, 03, 07), Y = 30},
        new DateTimeData{ X = new DateTime(2004, 03, 06), Y = 15},
        new DateTimeData{ X = new DateTime(2006, 03, 30), Y = 65},
        new DateTimeData{ X = new DateTime(2008, 03, 08), Y = 90},
        new DateTimeData{ X = new DateTime(2010, 03, 08), Y = 85}
    };
}

