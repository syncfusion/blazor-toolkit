@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="CheckingRowDefinition" Description="Checking RowDefinition">
    <ComponentUnderTest>
        <SfChart ID="container">
            <ChartRows>
                <ChartRow Height="300"></ChartRow>
                <ChartRow Height="100"></ChartRow>
            </ChartRows>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>


@code {

    SfFixture fixture { get; set; }
    bool _canAssert = false;
    async Task CheckingRowDefinition(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var axis = cut.Find("#containerAxisInsideCollection");
        Assert.True(axis.ChildNodes.Length == 2);
        var axis1 = cut.Find("#containerAxisLine_1");
        Assert.True(Convert.ToDouble(axis1.GetAttribute("d").Split(" ")[5]) - (Convert.ToDouble(axis1.GetAttribute("d").Split(" ")[2])) == 300);
        cut.SetParametersAndRender();
    }
}


