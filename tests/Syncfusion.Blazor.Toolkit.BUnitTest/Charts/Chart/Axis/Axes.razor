<SfFixture @ref="fixture75" TestAsync="CheckingAxisLabelStyleDynamicUpdate" Description="CheckingAxisLabelStyleDynamicUpdate">
    <ComponentUnderTest>
        <SfChart ID="container" Title="Weather Reports">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" Title="Countries">
                @{
                    if(axisLabelChange)
                    {
                        <ChartAxisLabelStyle Size="32px" FontFamily="Roboto" FontStyle="Normal" FontWeight="400"></ChartAxisLabelStyle>
                    }
                    else{
                        <ChartAxisLabelStyle Size="36px" FontFamily="Arial" FontStyle="Normal" FontWeight="400"></ChartAxisLabelStyle>
                    }

                    if(axisTitleChange)
                    {
                        <ChartAxisTitleStyle Size="14px" />
                    }
                    else{
                        <ChartAxisTitleStyle Size="16px" />
                    }
                }
            </ChartPrimaryXAxis>>
            <ChartPrimaryYAxis LabelIntersectAction="LabelIntersectAction.Hide">
                @{
                    if(majorGridLinesChange)
                    {
                        <ChartAxisMajorGridLines Width="5" Color="blue"/>
                    }
                    else{
                        <ChartAxisMajorGridLines Width="0.5" Color="red"/>
                    }
                }
            </ChartPrimaryYAxis>
            <ChartSeriesCollection>
                <ChartSeries DataSource="@chartdata52" XName="X" YName="Y" Type="ChartSeriesType.Line" />
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {

    SfFixture fixture75 { get; set; }
    public bool axisLabelChange = true;
    public bool majorGridLinesChange = true;
    public bool axisTitleChange = true;
    async Task CheckingAxisLabelStyleDynamicUpdate(Fixture fixture75)
    {
        var cut = fixture75.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var text = cut.Find("#container0_AxisLabel_0");
        Assert.Equal("32px", text.GetAttribute("font-size"));
        Assert.Equal("Roboto", text.GetAttribute("font-family"));
        Assert.Equal("Normal", text.GetAttribute("font-style"));
        Assert.Equal("400", text.GetAttribute("font-weight"));
        var majorGridline = cut.Find("#container_MajorGridLine_1_3");
        Assert.Equal("blue", majorGridline.GetAttribute("stroke"));
        Assert.Equal("5", majorGridline.GetAttribute("stroke-width"));
        var axisTitle = cut.Find("#container_AxisTitle_0");
        Assert.Equal("14px", axisTitle.GetAttribute("font-size"));
        axisLabelChange = false;
        majorGridLinesChange = false;
        axisTitleChange = false;
        cut.SetParametersAndRender();
        await Task.Delay(200);
        text = cut.Find("#container0_AxisLabel_0");
        Assert.Equal("36px", text.GetAttribute("font-size"));
        Assert.Equal("Arial", text.GetAttribute("font-family"));
        Assert.Equal("Normal", text.GetAttribute("font-style"));
        Assert.Equal("400", text.GetAttribute("font-weight"));
        majorGridline = cut.Find("#container_MajorGridLine_1_3");
        Assert.Equal("red", majorGridline.GetAttribute("stroke"));
        Assert.Equal("0.5", majorGridline.GetAttribute("stroke-width"));
        axisTitle = cut.Find("#container_AxisTitle_0");
        Assert.Equal("16px", axisTitle.GetAttribute("font-size"));
    }
}