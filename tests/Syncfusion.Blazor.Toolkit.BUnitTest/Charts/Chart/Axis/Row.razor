<SfFixture @ref="fixture" TestAsync="CheckingRowDefintionWithPixel" Description="CheckingRowDefintionWithPixel">
    <ComponentUnderTest>
        <SfChart ID="container" Title="Financial Analysis" Height="600">
            <ChartPrimaryXAxis Title="PrimaryXAxis"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis" RangePadding="ChartRangePadding.None" Minimum="110" Maximum="150" Interval="10"></ChartPrimaryYAxis>
            <ChartAxes>
                <ChartAxis RowIndex="1" Name="yAxis1" Minimum="20" Maximum="80" Interval="20" Title="Axis2">
                    <ChartAxisTitleStyle Size="14px" FontWeight="Regular" Color="#282828" FontFamily="Segoe UI" FontStyle="Normal"></ChartAxisTitleStyle>
                    <ChartAxisLabelStyle Size="12px" FontWeight="Regular" Color="#282828" FontFamily="Segoe UI" FontStyle="Normal"></ChartAxisLabelStyle>
                </ChartAxis>
            </ChartAxes>
            <ChartRows>
                <ChartRow Height="300">
                    <ChartBorder Width="4" Color="Red"></ChartBorder>
                </ChartRow>
                <ChartRow Height="300">
                    <ChartBorder Width="4" Color="Blue"></ChartBorder>
                </ChartRow>
            </ChartRows>
            <ChartSeriesCollection>
                <ChartSeries DataSource="@rows" Type="ChartSeriesType.Line" Name="Gold" Fill="#ACE5FF" Width="2" XName="x" YName="y">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
                <ChartSeries DataSource="@rows" Type="ChartSeriesType.Line" Name="Silver" Fill="Red" Width="2" XName="x" YName="y1" YAxisName="yAxis1">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {

    SfFixture fixture { get; set; }
    async Task CheckingRowDefintionWithPixel(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var chartBorder = cut.FindComponent<ChartBorder>();
        var svg = cut.Find("#container_Series_0");
        Assert.True(svg.GetAttribute("stroke") == "#ACE5FF");
        var svg1 = cut.Find("#container_Series_1");
        Assert.True(svg1.GetAttribute("stroke") == "Red");
        await (chartBorder.Instance).DisposeAsync();
        cut.SetParametersAndRender();
    }
    public class RowData
    {
        public double x { get; set; }
        public double y { get; set; }
        public double y1 { get; set; }
    }
    public List<RowData> rows = new List<RowData>
{
        new RowData{ x = 10, y = 124, y1 = 24},
        new RowData{ x = 20, y = 120, y1 = 20},
        new RowData{ x = 30, y = 115, y1 = 55},
        new RowData{ x = 40, y = 147, y1 = 47},
        new RowData{ x = 50, y = 122, y1 = 72}
    };
}


