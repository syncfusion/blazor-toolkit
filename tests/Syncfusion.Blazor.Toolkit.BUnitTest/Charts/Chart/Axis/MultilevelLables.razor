@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Bunit
@using Xunit

@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="CheckingMultiLevelLabels" Description="CheckingMultiLevelLabels">
    <ComponentUnderTest>
        <SfChart ID="container">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" Title="PrimaryXAxis">
                <ChartMultiLevelLabels>
                    <ChartMultiLevelLabel>
                        <ChartCategories>
                            <ChartCategory Start="-0.5" End="2.5" Text="Quater 1"></ChartCategory>
                            <ChartCategory Start="2.5" End="5.5" Text="Quater 2"></ChartCategory>
                            <ChartCategory Start="5.5" End="7.5" Text="Quater 3"></ChartCategory>
                        </ChartCategories>
                    </ChartMultiLevelLabel>
                </ChartMultiLevelLabels>
            </ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="PrimaryYaxis" RangePadding="ChartRangePadding.None"></ChartPrimaryYAxis>
            
                <ChartSeries DataSource="@Sales" XName="x" YName="y" Type="ChartSeriesType.Line" Name="Gold" Fill="Green">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            
        </SfChart>
    </ComponentUnderTest>
</SfFixture>

@code {

    SfFixture fixture { get; set; }
    async Task CheckingMultiLevelLabels(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#container0_Axis_MultiLevelLabel_Level_0_Text_0");
        // Note: Values may vary slightly depending on screen resolution.
        Assert.True(svg.GetAttribute("x") == "161.89374999999998");
        Assert.True(svg.GetAttribute("y") == "376.25");
        var multiLevelLabels = cut.FindComponent<ChartMultiLevelLabels>();
        var multiLevelLabel = cut.FindComponent<ChartMultiLevelLabel>();
        multiLevelLabels.Instance.MultiLevelLabels = new List<ChartMultiLevelLabel>();
        cut.SetParametersAndRender();
        await multiLevelLabels.Instance.DisposeAsync();
        await multiLevelLabel.Instance.DisposeAsync();
    }
    public class SalesInfo
    {
        public string x { get; set; }
        public double? y { get; set; }
    }

    public List<SalesInfo> Sales = new List<SalesInfo>
{
        new SalesInfo { x = "USA", y = 50 },
        new SalesInfo { x = "China", y = 40 },
        new SalesInfo { x = "Japan", y = 70 },
        new SalesInfo { x = "Australia", y = 60 },
        new SalesInfo { x = "France", y = 50 },
        new SalesInfo { x = "Germany", y = null },
        new SalesInfo { x = "Italy", y = 40 },
        new SalesInfo { x = "Sweden", y = 30 }
    };
}


