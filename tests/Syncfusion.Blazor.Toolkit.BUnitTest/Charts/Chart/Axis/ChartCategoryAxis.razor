        new SalesInfo8 { Month = "Apr", SalesValue = 32 },
        new SalesInfo8 { Month = "May", SalesValue = 40 },
        new SalesInfo8 { Month = "Jun", SalesValue = 32 },
        new SalesInfo8 { Month = "Jul", SalesValue = 35 }
    };

    public void axislabels(AxisLabelRenderEventArgs args)
    {
        args.Text = args.Text + "cus";
        {
            if (args.Text == "Jancus")
            {
                args.LabelStyle.Color = "Red";
            }
        }
    }
