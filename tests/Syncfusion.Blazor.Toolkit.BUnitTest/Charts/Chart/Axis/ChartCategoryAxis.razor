@code{
    SfFixture fixture8 { get; set; }
    bool _canAssert8 = false;
    async Task CheckLabelsWithCategoryRange(Fixture fixture8)
    {
        var cut = fixture8.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#containerAxisLabels0");
        Assert.True(svg.ChildNodes.Length == 4);
        Assert.True(svg.ChildNodes[1].TextContent.IndexOf("cus") > -1);

        var axisLabel = cut.Find("#container0_AxisLabel_0");
        Assert.True(axisLabel.GetAttribute("fill") == "Red");

