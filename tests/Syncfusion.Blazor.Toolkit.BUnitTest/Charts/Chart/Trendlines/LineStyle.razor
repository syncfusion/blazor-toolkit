@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Bunit
@using Xunit

@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="TrendLineWithLineStyle" Description="TrendLineWithLineStyle">
    <ComponentUnderTest>
        <SfChart ID="container" Title="Online trading">
            <ChartPrimaryXAxis Title="Months" ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5"></ChartPrimaryYAxis>
            <ChartSeriesCollection>
                <ChartSeries DataSource="@Trends" XName="x" YName="y" Type="ChartSeriesType.Scatter" Name="trend" Fill="#0066FF">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                    <ChartTrendlines>
                        <ChartTrendline Type="TrendlineTypes.Linear" ForwardForecast="5" Name="Linear"
                                        DashArray="4,5" Fill="Red" Width="1.5"></ChartTrendline>
                    </ChartTrendlines>
                </ChartSeries>
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>
@code {

    SfFixture fixture { get; set; }
    async Task TrendLineWithLineStyle(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#container_Series_0_TrendLine_0");
        Assert.True(svg.GetAttribute("stroke-dasharray") == "4,5");
        Assert.True(svg.GetAttribute("stroke") == "Red");
        Assert.True(svg.GetAttribute("stroke-width") == "1.5");
        Assert.True(svg.GetAttribute("fill") == "none");
        cut.SetParametersAndRender();
    }
    public class TrendData
    {
        public DateTime x { get; set; }
        public double y { get; set; }
    }
    public List<TrendData> Trends = new List<TrendData>
{
        new TrendData { x = new DateTime(2000, 2, 11), y = 14 },
        new TrendData { x = new DateTime(2001, 9, 4), y = 20 },
        new TrendData { x = new DateTime(2002, 2, 11), y = 25 },
        new TrendData { x = new DateTime(2003, 9, 16), y = 21 },
        new TrendData { x = new DateTime(2004, 2, 7), y = 13},
        new TrendData { x = new DateTime(2005, 9, 7), y = 18 },
        new TrendData { x = new DateTime(2006, 2, 11), y = 24 },
        new TrendData { x = new DateTime(2007, 9, 14), y = 23 },
        new TrendData { x = new DateTime(2008, 2, 6), y = 19 },
        new TrendData { x = new DateTime(2009, 9, 6), y = 31 },
        new TrendData { x = new DateTime(2010, 2, 11), y = 39},
        new TrendData { x = new DateTime(2011, 9, 11), y = 50 },
        new TrendData { x = new DateTime(2012, 2, 11), y = 24 },
    };
}


