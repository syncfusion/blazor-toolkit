@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Tests
@using Bunit
@using Xunit

@inherits TestComponentBase

<SfFixture @ref="fixture" TestAsync="MovingAverageWithoutSeriesPointsWithTrendlineEmptyCollection" Description="MovingAverageWithoutSeriesPointsWithTrendlineEmptyCollection">
    <ComponentUnderTest>
        <SfChart ID="container" Title="Online trading" Height="600px" Width="850px">
            <ChartPrimaryXAxis Title="Months"></ChartPrimaryXAxis>
            <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5"></ChartPrimaryYAxis>
            <ChartSeriesCollection>
                <ChartSeries XName="x" YName="y" Type="ChartSeriesType.Scatter" Name="trend" Fill="#0066FF">
                    <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
                </ChartSeries>
            </ChartSeriesCollection>
        </SfChart>
    </ComponentUnderTest>
</SfFixture>


@code {

    SfFixture fixture { get; set; }
    async Task MovingAverageWithoutSeriesPointsWithTrendlineEmptyCollection(Fixture fixture)
    {
        var cut = fixture.GetComponentUnderTest<SfChart>();
        await Task.Delay(200);
        var svg = cut.Find("#containerSeriesGroup0").ChildNodes.Length;
        Assert.True(svg == 1);
        var xAxisLabelCollection = cut.Find("#containerAxisLabels0").ChildNodes.Length;
        Assert.True(xAxisLabelCollection == 11);
        var yAxisLabelCollection = cut.Find("#containerAxisLabels1").ChildNodes.Length;
        Assert.True(yAxisLabelCollection == 3);
        cut.SetParametersAndRender();
    }
}


