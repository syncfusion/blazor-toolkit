@page "/TooltipEvent"
@using System.Text.Json;
@using System.Text.Json.Serialization;
@using Bunit
@using Syncfusion.Blazor.Toolkit.Popups
@using Syncfusion.Blazor.Toolkit.Buttons


@* BeforeRender event*@

<SfTooltip @ref="tooltip" Content="Sample ToolTip" Target="#MyButton" OpensOn="Click" Colliding="BeforeCollision">
            <SfButton ID="MyButton" Content="Show Tooltip"></SfButton>
        </SfTooltip>
  
@* BeforeCollision event*@

        <SfTooltip @ref="tooltip" Content="Sample ToolTip" Target="#MyButton" OpensOn="Click" Colliding="BeforeCollision">
            <SfButton ID="MyButton" Content="Show Tooltip"></SfButton>
        </SfTooltip>


@* BeforeOpen event*@

        <SfTooltip @ref="tooltip" Content="Sample ToolTip" Target="#MyButton" OpensOn="Click" OnOpen="OnBeforeOpen">
            <SfButton ID="MyButton" Content="Show Tooltip"></SfButton>
        </SfTooltip>

@* AfterOpen event*@


        <SfTooltip @ref="tooltip" Content="Sample ToolTip" Target="#MyButton" OpensOn="Click" Opened="OnAfterOpen">
            <SfButton ID="MyButton" Content="Show Tooltip"></SfButton>
        </SfTooltip>
   

@* BeforeClose event*@

        <SfTooltip @ref="tooltip" Content="Sample ToolTip" Target="#MyButton" OpensOn="Click" OnClose="OnBeforeClose">
            <SfButton ID="MyButton" Content="Show Tooltip"></SfButton>
        </SfTooltip>


@* AfterClose event*@


        <SfTooltip @ref="tooltip" Content="Sample ToolTip" Target="#MyButton" OpensOn="Click" Closed="OnAfterClose">
            <SfButton ID="MyButton" Content="Show Tooltip"></SfButton>
        </SfTooltip>


@code
{
