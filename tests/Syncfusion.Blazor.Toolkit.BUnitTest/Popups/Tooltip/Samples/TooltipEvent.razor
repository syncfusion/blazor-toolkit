    async Task RenderEvent(Fixture fixture)
    {
        TooltipEventArgs args = new TooltipEventArgs();
        args.Cancel = false;
        args.IsInteracted = true;
        args.CollidedPosition = null;
        args.HasText = false;
        args.Left = 688;
        args.Top = 147;
        var tooltip = fixture.GetComponentUnderTest<SfTooltip>();
        await Task.Delay(200);
        var rootEle = tooltip.Find(".e-tooltip");
        await tooltip.Instance.TriggerBeforeRenderEventAsync(args);
    }

