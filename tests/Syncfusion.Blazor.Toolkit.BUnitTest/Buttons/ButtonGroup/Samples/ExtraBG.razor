@using Syncfusion.Blazor.Toolkit.Buttons

@namespace Syncfusion.Blazor.Toolkit.Tests.Buttons
@* Group 0 — Mode=Default: three plain SfButton children *@
<SfButtonGroup>
    <Button>View</Button>
    <Button>Edit</Button>
    <Button>Delete</Button>
</SfButtonGroup>

@* Group 1 — Mode=Default with Content property (no ChildContent) *@
<SfButtonGroup>
    <Button Content="Left"></Button>
    <Button Content="Center"></Button>
    <Button Content="Right"></Button>
</SfButtonGroup>

@* Group 2 — Mode=Default with ChildContent present (ChildContent takes priority) *@
<SfButtonGroup>
    <Button Content="Fallback"><span>Child</span></Button>
    <Button Content="Fallback"><span>Child</span></Button>
    <Button Content="Fallback"><span>Child</span></Button>
</SfButtonGroup>

@* Group 3 — Mode=Default, empty ChildContent + empty Content = renders an empty button *@
<SfButtonGroup>
    <Button></Button>
    <Button></Button>
    <Button></Button>
</SfButtonGroup>

@* Group 4 — Mode=Default with IsToggle=true *@
<SfButtonGroup>
    <Button IsToggle="true">Toggle</Button>
    <Button IsToggle="false">Normal</Button>
</SfButtonGroup>

@* Group 5 — Mode=Single with Value override *@
<SfButtonGroup Mode="SelectionMode.Single">
    <Button Value="val-a">A</Button>
    <Button Value="val-b">B</Button>
    <Button Value="val-c">C</Button>
</SfButtonGroup>

@* Group 6 — Mode=Multiple with HtmlAttributes (title) applied *@
<SfButtonGroup Mode="SelectionMode.Multiple">
    <Button title="Button One">One</Button>
    <Button title="Button Two">Two</Button>
</SfButtonGroup>

@* Group 7 — Mode=Default with HtmlAttributes (data-testid) applied to SfButton *@
<SfButtonGroup>
    <Button data-testid="btn-attr-test">Attribute</Button>
</SfButtonGroup>
