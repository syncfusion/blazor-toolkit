@page "/chart/category-axis"

@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Data

<h1>Chart - Category Axis</h1>

<div class="test-container">
    <h2>Chart Label Intersection Rotate45</h2>
    <SfChart ID="Chart" Title="Month wise Sales Report" Width="500" Height="400">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" LabelIntersectAction="LabelIntersectAction.Rotate45"></ChartPrimaryXAxis>
        <ChartPrimaryYAxis Title="PrimaryYAxis"></ChartPrimaryYAxis>
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Sales" XName="Month" YName="SalesValue" Type="ChartSeriesType.Column">
                <ChartSeriesAnimation Enable="false"></ChartSeriesAnimation>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

