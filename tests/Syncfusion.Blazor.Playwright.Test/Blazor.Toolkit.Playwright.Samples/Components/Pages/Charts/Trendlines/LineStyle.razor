@page "/trendline-line-style-playwright"
@using Syncfusion.Blazor.Toolkit.Charts
@layout MainLayout

<h2>Trendline – LineStyle & Legend (Playwright Sample)</h2>

<div style="display:flex; flex-direction:column; gap:40px;">

    <!-- 1️⃣ TrendLine with Line Style -->
    <SfChart ID="trendLineStyleChart" Title="Online trading" Width="800px" Height="500px">
        <ChartPrimaryXAxis Title="Months" ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter"
                         Name="trend">
                <ChartSeriesAnimation Enable="false" />
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear"
                                    Name="Linear"
                                    ForwardForecast="5"
                                    DashArray="4,5"
                                    Fill="Red"
                                    Width="1.5" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 2️⃣ TrendLine Legend Visibility -->
    <SfChart ID="trendLegendVisibilityChart" Title="Online trading" Width="800px" Height="500px">
        <ChartPrimaryXAxis Title="Months" ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter"
                         Name="trend">
                <ChartSeriesAnimation Enable="false" />
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear"
                                    Name="Linear"
                                    ForwardForecast="5"
                                    DashArray="4,5"
                                    Fill="Red"
                                    Width="1.5" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 3️⃣ TrendLine Legend Text -->
    <SfChart ID="trendLegendTextChart" Title="Online trading" Width="800px" Height="500px">
        <ChartPrimaryXAxis Title="Months" ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter"
                         Name="trend">
                <ChartSeriesAnimation Enable="false" />
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear"
                                    Name="Linear"
                                    ForwardForecast="5"
                                    DashArray="4,5"
                                    Fill="Red"
                                    Width="1.5" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

</div>

@code {

    public class TrendData
    {
        public DateTime x { get; set; }
        public double y { get; set; }
    }

    public List<TrendData> Trends = new()
    {
        new() { x = new DateTime(2000, 2, 11), y = 14 },
        new() { x = new DateTime(2001, 9, 4),  y = 20 },
        new() { x = new DateTime(2002, 2, 11), y = 25 },
        new() { x = new DateTime(2003, 9, 16), y = 21 },
        new() { x = new DateTime(2004, 2, 7),  y = 13 },
        new() { x = new DateTime(2005, 9, 7),  y = 18 },
        new() { x = new DateTime(2006, 2, 11), y = 24 },
        new() { x = new DateTime(2007, 9, 14), y = 23 },
        new() { x = new DateTime(2008, 2, 6),  y = 19 },
        new() { x = new DateTime(2009, 9, 6),  y = 31 },
        new() { x = new DateTime(2010, 2, 11), y = 39 },
        new() { x = new DateTime(2011, 9, 11), y = 50 },
        new() { x = new DateTime(2012, 2, 11), y = 24 }
    };
}
