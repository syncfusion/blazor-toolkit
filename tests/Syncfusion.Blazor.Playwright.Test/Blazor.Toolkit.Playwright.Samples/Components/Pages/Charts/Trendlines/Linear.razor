@page "/linear-trendline-playwright"
@using Syncfusion.Blazor.Toolkit.Charts
@layout MainLayout

<h2>Linear Trendline – Playwright Converted Sample</h2>

<div style="display:flex; flex-direction:column; gap:50px;">

    <!-- 1️⃣ Without series points – no trendline -->
    <SfChart ID="trendEmptyNoTrendline" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis Title="Months" />
        <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries XName="x" YName="y" Type="ChartSeriesType.Scatter" />
        </ChartSeriesCollection>
    </SfChart>

    <!-- 2️⃣ Without series points – linear trendline -->
    <SfChart ID="trendEmptyWithTrendline" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis Title="Months" />
        <ChartPrimaryYAxis Title="Rupees against Dollars" Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries XName="x" YName="y" Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 3️⃣ With series points – no trendline -->
    <SfChart ID="trendWithDataNoTrendline" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter" />
        </ChartSeriesCollection>
    </SfChart>

    <!-- 4️⃣ With series points – linear trendline -->
    <SfChart ID="trendWithDataAndTrendline" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear">
                        <ChartTrendlineAnimation Enable="false" />
                    </ChartTrendline>
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 5️⃣ Default appearance -->
    <SfChart ID="trendDefaultAppearance" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 6️⃣ Custom appearance -->
    <SfChart ID="trendCustomColor" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear" Fill="Orange" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 7️⃣ Trendline with marker -->
    <SfChart ID="trendWithMarker" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear" Fill="Orange">
                        <ChartTrendlineMarker Visible="true" Fill="Red" />
                    </ChartTrendline>
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 8️⃣ Forward forecast -->
    <SfChart ID="trendForwardForecast" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear"
                                    Fill="Orange"
                                    ForwardForecast="5" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 9️⃣ Backward forecast -->
    <SfChart ID="trendBackwardForecast" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear"
                                    Fill="Orange"
                                    BackwardForecast="4" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

    <!-- 🔟 Intercept -->
    <SfChart ID="trendIntercept" Title="Online trading" Height="600px" Width="850px">
        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" />
        <ChartPrimaryYAxis Interval="5" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@Trends"
                         XName="x"
                         YName="y"
                         Type="ChartSeriesType.Scatter">
                <ChartTrendlines>
                    <ChartTrendline Type="TrendlineTypes.Linear"
                                    Fill="Orange"
                                    Intercept="3" />
                </ChartTrendlines>
            </ChartSeries>
        </ChartSeriesCollection>
    </SfChart>

</div>

@code {
    public class TrendData
    {
        public DateTime x { get; set; }
        public double y { get; set; }
    }

    public List<TrendData> Trends = new()
    {
        new() { x = new DateTime(2000, 2, 11), y = 14 },
        new() { x = new DateTime(2001, 9, 4),  y = 20 },
        new() { x = new DateTime(2002, 2, 11), y = 25 },
        new() { x = new DateTime(2003, 9, 16), y = 21 },
        new() { x = new DateTime(2004, 2, 7),  y = 13 },
        new() { x = new DateTime(2005, 9, 7),  y = 18 },
        new() { x = new DateTime(2006, 2, 11), y = 24 },
        new() { x = new DateTime(2007, 9, 14), y = 23 },
        new() { x = new DateTime(2008, 2, 6),  y = 19 },
        new() { x = new DateTime(2009, 9, 6),  y = 31 },
        new() { x = new DateTime(2010, 2, 11), y = 39 },
        new() { x = new DateTime(2011, 9, 11), y = 50 },
        new() { x = new DateTime(2012, 2, 11), y = 24 }
    };
}