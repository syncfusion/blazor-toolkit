@page "/chart-scrollbar-playwright"
@using Syncfusion.Blazor.Toolkit.Charts
@layout MainLayout

<h2>Chart Scrollbar – Playwright Converted Sample</h2>

<div style="display:flex; flex-direction:column; gap:50px;">

    <!-- 1️⃣ Default scrollbar rendering -->
    <SfChart ID="scrollbarDefault"
             Width="900px"
             Height="450px">
        <ChartPrimaryXAxis ZoomFactor="0.5"
                           ZoomPosition="0.5"
                           ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                           LabelFormat="yyyy"
                           IntervalType="IntervalType.Years" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@ChartPoints"
                         XName="Period"
                         YName="JohnRevenue"
                         Type="ChartSeriesType.Column">
                <ChartSeriesAnimation Enable="false" />
            </ChartSeries>
        </ChartSeriesCollection>
        <ChartZoomSettings EnableScrollbar="true"
                           EnableSelectionZooming="true"
                           Mode="ZoomMode.XY" />
    </SfChart>

    <!-- 2️⃣ Scrollbar refresh stability -->
    <SfChart ID="scrollbarRefresh"
             Width="900px"
             Height="450px">
        <ChartPrimaryXAxis ZoomFactor="0.6"
                           ZoomPosition="0.2"
                           ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                           LabelFormat="yyyy" />
        <ChartSeriesCollection>
            <ChartSeries DataSource="@ChartPoints"
                         XName="Period"
                         YName="JohnRevenue"
                         Type="ChartSeriesType.Column">
                <ChartSeriesAnimation Enable="false" />
            </ChartSeries>
        </ChartSeriesCollection>
        <ChartZoomSettings EnableScrollbar="true" />
    </SfChart>

    <!-- 3️⃣ Scrollbar customization -->
    <SfChart ID="scrollbarCustom"
             Title="Sales History of Product X"
             Width="900px"
             Height="450px">

        <ChartPrimaryXAxis EdgeLabelPlacement="EdgeLabelPlacement.Shift">
            <ChartAxisScrollbarSettings Enable="false"
                                        Height="16"
                                        EnableZoom="true"
                                        TrackRadius="8"
                                        ScrollbarRadius="8"
                                        GripColor="red"
                                        TrackColor="blue"
                                        ScrollbarColor="yellow" />
        </ChartPrimaryXAxis>

        <ChartPrimaryYAxis>
            <ChartAxisScrollbarSettings Enable="false"
                                        Height="16"
                                        EnableZoom="true"
                                        TrackRadius="8"
                                        ScrollbarRadius="8"
                                        GripColor="red"
                                        TrackColor="blue"
                                        ScrollbarColor="yellow" />
        </ChartPrimaryYAxis>

        <ChartZoomSettings EnableScrollbar="true"
                           EnableMouseWheelZooming="true"
                           EnableSelectionZooming="true"
                           EnablePinchZooming="true" />

        <ChartSeriesCollection>
            <ChartSeries DataSource="@SalesDetails"
                         XName="X"
                         YName="Y"
                         Type="ChartSeriesType.Area" />
        </ChartSeriesCollection>

    </SfChart>

</div>

@code {

    public class TrackballChartData
    {
        public DateTime Period { get; set; }
        public double JohnRevenue { get; set; }
    }

    public List<TrackballChartData> ChartPoints = new()
    {
        new() { Period = new DateTime(2000, 2, 11), JohnRevenue = 14 },
        new() { Period = new DateTime(2001, 2, 11), JohnRevenue = 25 },
        new() { Period = new DateTime(2002, 2, 7),  JohnRevenue = 13 },
        new() { Period = new DateTime(2003, 2, 11), JohnRevenue = 24 },
        new() { Period = new DateTime(2004, 2, 6),  JohnRevenue = 19 },
        new() { Period = new DateTime(2005, 2, 11), JohnRevenue = 39 },
        new() { Period = new DateTime(2006, 2, 11), JohnRevenue = 24 }
    };

    public class ChartData
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    public List<ChartData> SalesDetails = new()
    {
        new() { X = 1900, Y = 4 },
        new() { X = 1920, Y = 3.0 },
        new() { X = 1940, Y = 3.8 },
        new() { X = 1960, Y = 3.4 },
        new() { X = 2000, Y = 3.9 }
    };
}