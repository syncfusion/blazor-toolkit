@page "/button-group/content-variations"
@using Syncfusion.Blazor.Toolkit.Buttons
@layout MainLayout

<h1>Button Group - Content Variations</h1>

<div class="test-container">
    <h2>Text-Only Buttons</h2>
    <SfButtonGroup id="bg-text-only" Mode="SelectionMode.Single">
        <Button Content="All" id="view-all"></Button>
        <Button Content="Pending" id="view-pending"></Button>
        <Button Content="Completed" id="view-completed"></Button>
    </SfButtonGroup>
</div>

<div class="test-container">
    <h2>Icon and Text Buttons</h2>
    <SfButtonGroup id="bg-icon-text">
        <Button IconCss="e-icons e-cut" Content="Cut" id="btn-cut"></Button>
        <Button IconCss="e-icons e-copy" Content="Copy" id="btn-copy"></Button>
        <Button IconCss="e-icons e-paste" Content="Paste" id="btn-paste"></Button>
    </SfButtonGroup>
</div>

<div class="test-container">
    <h2>Icon-Only Buttons</h2>
    <SfButtonGroup id="bg-icon-only">
        <Button IconCss="e-icons e-bold" id="fmt-bold"></Button>
        <Button IconCss="e-icons e-italic" id="fmt-italic"></Button>
        <Button IconCss="e-icons e-underline" id="fmt-underline"></Button>
    </SfButtonGroup>
</div>

<div class="test-container">
    <h2>Buttons with Custom Content</h2>
    <SfButtonGroup id="bg-custom" Mode="SelectionMode.Single">
        <Button id="custom-1">
            <span>Custom</span>
        </Button>
        <Button id="custom-2">
            <span>Content</span>
        </Button>
    </SfButtonGroup>
</div>

<style>
    .test-container {
        padding: 20px;
        border: 1px solid #ddd;
        margin: 10px 0;
        border-radius: 4px;
        background-color: #f9f9f9;
    }
    
    h2 {
        margin-top: 20px;
        font-size: 18px;
        font-weight: 600;
    }
    
    .e-icons {
        display: inline-block !important;
        margin: 0 4px;
    }
</style>

