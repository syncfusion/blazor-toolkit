@page "/button-group/basic-rendering"
@using Syncfusion.Blazor.Toolkit.Buttons
@layout MainLayout

<h1>Button Group - Basic Rendering</h1>

<div class="test-container">
    <h2>Basic Button Group (Default Mode)</h2>
    <SfButtonGroup id="bg-basic" CssClass="e-basic-group">
        <Button Content="Left" id="btn-left"></Button>
        <Button Content="Center" id="btn-center"></Button>
        <Button Content="Right" id="btn-right"></Button>
    </SfButtonGroup>
</div>

<div class="test-container">
    <h2>Button Group with Single Selection</h2>
    <SfButtonGroup id="bg-single" Mode="SelectionMode.Single">
        <Button Content="Option 1" id="opt-1"></Button>
        <Button Content="Option 2" id="opt-2"></Button>
        <Button Content="Option 3" id="opt-3"></Button>
    </SfButtonGroup>
    <p>Selected: <strong id="single-selected">None</strong></p>
</div>

<div class="test-container">
    <h2>Button Group with Multiple Selection</h2>
    <SfButtonGroup id="bg-multiple" Mode="SelectionMode.Multiple">
        <Button Content="Bold" id="opt-bold"></Button>
        <Button Content="Italic" id="opt-italic"></Button>
        <Button Content="Underline" id="opt-underline"></Button>
    </SfButtonGroup>
    <p>Selected: <strong id="multiple-selected">None</strong></p>
</div>

<style>
    .test-container {
        padding: 20px;
        border: 1px solid #ddd;
        margin: 10px 0;
        border-radius: 4px;
        background-color: #f9f9f9;
    }
    
    h2 {
        margin-top: 20px;
        font-size: 18px;
        font-weight: 600;
    }
    
    p {
        margin-top: 15px;
        font-size: 14px;
    }
</style>

