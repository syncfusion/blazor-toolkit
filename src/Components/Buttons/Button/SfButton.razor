@namespace Syncfusion.Blazor.Toolkit.Buttons
@inherits SfBaseComponent

<button
        type="@Type.ToString().ToLower()"
        @attributes="HtmlAttributes"
        class="@_buttonCssClass"
        disabled="@Disabled"
        aria-disabled="@GetAriaDisabled()"
        aria-pressed="@GetAriaPressed()"
        @onclick="HandleClickAsync">
  
    @{
        bool isRtl = SyncfusionService?._options?.EnableRtl ?? false;
        bool isIconBeforeContent = !isRtl
            ? (IconPosition == IconPosition.Left || IconPosition == IconPosition.Top)
            : (IconPosition == IconPosition.Right || IconPosition == IconPosition.Bottom);
    }
    @if (!string.IsNullOrEmpty(IconCss) && isIconBeforeContent)
    {
        <span class="@IconCss @_iconCssModifier" aria-hidden="true"></span>
    }
	@if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @Content
    }
    @if (!string.IsNullOrEmpty(IconCss) && !isIconBeforeContent)
    {
        <span class="@IconCss @_iconCssModifier" aria-hidden="true"></span>
    }
</button>