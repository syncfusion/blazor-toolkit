@page "/browser-support"

<PageTitle>Browser Compatibility | Syncfusion Blazor Toolkit</PageTitle>

<style>
    :root {
        /* Table-specific variables (light defaults) */
        --table-bg: var(--panel-bg);
        --table-border: rgba(0,0,0,0.06);
        --table-border-radius: 6px;
        --table-header-bg: rgba(0,0,0,0.02);
        --table-header-color: var(--top-text);
        --table-row-bg: #ffffff;
        --table-row-border: rgba(0,0,0,0.04);
    }

    .dark {
        --table-bg: var(--panel-bg);
        --table-border: rgba(255,255,255,0.10);
        --table-header-bg: rgba(255,255,255,0.04);
        --table-header-color: var(--top-text);
        --table-row-bg: rgba(255,255,255,0.01);
        --table-row-border: rgba(255,255,255,0.04);
    }

    .table {
        background-color: var(--table-bg, #ffffff);
        color: var(--text-color, #111827);
        border: 1px solid var(--table-border, rgba(0,0,0,0.06));
        border-radius: var(--table-border-radius, 6px);
        overflow: hidden;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table thead th {
        background-color: var(--table-header-bg, rgba(0,0,0,0.02));
        color: var(--table-header-color, var(--top-text, #111827));
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 600;
        border-bottom: 1px solid var(--table-row-border, rgba(0,0,0,0.04));
    }

    .table tbody td {
        padding: 0.75rem 1rem;
        border-top: 1px solid var(--table-row-border, rgba(0,0,0,0.04));
        background-color: var(--table-row-bg, #ffffff);
        color: var(--text-color, #111827);
    }

</style>

<Description>
    <Header>
        <h4>Browser Support</h4>
    </Header>
    <Content>
        <p><a href="https://www.syncfusion.com/blazor-toolkit" target="_blank" rel="noreferrer noopener">Syncfusion<sup style="font-size:70%">&reg;</sup> Toolkit for Blazor</a> components are fully supported in modern browsers on both desktop and mobile devices running Windows, Linux, or macOS. The following table shows the specific browser versions required for optimal compatibility with Syncfusion Blazor Toolkit.</p>
    </Content>
</Description>

<Description>
    <Header>
        <h5>Supported browsers</h5>
    </Header>
    <Content>
        <table class="table">
            <thead>
                <tr>
                    <th>Browser</th>
                    <th>Versions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Google Chrome (including Android &amp; iOS)</td>
                    <td>Latest Version</td>
                </tr>
                <tr>
                    <td>Mozilla Firefox</td>
                    <td>Latest Version</td>
                </tr>
                <tr>
                    <td>Microsoft Edge</td>
                    <td>Latest Version</td>
                </tr>
                <tr>
                    <td>Apple Safari (including iOS)</td>
                    <td>Latest Version</td>
                </tr>
            </tbody>
        </table>
    </Content>
</Description>

