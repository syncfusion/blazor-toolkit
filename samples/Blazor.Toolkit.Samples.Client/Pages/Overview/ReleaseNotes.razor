@page "/release-notes"
@page "/release-notes/{version}"
@inject HttpClient Http
@inject ILogger<ReleaseNotes> Logger
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<PageTitle>Release Notes @(string.IsNullOrEmpty(DisplayVersion) ? "" : $"- v{DisplayVersion}") | Syncfusion Blazor Toolkit</PageTitle>

@* Main Content Area Only - Layout sidebars are in MainLayout *@
<main class="release-notes-main" @ref="_mainContentRef">
    @if (IsLoading)
    {
        <div class="loading-container">
            <div class="skeleton-loader">
                <div class="skeleton skeleton-title"></div>
                <div class="skeleton skeleton-meta"></div>
                <div class="skeleton skeleton-heading"></div>
                <div class="skeleton skeleton-text"></div>
                <div class="skeleton skeleton-text short"></div>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-container">
            <div class="error-icon">⚠️</div>
            <h2>Unable to Load Release Notes</h2>
            <p>@ErrorMessage</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(HtmlContent))
    {
        <article class="release-content">
            @* Content Header *@
            <header class="content-header">
                <h1 class="release-title">Syncfusion Toolkit for Blazor - v@(DisplayVersion) Release Notes</h1>
                <div class="release-meta">
                    <span class="meta-badge version-badge-large">
                        <span class="badge-icon">📦</span> v@(DisplayVersion)
                    </span>
                    @if (!string.IsNullOrEmpty(ReleaseDate))
                    {
                        <span class="meta-badge date-badge">
                            <span class="badge-icon">📅</span> @ReleaseDate
                        </span>
                    }
                </div>
            </header>

            @* Filter Dropdown *@
            <div class="filter-bar">
                <select id="contentFilter" value="@CurrentFilter" @onchange="OnFilterChanged">
                    <option value="all">All</option>
                    <option value="features">Features</option>
                    <option value="bugfixes">Bug Fixes</option>
                    <option value="breaking">Breaking Changes</option>
                </select>
            </div>

            @* Rendered Markdown Content *@
            <div class="markdown-content" id="markdown-content">
                @((MarkupString)HtmlContent)
            </div>
        </article>
    }
</main>

@code {
    [Parameter]
    public string? Version { get; set; }

    private bool IsLoading { get; set; } = true;
    private string HtmlContent { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private string SelectedVersion { get; set; } = string.Empty;
    private string DisplayVersion { get; set; } = string.Empty;
    private string ReleaseDate { get; set; } = string.Empty;
    private string CurrentFilter { get; set; } = "all";
    
    private ElementReference _mainContentRef;
    private DotNetObjectReference<ReleaseNotes>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnParametersSetAsync()
    {
        await InitializeAsync().ConfigureAwait(true);
    }

    private async Task InitializeAsync()
    {
        try
        {
            // Bundle loading state update in InvokeAsync
            await InvokeAsync(() =>
            {
                IsLoading = true;
                ErrorMessage = string.Empty;
                HtmlContent = string.Empty;
                StateHasChanged();
            }).ConfigureAwait(true);

            // Resolve version
            string versionToLoad;
            if (!string.IsNullOrEmpty(Version))
            {
                versionToLoad = Version.StartsWith("v") ? Version : "v" + Version;
            }
            else
            {
                versionToLoad = "v1.0.1";
            }

            if (versionToLoad != SelectedVersion)
            {
                SelectedVersion = versionToLoad;
                DisplayVersion = versionToLoad.TrimStart('v');
                await LoadReleaseNotesAsync().ConfigureAwait(true);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Initialization failed");
            await InvokeAsync(() =>
            {
                ErrorMessage = ex.Message;
                IsLoading = false;
                StateHasChanged();
            }).ConfigureAwait(true);
        }
    }

    private async Task RefreshRightTocAsync()
    {
        try
        {
            if (_dotNetRef != null)
            {
                await JS.InvokeVoidAsync("toc.refreshToc", _dotNetRef).ConfigureAwait(true);
            }
            
            // Force RightToc to re-render by triggering location change
            var currentUri = NavigationManager.Uri;
            NavigationManager.NavigateTo(currentUri, forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogDebug("RightToc refresh skipped: {Message}", ex.Message);
        }
    }

    private async Task LoadReleaseNotesAsync()
    {
        var cleanVersion = SelectedVersion.TrimStart('v');
        Logger.LogInformation("Loading release notes for version: {Version}", cleanVersion);

        // Build absolute URL using NavigationManager base address
        var baseUri = NavigationManager.BaseUri;
        var markdownUrl = $"{baseUri}release-notes/v{cleanVersion}.md";
        
        var markdown = await Http.GetStringAsync(markdownUrl).ConfigureAwait(true);
        
        // Extract release date from YAML front matter if present
        var releaseDate = ExtractReleaseDate(markdown);
        
        // Remove YAML front matter
        if (markdown.StartsWith("---"))
        {
            var endIndex = markdown.IndexOf("---", 3);
            if (endIndex > 0)
            {
                markdown = markdown[(endIndex + 3)..].Trim();
            }
        }

        // Convert Markdown to HTML
        var html = Markdig.Markdown.ToHtml(markdown);
        
        // Add IDs to h2 and h3 headings for TOC linking
        html = AddHeadingIdsToHtml(html);
        Logger.LogInformation("Converted to HTML, length: {Length}", html.Length);
        
        // Bundle ALL state updates in InvokeAsync for guaranteed render
        await InvokeAsync(async () =>
        {
            HtmlContent = html;
            ReleaseDate = releaseDate;
            IsLoading = false;
            StateHasChanged();
            
            // Yield to ensure render completes before TOC refresh
            await Task.Yield();
        }).ConfigureAwait(true);
        
        // Refresh TOC after state is updated
        await RefreshRightTocAsync().ConfigureAwait(true);
    }

    private string ExtractReleaseDate(string markdown)
    {
        // Try to extract date from YAML front matter
        var dateRegex = new System.Text.RegularExpressions.Regex(@"date:\s*(\d{4}-\d{2}-\d{2})", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        var match = dateRegex.Match(markdown);
        if (match.Success)
        {
            return DateTime.Parse(match.Groups[1].Value).ToString("MMMM dd, yyyy");
        }
        
        // Look for date in various formats in the content
        var patterns = new[]
        {
            @"(\d{1,2}\s+\w+\s+\d{4})",
            @"(\w+\s+\d{1,2},\s+\d{4})",
            @"(\d{4}-\d{2}-\d{2})"
        };
        
        foreach (var pattern in patterns)
        {
            var dateMatch = new System.Text.RegularExpressions.Regex(pattern).Match(markdown);
            if (dateMatch.Success)
            {
                if (DateTime.TryParse(dateMatch.Groups[1].Value, out var date))
                {
                    return date.ToString("MMMM dd, yyyy");
                }
            }
        }
        
        return DateTime.Now.ToString("MMMM dd, yyyy"); // Default fallback
    }

    private string AddHeadingIdsToHtml(string html)
    {
        // Add id attributes to h2 and h3 headings for TOC linking
        var regex = new System.Text.RegularExpressions.Regex(@"<(h[23])[^>]*>([^<]+)</h[23]>", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return regex.Replace(html, match =>
        {
            var tag = match.Groups[1].Value;
            var text = match.Groups[2].Value.Trim();
            var id = GenerateSlug(text);
            return $"<{tag} id=\"{id}\">{text}</{tag}>";
        });
    }

    private string GenerateSlug(string text)
    {
        return text.ToLowerInvariant()
            .Replace(" ", "-")
            .Replace(".", "")
            .Replace(":", "")
            .Replace("(", "")
            .Replace(")", "")
            .Replace(",", "")
            .Replace(";", "");
    }

    private async Task OnFilterChanged(ChangeEventArgs e)
    {
        if (e.Value is string filter)
        {
            CurrentFilter = filter;
            await ApplyFilter(filter);
        }
    }

    private async Task ApplyFilter(string filter)
    {
        if (filter == "all")
        {
            await JS.InvokeVoidAsync("blazorInterop.showAllSections", "markdown-content");
        }
        else
        {
            await JS.InvokeVoidAsync("blazorInterop.filterSections", "markdown-content", filter);
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}

<style>
    /* Release Notes Main Content - Uses existing layout (no duplicate sidebars) */
    .release-notes-main {
        max-width: 100%;
    }

    .content-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
    }

    .release-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-color, #1f2937);
        margin: 0 0 1rem 0;
        line-height: 1.3;
    }

    .release-meta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .meta-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--panel-bg, #f9fafb);
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .version-badge-large {
        background: var(--accent, #6750a4);
        color: var(--accent-foreground, #ffffff);
        border-color: var(--accent, #6750a4);
    }

    .date-badge {
        color: var(--text-color, #1f2937);
    }

    .badge-icon {
        font-size: 1rem;
    }

    /* Filter Bar */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: -7.5rem;
        padding: 1rem;
        background: var(--panel-bg, #f9fafb);
        float: right;
    }

    .filter-bar label {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-color-secondary, #6b7280);
    }

    .filter-bar select {
        padding: 0.5rem 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 6px;
        background: white;
        font-size: 0.9rem;
        cursor: pointer;
    }

    /* Loading State - Skeleton */
    .loading-container {
        padding: 2rem 0;
    }

    .skeleton-loader {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .skeleton {
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 4px;
    }

    .skeleton-title {
        height: 2.5rem;
        width: 70%;
    }

    .skeleton-meta {
        height: 1.5rem;
        width: 40%;
    }

    .skeleton-heading {
        height: 1.5rem;
        width: 50%;
        margin-top: 1rem;
    }

    .skeleton-text {
        height: 1rem;
        width: 100%;
    }

    .skeleton-text.short {
        width: 75%;
    }
    
    @@keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
    }

    /* Error State */
    .error-container {
        text-align: center;
        padding: 4rem 2rem;
    }

    .error-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .error-container h2 {
        color: var(--text-color, #1f2937);
        margin-bottom: 0.5rem;
    }

    .error-container p {
        color: var(--text-color-secondary, #6b7280);
    }

    /* Markdown Content Styles */
    .markdown-content {
        line-height: 1.7;
        color: var(--text-color, #1f2937);
    }

    .markdown-content :global(h1) {
        display: none; /* Hidden as we show custom title */
    }

    .markdown-content :global(h2) {
        font-size: 1.375rem;
        font-weight: 600;
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
        color: var(--text-color, #1f2937);
    }

    .markdown-content :global(h3) {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 1.5rem 0 0.75rem;
        color: var(--text-color, #1f2937);
    }

    .markdown-content :global(p) {
        margin: 1rem 0;
    }

    .markdown-content :global(ul),
    .markdown-content :global(ol) {
        margin: 1rem 0;
        padding-left: 1.5rem;
    }

    .markdown-content :global(li) {
        margin: 0.5rem 0;
    }

    .markdown-content :global(strong) {
        font-weight: 600;
    }

    .markdown-content :global(hr) {
        border: none;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        margin: 2rem 0;
    }

    .markdown-content :global(a) {
        color: var(--accent, #6750a4);
        text-decoration: none;
    }

    .markdown-content :global(a:hover) {
        text-decoration: underline;
    }

    /* Responsive */
    @@media (max-width: 640px) {
        .release-title {
            font-size: 1.5rem;
        }

        .release-meta {
            flex-direction: column;
            gap: 0.5rem;
        }

        .content-header {
            margin-bottom: 1.5rem;
        }
    }
</style>

<script>
    window.blazorInterop = {
        filterSections: function(containerId, filterType) {
            const container = document.getElementById(containerId);
            if (!container) return;

            const sectionMapping = {
                'features': ['Features', 'Button', 'ButtonGroup', 'Calendar', 'DatePicker', 'DateTimePicker', 'TimePicker', 'Chart', 'CheckBox', 'NumericTextBox', 'RadioButton', 'Switch', 'TextArea', 'TextBox', 'Uploader', 'Dialog', 'Popup', 'Tooltip', 'PreDefinedDialog', 'Spinner'],
                'bugfixes': ['Bug Fixes'],
                'breaking': ['Breaking Changes']
            };

            const showAll = filterType === 'all';
            const keywords = showAll ? [] : sectionMapping[filterType] || [];

            container.querySelectorAll('h2').forEach(h2 => {
                if (showAll) {
                    h2.style.display = '';
                    let nextEl = h2.nextElementSibling;
                    while (nextEl && nextEl.tagName !== 'H2') {
                        nextEl.style.display = '';
                        nextEl = nextEl.nextElementSibling;
                    }
                } else {
                    const shouldShow = keywords.some(kw => h2.textContent.includes(kw));
                    h2.style.display = shouldShow ? '' : 'none';
                    
                    let nextEl = h2.nextElementSibling;
                    while (nextEl && nextEl.tagName !== 'H2') {
                        nextEl.style.display = shouldShow ? '' : 'none';
                        nextEl = nextEl.nextElementSibling;
                    }
                }
            });
        },

        showAllSections: function(containerId) {
            const container = document.getElementById(containerId);
            if (!container) return;

            container.querySelectorAll('h2, h3, p, ul, li').forEach(el => {
                el.style.display = '';
            });
        }
    };
</script>
