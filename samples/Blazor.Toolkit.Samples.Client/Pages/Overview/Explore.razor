@page "/"
@implements IAsyncDisposable

@using Microsoft.AspNetCore.Components.Routing
@using System.Linq
@inject IJSRuntime JS

<PageTitle>Explore Blazor Components | Syncfusion Toolkit</PageTitle>

<div class="explore-page container">
    <!-- Main heading: larger, consistent font size -->
    <h2 class="h2-title">Explore Syncfusion</h2>
    <p>
        The Syncfusion Blazor Toolkit is a lightweight, open-source collection of high-performance UI components for building Server and WebAssembly Blazor applications. It delivers modern, accessible controls that accelerate development and integrate easily into existing projects.
        Discover the sample components in this toolkit. Click any tile to open the component demo page.
    </p>

    @foreach (var category in Categories)
    {
        <section class="category-section">
            <h4 class="mb-1">@category.Name</h4>
            <p class="text-muted small mb-2">@category.Tagline</p>

            <div class="component-grid @category.Name">
                @foreach (var component in category.Components.Where(c => c.Available))
                {
                    <NavLink class="component-tile" href="@component.Href" Match="NavLinkMatch.All">
                        <span class="component-icon-box @component.Name">
                            <img class="component-icon-image" src="@GetIconPath(component.IconClass)" alt="@component.Name" loading="lazy" />
                        </span>
                        <span class="component-title">@component.Name</span>
                    </NavLink>
                }
            </div>
        </section>
    }
</div>

@code {
    // Add Available flag to hide placeholders
    record ComponentItem(string Name, string Href, string IconClass, bool Available = true);
    record Category(string Name, string Tagline, List<ComponentItem> Components);

    private List<Category> Categories = new()
    {
        new Category("Charts","Line, Area, Colum, Bar Charts…", new List<ComponentItem>
        {
            new ComponentItem("Chart","charts/overview", "ci-chart"),
        }),

        new Category("Buttons","Regular, Icon, FAB…", new List<ComponentItem>
        {
            new ComponentItem("Button","buttons/button", "ci-button"),
            new ComponentItem("Button Group","buttons/button-group", "ci-buttongroup")
        }),

        new Category("Calendars","Date & Time Pickers…", new List<ComponentItem>
        {
            new ComponentItem("Calendar","calendars/calendar", "ci-calendar"),
            new ComponentItem("DatePicker","calendars/datepicker", "ci-datepicker"),
            new ComponentItem("DateTime Picker","calendars/datetimepicker", "ci-datetime"),
            new ComponentItem("TimePicker","calendars/timepicker", "ci-timepicker"),
        }),

        new Category("Spinner","Loading Indicators…", new List<ComponentItem>
        {
            new ComponentItem("Spinner","spinner", "ci-spinner"),
        }),

        new Category("Inputs","Forms, Selections…", new List<ComponentItem>
        {
            new ComponentItem("Checkbox","inputs/checkbox", "ci-checkbox"),
            new ComponentItem("File Upload","inputs/uploader", "ci-upload"),
            new ComponentItem("Numeric Textbox","inputs/numerictextbox", "ci-numeric"),
            new ComponentItem("TextArea","inputs/textarea", "ci-textarea"),
            new ComponentItem("TextBox","inputs/textbox", "ci-textbox"),
            new ComponentItem("Radio Button","inputs/radio-button", "ci-radio"),
            new ComponentItem("Switch","inputs/switch", "ci-switch"),
        }),

        new Category("Popups","Dialogs, Tooltips…", new List<ComponentItem>
        {
            new ComponentItem("Dialog","popups/dialog", "ci-dialog"),
            new ComponentItem("Tooltip","popups/tooltip", "ci-tooltip"),
        })
    };

    private static readonly Dictionary<string, string> IconSvgFiles = new(StringComparer.OrdinalIgnoreCase)
    {
        ["ci-chart"] = "Charts.svg",
        ["ci-button"] = "Button.svg",
        ["ci-buttongroup"] = "Button Group.svg",
        ["ci-calendar"] = "Calendar.svg",
        ["ci-datepicker"] = "Date Picker.svg",
        ["ci-datetime"] = "DateTime Picker.svg",
        ["ci-timepicker"] = "TimePicker.svg",
        ["ci-spinner"] = "Spinners.svg",
        ["ci-checkbox"] = "Check Box.svg",
        ["ci-upload"] = "File Upload.svg",
        ["ci-numeric"] = "Numeric TextBox.svg",
        ["ci-textarea"] = "TextArea.svg",
        ["ci-textbox"] = "Textbox.svg",
        ["ci-radio"] = "Radio Button.svg",
        ["ci-switch"] = "Switch.svg",
        ["ci-dialog"] = "Dialog.svg",
        ["ci-tooltip"] = "Tooltip.svg"
    };

    private bool _isDarkTheme;
    private DotNetObjectReference<Explore>? _themeRef;

    private string GetIconPath(string iconClass)
    {
        var folder = _isDarkTheme ? "svg-dark" : "svg-light";

        return IconSvgFiles.TryGetValue(iconClass, out var fileName)
            ? $"{folder}/{fileName}"
            : $"{folder}/Charts.svg";
    }

    private bool _revealInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_revealInitialized)
        {
            _revealInitialized = true;
            try
            {
                await JS.InvokeVoidAsync("scrollEffects.initReveal", ".component-tile");
            }
            catch { /* fail silently if JS not available */ }
        }

        if (firstRender)
        {
            try
            {
                var currentTheme = await JS.InvokeAsync<string>("mainLayout.initTheme");
                _isDarkTheme = currentTheme == "dark";
                await InvokeAsync(StateHasChanged);
                _themeRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("mainLayout.observeTheme", _themeRef);
            }
            catch { /* fail silently if JS not available */ }
        }
    }

    [JSInvokable]
    public Task NotifyThemeChanged(string theme)
    {
        var isDarkTheme = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);

        if (_isDarkTheme != isDarkTheme)
        {
            _isDarkTheme = isDarkTheme;
            return InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_revealInitialized)
        {
            try { await JS.InvokeVoidAsync("scrollEffects.dispose"); } catch { }
        }

        try { await JS.InvokeVoidAsync("mainLayout.disposeThemeObserver"); } catch { }

        _themeRef?.Dispose();
    }
}

<style>
    :root {
        --page-bg: #ffffff;
        --text-color: #0f172a;
        --muted-color: #6c757d;
        --card-bg: #ffffff;
        --card-border: #d5d0db;
        --card-shadow: 0px 4px 14px 0px #251C3021, 0px 0px 20px 4px #6750A41F;
        --card-hover-border: #592C8C;
        --card-hover-shadow: 0 4px 10px rgba(16, 24, 40, .08), 0 16px 30px rgba(16, 24, 40, .08);
        --icon-box-bg: #F7F4FA;
        --icon-placeholder-border: rgba(122, 92, 196, .45);
        --icon-placeholder-bg: rgba(255, 255, 255, .75);
        --title-color: #0F172A;
        --title-border: rgba(127, 96, 187, .12);
    }

    .dark {
        --page-bg: #0b1220;
        --text-color: #e5e7eb;
        --muted-color: #9aa4b2;
        --card-bg: #111827;
        --card-border: #2a3346;
        --card-shadow: 0 10px 24px rgba(0, 0, 0, .35);
        --card-hover-border: #a78bfa;
        --card-hover-shadow: 0 12px 28px rgba(0, 0, 0, .45);
        --icon-box-bg: #162033;
        --icon-placeholder-border: rgba(167, 139, 250, .55);
        --icon-placeholder-bg: rgba(17, 24, 39, .85);
        --title-color: #f3f4f6;
        --title-border: rgba(167, 139, 250, .18);
    }

    .explore-page {
        font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-size: 15px;
        background: var(--page-bg);
        color: var(--text-color);
        transition: background 160ms ease, color 160ms ease;
        box-sizing: border-box;
    }

        .explore-page .text-muted {
            color: var(--muted-color) !important;
            transition: color 160ms ease;
            font-size: 13px;
        }

        .explore-page h2 {
            font-size: 20px;
            margin-bottom: 6px;
            color: var(--text-color);
        }

        .explore-page h4 {
            font-size: 16px;
            margin-bottom: 6px;
            color: var(--text-color);
        }

    .category-section {
        margin: 15px 0;
    }

    .component-grid {
        display: inline-flex;
        gap: 1rem;
    }

        .component-grid.Inputs {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        }

    .component-tile {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        justify-content: space-between;
        min-height: 150px;
        border: 1px solid var(--card-border);
        border-radius: 16px;
        background: var(--card-bg);
        box-shadow: var(--card-shadow);
        text-decoration: none;
        color: inherit;
        overflow: hidden;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease;
        width: 200px;
    }

        .component-tile:hover {
            transform: translateY(-2px);
            border-color: var(--card-hover-border);
            box-shadow: var(--card-hover-shadow);
        }

    .component-icon-box {
        display: flex;
        width: 100%;
        flex: 1 1 auto;
        position: relative;
        background: var(--icon-box-bg);
        align-items: center;
        justify-content: center;
    }

    .component-icon-image {
        width: 180px;
        height: 100px;
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
    }

    .component-title {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: .75rem 1rem;
        border-top: 1px solid var(--title-border);
        font-weight: 600;
        line-height: 150%;
        letter-spacing: 0%;
        text-align: center;
        vertical-align: middle;
        color: var(--title-color);
    }

    .explore-page p.small {
        margin-top: -6px;
    }

    .right-panel {
        display: none;
    }

    .explore-page .h2-title {
        margin-bottom: 10px;
    }

    .explore-page .h4 {
        font-size: 20px;
    }

    @@media (max-width: 640px) {
        .component-grid {
            display: grid;
            grid-template-columns: 1fr;
            width: 100%;
        }

        .component-tile {
            width: 100%;
        }
    }
</style>