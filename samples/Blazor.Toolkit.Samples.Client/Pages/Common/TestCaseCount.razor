@page "/common/test-case-count"

<PageTitle>Component Test Matrix | ASP.NET Core Blazor OSS Components</PageTitle>

<style>
    :root {
        /* Table-specific variables (light defaults) */
        --table-bg: var(--panel-bg);
        --table-border: rgba(0,0,0,0.06);
        --table-border-radius: 6px;
        --table-header-bg: rgba(0,0,0,0.02);
        --table-header-color: var(--top-text);
        --table-row-bg: #ffffff; /* light theme rows: white (fallback transparent allowed) */
        --table-row-border: rgba(0,0,0,0.04);
    }

    .dark {
        /* Dark overrides for table variables */
        --table-bg: var(--panel-bg);
        --table-border: rgba(255,255,255,0.10);
        --table-header-bg: rgba(255,255,255,0.04);
        --table-header-color: var(--top-text);
        --table-row-bg: rgba(255,255,255,0.01);
        --table-row-border: rgba(255,255,255,0.04);
    }

    /* Table styling: use theme variables, with sensible fallbacks */
    .table {
        background-color: var(--table-bg, #ffffff);
        color: var(--text-color, #111827);
        border: 1px solid var(--table-border, rgba(0,0,0,0.06));
        border-radius: var(--table-border-radius, 6px);
        overflow: hidden;
        border-collapse: separate;
        border-spacing: 0;
        width: 100%;
    }

    .table thead th {
        background-color: var(--table-header-bg, rgba(0,0,0,0.02));
        color: var(--table-header-color, var(--top-text, #111827));
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 600;
        border-bottom: 1px solid var(--table-row-border, rgba(0,0,0,0.04));
    }

    .table tbody td {
        padding: 0.75rem 1rem;
        border-top: 1px solid var(--table-row-border, rgba(0,0,0,0.04));
        background-color: var(--table-row-bg, #ffffff);
        color: var(--text-color, #111827);
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin: 1.5rem 0;
    }

    .summary-card {
        background-color: var(--table-bg);
        border: 1px solid var(--table-border);
        border-radius: var(--table-border-radius);
        padding: 1.25rem;
        text-align: center;
    }

    .summary-card .number {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .summary-card .label {
        font-size: 0.875rem;
        color: var(--text-color);
        opacity: 0.7;
    }

    .summary-card.accessibility .number { color: #2563eb; }
    .summary-card.playwright .number   { color: #059669; }
    .summary-card.bunit .number        { color: #7c3aed; }

</style>

<Description>
    <Header>
        <h4>Component Test Matrix</h4>
    </Header>
    <Content>
        <p>
            This report provides a comprehensive overview of test case distribution across the
            Syncfusion<sup style="font-size:70%">&reg;</sup> Blazor Toolkit components.
            The Toolkit maintains high quality standards through rigorous testing across three complementary categories:
        </p>
        <ul>
            <li>
                <strong>Accessibility Tests</strong> — Automated WCAG 2.1 compliance and accessibility validation tests powered by axe-core with Playwright. These tests ensure components are usable by all users, including those with assistive technology.
            </li>
            <li>
                <strong>Playwright Tests</strong> — End-to-end browser automation tests that validate user interactions, visual rendering, and component behavior across multiple browser environments.
            </li>
            <li>
                <strong>BUnit Tests</strong> — Blazor component unit tests using the bUnit framework for granular testing of component logic, state management, and lifecycle events. Supports xUnit, NUnit, and MSTest test runners.
            </li>
        </ul>
    </Content>
</Description>

<Description>
    <Header>
        <h5>Total Test Case Summary</h5>
    </Header>
    <Content>
        <div class="summary-grid">
            <div class="summary-card accessibility">
                <div class="number">85</div>
                <div class="label">Accessibility Tests</div>
            </div>
            <div class="summary-card playwright">
                <div class="number">644</div>
                <div class="label">Playwright Tests</div>
            </div>
            <div class="summary-card bunit">
                <div class="number">2,573</div>
                <div class="label">BUnit Tests</div>
            </div>
        </div>
    </Content>
</Description>

