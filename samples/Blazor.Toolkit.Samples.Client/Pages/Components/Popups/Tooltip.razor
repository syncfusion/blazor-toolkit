<Description>
    <Header>
        <h5>Delay & Animation</h5>
    </Header>
    <Content>
        Control tooltip visibility timing using <code>ShowDelay</code> and <code>HideDelay</code> properties (in milliseconds). The <code>Animation</code> property with <code>Effect</code> defines entrance/exit animations. Common effects include <code>FadeIn</code>, <code>FadeOut</code>, <code>ZoomIn</code>, <code>ZoomOut</code>, and <code>None</code>. This example demonstrates configurable delays and smooth animations for better UX.
    </Content>
</Description>
<CodePreview CodeSection="@DelayAnimationCode">
    <PreviewSection>
        <div style="display:flex;justify-content:center;gap:40px;align-items:center;flex-wrap:wrap;padding:40px;">
            <div>
                <p style="text-align:center;margin-bottom:16px;"> <strong>Fast</strong></p>
                <SfTooltip Content="Shows quickly" OpenDelay="100" CloseDelay="100" Animation="@Animation">
                    <SfButton Content="Fast Tooltip"></SfButton>
                </SfTooltip>
            </div>
            <div>
                <p style="text-align:center;margin-bottom:16px;"> <strong>Medium</strong></p>
                <SfTooltip Content="Shows with slight delay" OpenDelay="500" CloseDelay="300" Animation="@Animation">
                    <SfButton Content="Medium Tooltip"></SfButton>
                </SfTooltip>
            </div>
            <div>
                <p style="text-align:center;margin-bottom:16px;"> <strong>Slow</strong></p>
                <SfTooltip Content="Shows after delay" OpenDelay="1000" CloseDelay="500" Animation="@Animation">
                    <SfButton Content="Slow Tooltip"></SfButton>
                </SfTooltip>
            </div>
        </div>
@code {
    public AnimationModel Animation { get; set; } = new AnimationModel
    {
        Open = new TooltipAnimationSettings { Delay = 0, Duration = 1000, Effect = Effect.ZoomIn },
        Close = new TooltipAnimationSettings { Delay = 0, Duration = 500, Effect = Effect.ZoomOut }
    };
}
</PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5>Tooltip on Disabled Elements</h5>
    </Header>
    <Content>
