";
}

<style>
    /* --- Layout helpers (safe) --- */
    .switch-container {
        margin: 0;
    }

    .status-text {
        margin-left: 0;
    }

    /* Form row alignment tweaks */
    .form-group.d-flex {
        gap: .5rem;
    }
</style>