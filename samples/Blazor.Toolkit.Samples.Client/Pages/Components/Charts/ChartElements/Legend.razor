<Description>
    <Header>
        <h5><b>Item Size</b></h5>
    </Header>
    <Content>
        The size and spacing of legend items can be customized using the <code>ShapeHeight</code>, <code>ShapeWidth</code>, and <code>ShapePadding</code> properties in the <code>ChartLegendSettings</code> component.
        This example demonstrates how to adjust these properties to change the dimensions of the legend shapes and the spacing between them and their labels.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="637px">
    <CodePreview IsFullWidth="true" CodeSection="@LegendItemSizeCode">
    <PreviewSection>
    <div class="legend-controls" style="@LegendControlsStyle">
            <div style="display: flex; align-items: center; gap: 10px;">
                <label style="font-weight: 500;">Shape Height:</label>
                <input type="range" min="10" max="50" @bind="shapeHeight" @bind:event="oninput" style="cursor: pointer;" />
                <span style="min-width: 25px">@shapeHeight</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <label style="font-weight: 500;">Shape Width:</label>
                <input type="range" min="10" max="50" @bind="shapeWidth" @bind:event="oninput" style="cursor: pointer;" />
                <span style="min-width: 25px">@shapeWidth</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <label style="font-weight: 500;">Shape Padding:</label>
                <input type="range" min="0" max="50" @bind="shapePadding" @bind:event="oninput" style="cursor: pointer;" />
                <span style="min-width: 25px">@shapePadding</span>
            </div>
        </div>
