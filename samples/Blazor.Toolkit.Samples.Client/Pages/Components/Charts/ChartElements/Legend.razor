@page "/charts/legend"
@using Syncfusion.Blazor.Toolkit.Charts
@using ValueType = Syncfusion.Blazor.Toolkit.ValueType

<PageTitle>Blazor Chart Legend Demo | Syncfusion Toolkit</PageTitle>

<Description>
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        Legends help users identify the data series rendered in a Chart.
        This example demonstrates the default legend behavior where each
        series appears as an individual legend item based on its name by setting the <code>Visible</code> property in the <code>ChartLegendSettings</code> component to <code>true</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="553px">
    <CodePreview IsFullWidth="true" CodeSection="@LegendOverviewCode">
    <PreviewSection>
            <SfChart @key="@_currentTheme" Title="GDP Growth (2015 - 2024)" Theme="@_currentTheme">

            <ChartPrimaryXAxis ValueType="ValueType.Category">
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Interval="5"
                               LineStyle="new ChartAxisLineStyle { Width = 0 }">
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@LegendOverviewData"
                             XName="Year"
                             YName="USA"
                             Name="USA"
                             Type="ChartSeriesType.Column"
                             Fill="#689B8A"
                             ColumnSpacing="0.1"
                             LegendShape="LegendShape.Circle"
                             CornerRadius="new ChartCornerRadius { TopLeft = 2, TopRight = 2 }">
                </ChartSeries>

                <ChartSeries DataSource="@LegendOverviewData"
                             XName="Year"
                             YName="India"
                             Name="India"
                             Type="ChartSeriesType.Column"
                             Fill="#8E7AB5"
                             ColumnSpacing="0.1"
                             LegendShape="LegendShape.Circle"
                             CornerRadius="new ChartCornerRadius { TopLeft = 2, TopRight = 2 }">
                </ChartSeries>

                <ChartSeries DataSource="@LegendOverviewData"
                             XName="Year"
                             YName="Japan"
                             Name="Japan"
                             Type="ChartSeriesType.Column"
                             Fill="#FF6868"
                             ColumnSpacing="0.1"
                             LegendShape="LegendShape.Circle"
                             CornerRadius="new ChartCornerRadius { TopLeft = 2, TopRight = 2 }">
                </ChartSeries>

                <ChartSeries DataSource="@LegendOverviewData"
                             XName="Year"
                             YName="Russia"
                             Name="Russia"
                             Type="ChartSeriesType.Column"
                             Fill="#6897D4"
                             ColumnSpacing="0.1"
                             LegendShape="LegendShape.Circle"
                             CornerRadius="new ChartCornerRadius { TopLeft = 2, TopRight = 2 }">
                </ChartSeries>

                <ChartSeries DataSource="@LegendOverviewData"
                             XName="Year"
                             YName="France"
                             Name="France"
                             Type="ChartSeriesType.Column"
                             Fill="#D2A953"
                             ColumnSpacing="0.1"
                             LegendShape="LegendShape.Circle"
                             CornerRadius="new ChartCornerRadius { TopLeft = 2, TopRight = 2 }">
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true"
                                  Header="<b>${point.x}</b>"
                                  Format="${series.name} : <b>${point.y}%</b>" />

            <ChartLegendSettings Visible="true"></ChartLegendSettings>
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Shapes</b></h5>
    </Header>
    <Content>
        Legend shapes visually represent the corresponding data series in a Chart.
        This example demonstrates customizing legend items using different shapes
        such as <code>Circle</code> and <code>Rectangle</code> using the <code>LegendShape</code> property in the <code>ChartSeries</code> component to improve series differentiation.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="553px">
    <CodePreview IsFullWidth="true" CodeSection="@LegendShapesCode">
    <PreviewSection>
         <SfChart @key="@_currentTheme" Title="Global CO₂ Emissions: India vs China" Theme="@_currentTheme">

            <ChartPrimaryXAxis ValueType="ValueType.Category">
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Interval="5" Format="{value}">
                <ChartAxisLineStyle Width = "0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@IndiaLegendData"
                             XName="Year"
                             YName="Value"
                             Name="India"
                             Type="ChartSeriesType.SplineArea"
                             Width="2"
                             Opacity="0.5"
                             Fill="#F57BB8"
                             LegendShape="LegendShape.SeriesType">
                </ChartSeries>

                <ChartSeries DataSource="@ChinaLegendData"
                             XName="Year"
                             YName="Value"
                             Name="China"
                             Type="ChartSeriesType.SplineArea"
                             Width="2"
                             Opacity="0.5"
                             Fill="#9DACFF"
                                 LegendShape="LegendShape.SeriesType">
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="${series.name} : <b>${point.y}%</b>" />

            <ChartLegendSettings Visible="true"></ChartLegendSettings>
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Position</b></h5>
    </Header>
    <Content>
        The legend position property controls where the legend is displayed
        within the Chart area. This example demonstrates positioning the
        legend at the top of the Chart by setting the <code>Position</code> property to <code>LegendPosition.Top</code> in the <code>ChartLegendSettings</code> component to improve visibility and layout.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="553px">
    <CodePreview IsFullWidth="true" CodeSection="@LegendPositionCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Annual percentage change in fossil fuel consumption (2023 - 2024)" Theme="@_currentTheme">

            <ChartPrimaryXAxis ValueType="ValueType.Category" LabelIntersectAction="LabelIntersectAction.Rotate45">
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Interval="2" Format="{value}%">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@LegendPositionData"
                             XName="Country"
                             YName="Value2024"
                             Name="2024"
                             Type="ChartSeriesType.Bar"
                             Fill="#FF6868"
                             ColumnSpacing="0.1"
                             CornerRadius="new ChartCornerRadius { TopRight = 6, BottomRight = 6 }">
                </ChartSeries>

                <ChartSeries DataSource="@LegendPositionData"
                             XName="Country"
                             YName="Value2023"
                             Name="2023"
                             Type="ChartSeriesType.Bar"
                             Fill="#689B8A"
                             ColumnSpacing="0.1"
                             CornerRadius="new ChartCornerRadius { TopRight = 6, BottomRight = 6 }">
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="${series.name} : <b>${point.y}</b>" />

            <ChartLegendSettings Visible="true"
                                 Position="LegendPosition.Top">
