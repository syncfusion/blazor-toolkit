<Description>
    <Header>
        <h5><b>Customize The Stripline Text</b></h5>
    </Header>
    <Content>
        Stripline text customization allows you to display descriptive labels
        within specific axis ranges to provide contextual meaning to data bands.
        This example demonstrates adding custom text to striplines on the
        Y-axis to categorize wind conditions such as calm, breeze, and gusts,
        with precise control over text alignment and background styling.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StriplineTextCustomizationCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Wind Speed and Gust (km/h)" Theme="@_currentTheme">

            <!-- X Axis (DateTime) -->
            <ChartPrimaryXAxis ValueType="ValueType.DateTime" LabelFormat="ddd dd/MM" LabelRotation="-90">
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMajorGridLines Width="0" />
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Title="Wind Speed and Gust (km/h)"
                               Minimum="0"
                               Maximum="30"
                               Interval="5"
                               RangePadding="ChartRangePadding.None">
                <ChartAxisLineStyle Width="0"/>
                <ChartAxisMajorTickLines Width="0"/>
                <ChartStriplines>
                    <ChartStripline Start="0" End="5"
                                    Text="Calm"
                                    HorizontalAlignment="Anchor.Start"
                                    VerticalAlignment="Anchor.Middle"
                                    Color="rgba(68,170,213,0.1)"  />

                    <ChartStripline Start="5" End="8"
                                    Text="Light Air"
                                    HorizontalAlignment="Anchor.Middle"
                                    VerticalAlignment="Anchor.Start"
                                    Color="rgba(0,0,0,0)" />

                    <ChartStripline Start="8" End="11"
                                    Text="Light Breeze"
                                    HorizontalAlignment="Anchor.End"
                                    VerticalAlignment="Anchor.Middle"
                                    Color="rgba(68,170,213,0.1)" />

                    <ChartStripline Start="11" End="18"
                                    Text="Gentle Breeze"
                                    HorizontalAlignment="Anchor.Middle"
                                    VerticalAlignment="Anchor.End"
                                    Color="rgba(0,0,0,0)" />

                    <ChartStripline Start="18" End="28"
                                    Text="Moderate Breeze"
                                    HorizontalAlignment="Anchor.End"
                                    VerticalAlignment="Anchor.Start"
                                    Color="rgba(68,170,213,0.1)" />

                    <ChartStripline Start="28" End="30"
                                    Text="Fresh Breeze"
                                    HorizontalAlignment="Anchor.Start"
                                    VerticalAlignment="Anchor.End"
                                    Color="rgba(0,0,0,0)" />
                </ChartStriplines>
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="@WindSpeedData"
