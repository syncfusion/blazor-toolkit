@page "/charts/stripline"
@using Syncfusion.Blazor.Toolkit.Charts
@using ValueType = Syncfusion.Blazor.Toolkit.ValueType

<PageTitle>Blazor Chart Stripline Demo | Syncfusion Toolkit</PageTitle>
<Description>
    <Header>
        <h4><b>Stripline In Blazor Chart</b></h4>
    </Header>
    <Content>
        Striplines are horizontal or vertical bands in charts that highlight specific regions
        or intervals to emphasize important data points or ranges. They are commonly used
        to indicate thresholds, target ranges, or to visually separate different sections
        of a chart. In Blazor Chart, striplines are configured using the
        <code>ChartStripLines</code> collection on the axis.
    </Content>
</Description>
<Description>
    <Header>
        <h5><b>Horizontal Striplines</b></h5>
    </Header>
    <Content>
        Horizontal striplines highlight a specific range or threshold along the vertical axis.
        They appear as horizontal bands across the plot area and are defined using the
        <code>ChartStripLine</code> component inside the vertical axis.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StriplineBandCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Wind Speed and Gust (km/h)" Theme="@_currentTheme">
            <ChartPrimaryXAxis ValueType="ValueType.DateTime"
                               LabelFormat="ddd dd/MM" LabelRotation="-90">
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMajorGridLines Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Minimum="0" Maximum="35" Interval="5"
                               Title="Wind Speed and Gust (km/h)">
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisLineStyle Width="0"/>
                <ChartAxisLabelStyle Color="@AxisLabelColor" />
                <ChartStriplines>
                    <ChartStripline Start="0" End="2" Text="Calm" Color="@CalmStriplineColor" Opacity="0.6" HorizontalAlignment="Anchor.Start"/>
                    <ChartStripline Start="2" End="6" Text="Light Air" Color="@LightAirStriplineColor" Opacity="0.6" HorizontalAlignment="Anchor.Start" />
                    <ChartStripline Start="6" End="10" Text="Light Breeze" Color="@LightBreezeStriplineColor" Opacity="0.6" HorizontalAlignment="Anchor.Start" />
                    <ChartStripline Start="10" End="15" Text="Gentle Breeze" Color="@GentleBreezeStriplineColor" Opacity="0.6" HorizontalAlignment="Anchor.Start" />
                    <ChartStripline Start="15" End="25" Text="Moderate Breeze" Color="@ModerateBreezeStriplineColor" Opacity="0.6" HorizontalAlignment="Anchor.Start" />
                    <ChartStripline Start="25" End="35" Text="Fresh Breeze" Color="@FreshBreezeStriplineColor" Opacity="0.6" HorizontalAlignment="Anchor.Start" />
                </ChartStriplines>
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@WindSeriesData"
                             XName="Date"
                             YName="Gust"
                             Name="Wind Gust (km/h)"
                             Type="ChartSeriesType.Spline">
                </ChartSeries>

                <ChartSeries DataSource="@WindSeriesData"
                             XName="Date"
                             YName="Wind"
                             Name="Wind Speed (km/h)"
                             Type="ChartSeriesType.Spline">
                </ChartSeries>
            
            <ChartTooltipSettings Enable="true" EnableHighlight="true"
                                  EnableMarker="true"
                                  ShowNearestTooltip="true"
                                  Format="${point.x}<br/>${series.name}: <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Vertical Striplines</b></h5>
    </Header>
    <Content>
        Vertical striplines highlight a specific region or interval along the horizontal axis.
        They are rendered as vertical bands and are defined within the
        <code>ChartPrimaryXAxis</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@VerticalStriplineCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Wind Speed and Gust (km/h)" Theme="@_currentTheme">

            <ChartPrimaryXAxis ValueType="ValueType.DateTime"
                               LabelFormat="ddd dd/MM" LabelRotation="-90">

                       
                <!-- ✅ Vertical Striplines -->
                <ChartStriplines>
                    <ChartStripline Start="@(new DateTime(2023, 5, 1))"
                                    End="@(new DateTime(2023, 5, 5))"
                                    Text="Week 1"
                                    HorizontalAlignment="Anchor.Middle"
                                    Color="rgba(68,170,213,0.1)">
                    </ChartStripline>

                    <ChartStripline Start="@(new DateTime(2023, 5, 5))"
                                    End="@(new DateTime(2023, 5, 10))"
                                    Text="Week 2"
                                    HorizontalAlignment="Anchor.Middle"
                                    Color="rgba(0,0,0,0)">
                    </ChartStripline>

                    <ChartStripline Start="@(new DateTime(2023, 5, 10))"
                                    End="@(new DateTime(2023, 5, 15))"
                                    Text="Week 3"
                                    HorizontalAlignment="Anchor.Middle"
                                    Color="rgba(68,170,213,0.1)">
                    </ChartStripline>

                </ChartStriplines>
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Minimum="0"
                               Maximum="30"
                               Interval="10"
                               Title="Wind Speed and Gust (km/h)">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@WindSpeedData"
                             XName="Date"
                             YName="Wind"
                             Name="Wind Speed (km/h)"
                             Type="ChartSeriesType.Spline"
                             Width="2"
                             Fill="#01A725"
                             LegendShape="LegendShape.HorizontalLine">
                </ChartSeries>

                <ChartSeries DataSource="@WindGustData"
                             XName="Date"
                             YName="Gust"
                             Name="Wind Gust (km/h)"
                             Type="ChartSeriesType.Spline"
                             Width="2"
                             Fill="#FF8225"
                             LegendShape="LegendShape.HorizontalLine">
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true"
                                  ShowNearestTooltip="true"
                                  EnableHighlight="true" EnableMarker="true"
                                  Format="${point.x}<br/>${series.name} : <b>${point.y}</b>" />

            <ChartLegendSettings Visible="true"
                                 ShapeHeight="6"
                                 ShapeWidth="15">
            </ChartLegendSettings>

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Stripline Recurrence</b></h5>
    </Header>
    <Content>
        Striplines with recurrence enable highlighting repeating ranges
        across chart axes. This example demonstrates recurring striplines
        on both horizontal and vertical axes to improve readability
        in a world pollution data visualization.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StriplineRecurrenceCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="World Pollution Report" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
            <ChartTooltipSettings Enable="true" EnableHighlight="true"
                                  Format="Year: ${point.x}<br/>Tons Per Day: <b>${point.y}</b>" />
            <ChartPrimaryXAxis ValueType="ValueType.DateTime"
                               IntervalType="IntervalType.Years" EdgeLabelPlacement="EdgeLabelPlacement.Shift"
                               Minimum="@(new DateTime(1965, 1, 1))" LabelFormat="yyyy"
                               Maximum="@(new DateTime(2010, 1, 1))" >
                                    <ChartAxisMinorTickLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMajorGridLines Width="0" />

                <ChartStriplines>
                    <ChartStripline Start="@(new DateTime(1965, 1, 1))"
                                    Size="5"
                                    SizeType="SizeType.Years"
                                    IsRepeat="true"
                                    RepeatEvery="10"
                                    Color="rgba(167,169,171,0.1)"
                                    Visible="true" />
                </ChartStriplines>
            </ChartPrimaryXAxis>
            <ChartPrimaryYAxis Minimum="0"
                               Maximum="18000"
                               Interval="2000">
                <ChartAxisMajorGridLines Color="rgba(167,169,171,0.3)" />
                <ChartAxisLabelStyle Color="transparent" />
                <ChartAxisMajorTickLines Width="0" />

                <ChartStriplines>
                    <ChartStripline Start="0"
                                    Size="2000"
                                    IsRepeat="true"
                                    RepeatEvery="4000"
                                    Color="rgba(167,169,171,0.1)"
                                    Visible="true" />
                </ChartStriplines>
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@AllSourcesData"
                             XName="Year"
                             YName="Value"
                             Name="All sources"
                             Type="ChartSeriesType.Column"
                             Fill="#00C58D"
                             ColumnWidth="0.8"
                             ColumnSpacing="0.2"
                             CornerRadius="new ChartCornerRadius {TopLeft = 5, TopRight = 5}">
                </ChartSeries>

                <ChartSeries DataSource="@AutosData"
                             XName="Year"
                             YName="Value"
                             Name="Autos & Light Trucks"
                             Type="ChartSeriesType.Column"
                             Fill="#DA7DD4"
                             ColumnWidth="0.8"
                             ColumnSpacing="0.2"
                             CornerRadius="new ChartCornerRadius {TopLeft = 5, TopRight = 5}">
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
@code {
    [CascadingParameter]
    private Theme CurrentTheme { get; set; } = Theme.Fluent;

    private Theme _currentTheme = Theme.Fluent;

    private string _prevThemeName = string.Empty;

    protected override void OnInitialized()
    {
        _currentTheme = CurrentTheme;
    }

    protected override void OnParametersSet()
    {
        var name = CurrentTheme.ToString() ?? string.Empty;
        if (name != _prevThemeName)
        {
            _prevThemeName = name;
            _currentTheme = CurrentTheme;
            InvokeAsync(StateHasChanged);
        }
        else
        {
            _currentTheme = CurrentTheme;
        }
    }

