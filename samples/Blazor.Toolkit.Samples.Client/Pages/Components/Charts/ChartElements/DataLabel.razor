<Description>
    <Header>
        <h5><b>Format</b></h5>
    </Header>
    <Content>
        Data label formatting controls how values are displayed on data points.
        This example demonstrates applying numeric formatting to data labels
        using the <code>Format</code> property in the <code>ChartDataLabel</code> component, 
        displaying day‑wise units sold in a Column Chart.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelFormatCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Day-wise Units Sold" Theme="@_currentTheme">

                <ChartTooltipSettings Enable="true"
                                      Header="${point.x}"
                                      Format="Sales: <b>${point.y} Units</b>" />

                <!-- Primary X Axis -->
                <ChartPrimaryXAxis ValueType="ValueType.Category">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <!-- Primary Y Axis -->
                <ChartPrimaryYAxis Interval="20" Title="Units Sold">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                
                    <ChartSeries DataSource="@LabelCustomData"
                                 XName="Country"
                                 YName="Gold"
                                 Type="ChartSeriesType.Column"
                                 Fill="#A0D683"
                                 ColumnWidth="0.4"
                                 CornerRadius="@(new ChartCornerRadius { TopLeft = 5, TopRight = 5 })">

                        <ChartMarker>
                            <ChartDataLabel Visible="true"
                                            Format="n2"
                                            EnableRotation="true"
                                            Angle="-90"
                                            Font="@(new ChartDataLabelFont { Color = DataLabelTextColor })" />
                        </ChartMarker>

                    </ChartSeries>
                

            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

