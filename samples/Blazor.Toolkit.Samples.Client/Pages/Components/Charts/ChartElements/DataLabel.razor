<Description>
    <Header>
        <h5><b>Text Mapping</b></h5>
    </Header>
    <Content>
        Text mapping allows custom text to be displayed as data labels by
        binding a specific field from the data source. This example demonstrates
        mapping energy consumption text values to data labels in a Bar Chart 
        by specifying the mapping field in the <code>Name</code> property of the <code>ChartDataLabel</code> component.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelTextMappingCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Coal Production Per Capita, 2024" Theme="@_currentTheme">

                <!-- Primary X Axis -->
                <ChartPrimaryXAxis ValueType="ValueType.Category">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <!-- Primary Y Axis -->
                <ChartPrimaryYAxis Visible="false"
                                   Maximum="160000">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                
                    <ChartSeries DataSource="@DataLabelTextMappingData"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Bar"
                                 Fill="#A0D683"
                                 CornerRadius="@(new ChartCornerRadius { TopRight = 5, BottomRight = 5 })">

                        <ChartMarker>
                            <ChartDataLabel Visible="true" Context="Text" Font="@(new ChartDataLabelFont { Color = DataLabelTextColor })" Format="{value} kWh" />
                        </ChartMarker>

                    </ChartSeries>
                

                <ChartTooltipSettings Enable="true"
                                      Header="Coal Production"
                                      Format="${point.x} : <b>${point.y} kWh</b>" />

            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

