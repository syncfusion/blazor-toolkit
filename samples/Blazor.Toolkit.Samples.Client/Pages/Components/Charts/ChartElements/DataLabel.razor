<Description>
    <Header>
        <h5><b>Label Rotation</b></h5>
    </Header>
    <Content>
        Data label rotation allows labels to be displayed at different angles
        to improve readability when space is constrained. This example shows
        rotating data labels by setting the <code>EnableRotation</code> property to <code>true</code> and specifying the <code>Angle</code> 
        in the <code>ChartDataLabel</code> component.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelRotationCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Total Renewable Surface Water" Theme="@_currentTheme">

                <ChartPrimaryXAxis ValueType="ValueType.Category"
                                   LabelRotation="-45">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <ChartPrimaryYAxis>
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                
                    <ChartSeries DataSource="@DataLabelRotationData"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Column"
                                 Fill="#A0D683"
                                 CornerRadius="@(new ChartCornerRadius { TopLeft = 5, TopRight = 5 })">

                        <ChartMarker>
                            <ChartDataLabel Visible="true"
                                            Format="{value}k"
                                            Position="ChartLabelPosition.Top"
                                            EnableRotation="true"
                                            Angle="270"
                                            LabelIntersectAction="None"
                                            Font="@(new ChartDataLabelFont { Color = DataLabelTextColor })" />
                        </ChartMarker>
                        <ChartDataLabel Visible="true" Format="<b>${point.y}k</b> Billion cubic meter per year"></ChartDataLabel>
                    </ChartSeries>
                
                <ChartTooltipSettings Enable="true" ShowHeaderLine="true"
                                      Format="<b>${point.y}k</b> Billion cubic meter per year" />
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

