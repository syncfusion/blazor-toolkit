<Description>
    <Header>
        <h5><b>Margin</b></h5>
    </Header>
    <Content>
        Data label margins control the spacing around labels to prevent
        overlap and improve readability. This example demonstrates applying
        margins using the <code>Margin</code> property and avoiding label intersection 
        by setting the <code>LabelIntersectAction</code> property to <code>None</code> in the <code>ChartDataLabel</code> component.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelMarginCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Day-wise Units Sold" Theme="@_currentTheme">

                <ChartTooltipSettings Enable="true"
                                      Header="${point.x}"
                                      Format="Sales: <b>${point.y} Units</b>" />

                <ChartPrimaryXAxis ValueType="ValueType.Category"
                                   LabelRotation="-45">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <ChartPrimaryYAxis Interval="20"
                                   Title="Units Sold">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                
                    <ChartSeries DataSource="@LabelCustomData"
                                 XName="Country"
                                 YName="Gold"
                                 Type="ChartSeriesType.Column"
                                 Fill="#A0D683"
                                 ColumnWidth="0.4"
                                 CornerRadius="@(new ChartCornerRadius { TopLeft = 5, TopRight = 5 })">
                        <ChartMarker>
                            <ChartDataLabel Visible="true"
                                            LabelIntersectAction="None"
                                            Margin="@(new ChartDataLabelMargin { Left = 30, Right = 30, Top = 30, Bottom = 30})"
                                            Font="@(new ChartDataLabelFont { Color = DataLabelTextColor })" />
                        </ChartMarker>
                    </ChartSeries>
                
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>
