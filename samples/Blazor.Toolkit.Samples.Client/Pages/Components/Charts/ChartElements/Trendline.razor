<Description>
    <Header>
        <h4><b>TrendLine Types</b></h4>
    </Header>
    <Content>
        Choose from multiple regression types to best fit your data pattern. The <code>Type</code> property determines which mathematical model is applied to calculate the trend line.
    </Content>
</Description>

<Description>
    <Header>
        <h5><b>Linear</b></h5>
    </Header>
    <Content>
        A linear trendline is a straight, best‑fit line that shows a constant
        rate of increase or decrease. This example demonstrates adding a
        linear trendline by setting the <code>Type</code> property to <code>TrendlineTypes.Linear</code> to S&amp;P 500 index data to visualize the overall
        market direction.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="553px">
    <CodePreview IsFullWidth="true" CodeSection="@TrendlineLinearCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="S&P 500 Index Performance (2014–2023)" SubTitle="Source: S&P Dow Jones Indices" Theme="@_currentTheme">

            <ChartPrimaryXAxis ValueType="ValueType.Category" Title="Year">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Minimum="2000"
                               Maximum="5000"
                               Interval="500"
                               Title="Index Value">
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <ChartTooltipSettings Enable="true"
                          Shared="true"
                          ShowNearestTooltip="true"
                          Format="Index Value: <b>${point.y}</b>">
            </ChartTooltipSettings>

            <ChartLegendSettings Visible="true"
                                 ShapeHeight="15"
                                 ShapeWidth="15">
            </ChartLegendSettings>

            
                <ChartSeries DataSource="@TrendlineLinearData"
                             XName="Year"
                             YName="Value"
                             Name="S&P 500"
                             Type="ChartSeriesType.Line"
                             Width="2"
                             Fill="#2E7D32"
                             Animation="new ChartSeriesAnimation { Enable = false }">

                    <ChartMarker Visible="true"
                                 Width="8"
                                 Height="8"
                                 Shape="ChartShape.Diamond">
                    </ChartMarker>

                    <ChartTrendlines>
                        <ChartTrendline Type="TrendlineTypes.Linear"
                                        Name="Market Trend"
                                        Width="3"
                                        DashArray="5,5"
                                        Fill="#FF6F00"
                                        EnableTooltip="false"
                                        Animation="new ChartTrendlineAnimation { Enable = false }">
                        </ChartTrendline>
                    </ChartTrendlines>

                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

