@page "/charts/trendline"
@using Syncfusion.Blazor.Toolkit.Charts
@using ValueType = Syncfusion.Blazor.Toolkit.ValueType

<PageTitle>Blazor Chart Trendline Demo | Syncfusion Toolkit</PageTitle>
<Description>
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        Trendlines help visualize the overall direction and pattern of a dataset.
        This example demonstrates adding a trendline to the S&amp;P 500 index data
        to highlight long-term market growth using the <code>ChartTrendlines</code> and <code>ChartTrendline</code> components.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="553px">
    <CodePreview IsFullWidth="true" CodeSection="@TrendlineOverviewCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="S&P 500 Index - Global Market Benchmark Growth" SubTitle="S&P 500 Index - Global Market Benchmark Growth" Theme="@_currentTheme">
            <ChartPrimaryXAxis ValueType="ValueType.Double"  Interval="1" Title="Year" >
                <ChartAxisMajorGridLines Width="0"/>
                <ChartAxisMajorTickLines Width="0"/>
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Interval="2000" Title="S&P 500 Index (Points)" LabelFormat="{value}">
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <ChartTooltipSettings Enable="true"
                          ShowNearestTooltip="true" Header=""
                          Format="S&P 500: <b>${point.y} Points</b>">
            </ChartTooltipSettings>

            <ChartLegendSettings Visible="true"
                                 ShapeHeight="15"
                                 ShapeWidth="15">
            </ChartLegendSettings>

            
                <ChartSeries DataSource="@Sp500Data"
                             XName="Year"
                             YName="Value"
                             Name="S&P 500"
                             Type="ChartSeriesType.Column"
                             ColumnWidth="0.6"
                             Fill="#7bd5d1"
                             Animation="new ChartSeriesAnimation { Enable = false }">

                    <ChartTrendlines>
                        <ChartTrendline Type="TrendlineTypes.Exponential"
                                        Name="Trend"
                                        Width="3"
                                        Fill="#ff6961"
                                        EnableTooltip="false"
                                        Animation="new ChartTrendlineAnimation { Enable = false }">
                        </ChartTrendline>
                    </ChartTrendlines>

                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

