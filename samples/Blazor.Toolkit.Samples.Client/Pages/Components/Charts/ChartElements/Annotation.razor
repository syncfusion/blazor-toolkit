@page "/charts/annotation"

@using Syncfusion.Blazor.Toolkit.Charts
@using ValueType = Syncfusion.Blazor.Toolkit.ValueType

<Description>
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        Annotations allow you to place custom content such as text, HTML, or SVG
        elements at specific data points or pixel coordinates in a Chart.
        elements at specific data points or pixel coordinates in a Chart using the <code>ChartAnnotation</code> component.
        This example demonstrates adding tooltip-style annotations to highlight
        important regions in a speed data plot.
        important regions in a speed data plot by configuring the <code>X</code> and <code>Y</code> properties.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@AnnotationOverviewCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Height="420px"
         Width="100%"
         Title="Speed Data Plot for Interlagos Circuit"
         Theme="@_currentTheme">

    <!-- Hide legend (React parity) -->
    <ChartLegendSettings Visible="false" />

    <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="ValueType.Double" Title="Distance"
                       LabelFormat="{value:0.00} KM">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
    </ChartPrimaryXAxis>

    <!-- Y Axis -->
    <ChartPrimaryYAxis Minimum="50" Title="Speed (KM/H)"
                       Maximum="400">
        <ChartAxisLineStyle Width="0" />
        <ChartAxisMajorTickLines Width="0" />
    </ChartPrimaryYAxis>

    <!-- ✅ Annotations -->
    <ChartAnnotations>

        <ChartAnnotation CoordinateUnits="Units.Point" X="0.36" Y="80">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Senna S", "Top", false))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="0.90" Y="158">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Curva do Sol", "Left", false))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="1.40" Y="120">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Descida do Lago", "Top", false))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="2.10" Y="200">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Ferradura", "Top", false))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="2.72" Y="80">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Bico de Pato", "Top", false))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="3.27" Y="98">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Juncao", "Top", false))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="0.70" Y="304">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Reta Oposta", "Bottom", true))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="3.136" Y="288">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Mergulho", "Bottom", true))
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="3.82" Y="312">
            <ContentTemplate>
                @((MarkupString)SpeedCallout("Subida dos Boxes", "Bottom", true))
            </ContentTemplate>
        </ChartAnnotation>

        <!-- Plain HTML annotation -->
        <ChartAnnotation CoordinateUnits="Units.Point" X="1.65" Y="330">
            <ContentTemplate>
                <div style="font-family:Inter;font-weight:600;color:@TextColor">
                    Max, acceleration<br />5.00 g at 5th gear
                </div>
            </ContentTemplate>
        </ChartAnnotation>

        <ChartAnnotation CoordinateUnits="Units.Point" X="2.50" Y="260">
            <ContentTemplate>
                <div style="font-family:Inter;font-weight:600;color:@TextColor">
                    Max, acceleration<br />4.58 g at 5th gear
                </div>
            </ContentTemplate>
        </ChartAnnotation>

    </ChartAnnotations>

    <!-- ✅ Series -->
    
        <ChartSeries DataSource="@AnnotateData"
                     XName="Distance"
                     YName="Speed"
                     Name="Speed"
                     Type="ChartSeriesType.Area"
                     Fill="#6200EE"
                     Border="@(new ChartSeriesBorder { Width = 2.5, Color = "#6200EE" })">
        </ChartSeries>
    

</SfChart>

    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Points</b></h5>
    </Header>
    <Content>
        Point annotations allow you to place custom content at specific
        data points in the Chart. This example demonstrates callout-style
        data points in the Chart by setting the <code>CoordinateUnits</code> property to <code>Units.Point</code>. 
        This example demonstrates callout-style
        annotations positioned at known peak and transition months in
        all-India monthly rainfall data.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@AnnotationPointCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Height="440px" Title="All-India Monthly Rainfall (mm, 1901-2000 normals)"
                 SubTitle="Source: India Meteorological Department" Theme="@_currentTheme">

            <ChartLegendSettings Visible="false"></ChartLegendSettings>

            <ChartPrimaryXAxis ValueType="ValueType.Category" Interval="1">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Minimum="0" Maximum="340" Title="Precipitation (mm)" Interval="100">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryYAxis>

            <ChartAnnotations>
                <ChartAnnotation X="@((object)"Jun")" Y="195"
                                 CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        @((MarkupString)RainfallCallout("SW monsoon onset month nationally (~167 mm)", "#0f766e", "#eafff6"))
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@((object)"Jul")" Y="317"
                                 CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        @((MarkupString)RainfallCallout("Peak monsoon — July averages ~289 mm", "#1e3a8a", "#ffffff"))
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@((object)"Oct")" Y="115"
                                 CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        @((MarkupString)RainfallCallout("Retreating monsoon - October (~85 mm)", "#7c2d12", "#fff7ed"))
                    </ContentTemplate>
                </ChartAnnotation>
            </ChartAnnotations>

            
                <ChartSeries DataSource="@RainfallIndia"
                             XName="Month"
                             YName="Rainfall"
                             Type="ChartSeriesType.Column"
                             Fill="#3b82f6"
                             Width="2">
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Pixel</b></h5>
    </Header>
    <Content>
        Pixel-based annotations allow you to position custom content at fixed
        locations within the Chart area using pixel or percentage values.
        locations within the Chart area using pixel or percentage values by setting the <code>CoordinateUnits</code> property to <code>Units.Pixel</code>.
        This example demonstrates adding a watermark-style annotation
        positioned at the center of the Chart using pixel coordinates.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@AnnotationPixelCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Height="420px" Width="100%" Title="Brent Crude Oil Price Trends (2015-2023)" 
                 SubTitle="Source: U.S. EIA-Europe Brent Spot Price FOB (Annual Averages)" Theme="@_currentTheme">
            <ChartLegendSettings Visible="false"></ChartLegendSettings>

            <ChartPrimaryXAxis ValueType="ValueType.DateTime" Format="yyyy">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0"/>
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Interval="20" Title="Price (USD per Barrel)">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryYAxis>

            <ChartAnnotations>
                <ChartAnnotation X="@((object)"60%")" Y="@((string)"60%".ToString())"
                                 CoordinateUnits="Units.Pixel">
                    <ContentTemplate>
                        @((MarkupString)WatermarkHtml("Annual Averages (2015-2023)"))
                    </ContentTemplate>
                </ChartAnnotation>
            </ChartAnnotations>

            
                <ChartSeries DataSource="@BrentAnnual"
                             XName="Year"
                             YName="Price"
                             Name="Price"
                             Type="ChartSeriesType.Spline"
                             Width="3"
                             Fill="#82C100">
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true" EnableHighlight="true"
                                  EnableMarker="true" ShowNearestPoint="true"
                                  Format="${point.x}<br/>${series.name}: <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5><b>Alignment</b></h5>
    </Header>
    <Content>
        Alignment properties allow you to control how annotation content is positioned
        relative to its anchor point. This example demonstrates horizontal and vertical
        alignment options applied to annotations highlighting maximum, minimum, and
        relative to its anchor point using the <code>HorizontalAlignment</code> and <code>VerticalAlignment</code> properties. 
        This example demonstrates horizontal and vertical alignment options applied to annotations highlighting maximum, minimum, and
        average values in a time series.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@AnnotationAlignmentCode">
    <PreviewSection>
        <SfChart Title="Bitcoin (BTC) vs USD — Monthly Close (Jun 2022–Oct 2024)" Theme="@_currentTheme">

            <ChartPrimaryXAxis ValueType="ValueType.DateTime"
                               IntervalType="IntervalType.Months" LabelFormat="MMM yy"
                               Interval="4">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Interval="20000" Title="Price in USD">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryYAxis>

            <ChartAnnotations>
                <ChartAnnotation X="@Stats.MaxPoint.X"
                                 Y="@(Stats.MaxPoint.Y.ToString())"
                                 CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        @((MarkupString)GlassBox($"📈 Max ${FmtUSD(Stats.MaxVal)}"))
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@Stats.MinPoint.X"
                                 Y="@(Stats.MinPoint.Y.ToString())"
                                 CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        @((MarkupString)GlassBox($"📉 Min ${FmtUSD(Stats.MinVal)}"))
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@Stats.MidPoint.X"
                                 Y="@(Stats.AvgVal.ToString())"
                                 CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        @((MarkupString)GlassBox($"⚖ Avg ${FmtUSD(Stats.AvgVal)}"))
                    </ContentTemplate>
                </ChartAnnotation>
            </ChartAnnotations>

            
                <ChartSeries DataSource="@Data"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.Area"
                             Fill="rgba(250, 8, 8, 0.26)"
                             Border="@(new ChartSeriesBorder { Color = "red", Width = 2 })">
                </ChartSeries>

            

            <ChartLegendSettings Visible="false"></ChartLegendSettings>
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

@code {
    [CascadingParameter]
    private Theme _currentTheme { get; set; } = Theme.Fluent;

    private bool IsDarkTheme => _currentTheme.ToString().Contains("Dark") || _currentTheme.ToString().Contains("HighContrast");
    private string TextColor => IsDarkTheme ? "#E6EEF8" : "#0B1F3B";

    // Helper methods for annotations
    string SpeedCallout(string text, string direction, bool dark = false)
    {
        var bg = dark ? "#000000" : "#1e3a8a";
        var fg = "#ffffff";
        return $@"
        <div style='
            padding:8px 10px;
            border-radius:10px;
            background:{bg};
            color:{fg};
            font-family:Inter, system-ui;
            font-weight:800;
            font-size:12px;'>
            {text}
        </div>";
    }

    string RainfallCallout(string text, string bg, string fg = "")
    {
        return $@"
        <div style='
            padding:8px 10px;
            border-radius:10px;
            background:{bg};
            color:{fg};
            font-family:Inter, system-ui;
            font-weight:800;
            font-size:12px;'>
            {text}
        </div>";
    }

    string WatermarkHtml(string text)
    {
        return $@"
        <div style='
            font-size:40px;
            font-weight:500;
            opacity:0.08;
            transform:rotate(-20deg);
            white-space:nowrap;
            user-select:none;
            pointer-events:none;
            font-family:Inter, system-ui;'>
            {text}
        </div>";
    }

    string GlassBox(string text) => $@"
    <div style='
        padding:4px 8px;
        border-radius:8px;
        background:rgba(30,143,255,0.26);
        border:1px solid rgba(30,144,255,0.45);
        color:#0b64c0;
        font-size:12px;
        font-weight:600;'>
        {text}
    </div>";

    string FmtUSD(double v) => v.ToString("N0");

