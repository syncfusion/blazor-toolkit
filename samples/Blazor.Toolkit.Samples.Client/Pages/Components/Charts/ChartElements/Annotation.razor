    public StatsInfo Stats => ComputeStats(Data);

    StatsInfo ComputeStats(List<PricePoint> ds)
    {
        var values = ds.Select(d => d.Y).ToList();
        var maxVal = values.Max();
        var minVal = values.Min();
        var maxPoint = ds[values.IndexOf(maxVal)];
        var minPoint = ds[values.IndexOf(minVal)];
        var avgVal = Math.Round(values.Average());
        var midPoint = ds[ds.Count / 2];
        return new StatsInfo(maxVal, minVal, maxPoint, minPoint, avgVal, midPoint);
    }

