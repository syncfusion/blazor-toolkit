@page "/charts/marker"

@using Syncfusion.Blazor.Toolkit.Buttons
@using Syncfusion.Blazor.Toolkit.Charts
@using ValueType = Syncfusion.Blazor.Toolkit.ValueType

<Description>
  
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        Markers are used to highlight individual data points in a Chart series.
        This sample demonstrates markers enabled in a Line Chart to visualize
        year-wise values for China and the United States by setting the <code>Visible</code> property 
        of the <code>ChartMarker</code> component to <code>true</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@MarkerOverviewCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Marker Overview" Theme="@_currentTheme">
            <ChartPrimaryXAxis ValueType="ValueType.Double"
                               Title="Year">
                <ChartAxisMajorTickLines Width="0"/>
                <ChartAxisMajorGridLines Width="0"/>
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Title="Value">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@MarkerOverviewData"
                             XName="Year"
                             YName="China"
                             Name="China"
                             Type="ChartSeriesType.Line">
                    <ChartMarker Visible="true" Width="10" Height="10">
                    </ChartMarker>
                </ChartSeries>

                <ChartSeries DataSource="@MarkerOverviewData"
                             XName="Year"
                             YName="UnitedStates"
                             Name="United States"
                             Type="ChartSeriesType.Line">
                    <ChartMarker Visible="true" Width="10" Height="10">
                    </ChartMarker>
                </ChartSeries>
            

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true" Shared ="true"
                                      Header="${point.x}"
                                      Format="${series.name} : <b>${point.y}°C</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

