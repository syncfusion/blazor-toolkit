<Description>
    <Header>
        <h5><b>Shape</b></h5>
    </Header>
    <Content>
        The <code>Shape</code> property of the <code>ChartMarker</code> component is used to control
        the visual representation of markers. This example demonstrates
        different marker shapes applied to data points in a Line Chart using the <code>ChartShape</code> enum.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@MarkerShapeCode">
    <PreviewSection>
        <div>
            <label>Shape: </label>
            <SfButtonGroup Mode="Syncfusion.Blazor.Toolkit.SelectionMode.Single">
                    <Button Selected="IsSelected(ChartShape.Circle)" SelectedChanged="@(v => OnMarkerShapeSelected(v, ChartShape.Circle))">Circle</Button>
                    <Button Selected="IsSelected(ChartShape.Diamond)" SelectedChanged="@(v => OnMarkerShapeSelected(v, ChartShape.Diamond))">Diamond</Button>
                    <Button Selected="IsSelected(ChartShape.Rectangle)" SelectedChanged="@(v => OnMarkerShapeSelected(v, ChartShape.Rectangle))">Rectangle</Button>
                    <Button Selected="IsSelected(ChartShape.Triangle)" SelectedChanged="@(v => OnMarkerShapeSelected(v, ChartShape.Triangle))">Triangle</Button>
            </SfButtonGroup>
        </div>
        <SfChart Title="Marker Shape Example" Theme="@_currentTheme" @key="@_currentTheme">
            <ChartPrimaryXAxis ValueType="ValueType.Double"
                               Title="Year">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorGridLines Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Title="Percentage (%)"
                               Minimum="75"
                               Maximum="100">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@MarkerShapeData"
                             XName="Year"
                             YName="Value"
                             Name="Growth"
                             Type="ChartSeriesType.Line">
                    <ChartMarker Visible="true"
                                 Shape="@chartShape"
                                 Width="10"
                                 Height="10">
                    </ChartMarker>
                </ChartSeries>
            

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true" 
                                      Header="${point.x}"
                                      Format="World : <b>${point.y}% of population</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

