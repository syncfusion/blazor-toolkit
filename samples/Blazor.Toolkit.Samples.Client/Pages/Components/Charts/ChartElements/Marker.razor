        <h5><b>Marker As Image</b></h5>
    </Header>
    <Content>
        Markers can be rendered using custom images instead of built-in shapes.
        This example demonstrates displaying image-based markers for average
        monthly temperature values using the <code>ImageUrl</code> property
        of the ChartMarker component.
        of the <code>ChartMarker</code> component and setting the <code>Shape</code> property to <code>ChartShape.Image</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@MarkerAsImageCode">
    <PreviewSection>
        <SfChart Title="Monthly Average Temperature" Theme="@_currentTheme">
            <ChartPrimaryXAxis ValueType="ValueType.Category"
                               Title="Month">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorGridLines Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Title="Temperature (°F)">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@TemperatureData"
                             XName="Month"
                             YName="Avg"
                             Name="Average Temperature"
                             Type="ChartSeriesType.Line">
                    <ChartMarker Visible="true"
                                 Width="16"
                                 Height="16"
                                 Shape="ChartShape.Image"
                                 ImageUrl="@(new Uri("images/charts/cloudy.png", UriKind.Relative))">
                    </ChartMarker>
                </ChartSeries>
            

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="Average"
                                      Format="${point.x} : <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

