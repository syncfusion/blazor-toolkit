@page "/charts/line-chart"
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Buttons
@using System.Collections.ObjectModel

<PageTitle>Syncfusion Blazor Toolkit Line Chart Demo</PageTitle>


    <!-- ─────────────────────────────────────────────
        OVERVIEW
        ───────────────────────────────────────────── -->
    <Description>
        <Header>
            <h5><b>Overview</b></h5>
        </Header>
        <Content>
            <p>The Line Chart displays data trends over time or across ordered categories by connecting individual data points with continuous lines. It is commonly used for tracking changes, comparing multiple datasets, and identifying patterns in time-series or sequential data.</p>
            <p>In the Syncfusion Blazor Toolkit, a Line chart is created by setting the <code>Type</code> property of the <code>ChartSeries</code> component to <code>ChartSeriesType.Line</code>. The data is bound using the <code>DataSource</code>, <code>XName</code>, and <code>YName</code> properties. The chart supports markers, tooltips, data labels, real-time updates, axis inversion, and visual customization for analytical dashboards.</p>
        </Content>
    </Description>


    <VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@OverviewCode">
            <PreviewSection>
               
                <SfChart @key="@_currentTheme" Title="Annual Crude Steel Production by Country (2019-2025)" Theme="@_currentTheme">
                    <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                    <!-- X Axis -->
                 
                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                                       Minimum="2019"
                                       Maximum="2025"
                                       Interval="1">
                        <ChartAxisMajorGridLines Width="0" />
                        <ChartAxisMajorTickLines Width="0" />
                        <ChartAxisMinorTickLines Width="0" />
                    </ChartPrimaryXAxis>
                    <!-- Y Axis -->
                    <ChartPrimaryYAxis Title="Volume in million metric tons"
                                       Minimum="0"
                                       Maximum="25"
                                       Interval="5"
                                       RangePadding="ChartRangePadding.None">
                        <ChartAxisLineStyle Width="0" />
                        <ChartAxisMajorTickLines Width="0" />
                    </ChartPrimaryYAxis>
                    <!-- Tooltip -->
                    <ChartTooltipSettings Enable="true"
                                          Header="${point.x}"
                                          Format="${series.name} : <b>${point.y}M</b>"
                                          EnableHighlight="true">
                    </ChartTooltipSettings>
                    <!-- Series -->
                    
                        <ChartSeries DataSource="VietnamData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.Line"
                                     Name="Vietnam">
                            <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                        </ChartSeries>
                        <ChartSeries DataSource="IndonesiaData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.Line"
                                     Name="Indonesia">
                            <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                        </ChartSeries>
                        <ChartSeries DataSource="FranceData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.Line"
                                     Name="France">
                            <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                        </ChartSeries>
                        <ChartSeries DataSource="PolandData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.Line"
                                     Name="Poland">
                            <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                        </ChartSeries>
                        <ChartSeries DataSource="MexicoData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.Line"
                                     Name="Mexico">
                            <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                        </ChartSeries>
                    
                    <ChartLegendSettings EnableHighlight="true"></ChartLegendSettings>
                </SfChart>
            </PreviewSection>
        </CodePreview>
    </VirtualizeSection>


<!-- ─────────────────────────────────────────────
     DATA LABEL
     ───────────────────────────────────────────── -->
<Description>
    <Header><h5><b>Data Label</b></h5></Header>
    <Content>
        <p>Data labels display the exact value of each data point directly on the line, improving clarity and reducing the need to rely solely on axis values or tooltips.</p>
        <p>In the Blazor Line chart, data labels are enabled by setting the <code>Visible</code> property to <code>true</code> in the <code>ChartDataLabel</code> component. You can further customize their appearance using <code>Format</code>, <code>Font</code>, and <code>ChartDataLabelBorder</code> options to improve readability.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Average Monthly Egg Prices in 2022" Theme="@_currentTheme">
            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Price : <b>${point.y}</b>" EnableHighlight="true">
            </ChartTooltipSettings>
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>
            <!-- Y Axis -->
            <ChartPrimaryYAxis Minimum="1.5" LabelFormat="${value}">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>
            <!-- Series -->
            
                <ChartSeries DataSource="EggPriceData"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.Line">
                    <ChartMarker Visible="true" IsFilled="false">
                        <ChartDataLabel Visible="true" Format="${value}"
                                        Font="@(new ChartDataLabelFont { Color = TextColor })">
                            <ChartDataLabelBorder Width="2" Color="#0A97B0">
                            </ChartDataLabelBorder>
                        </ChartDataLabel>
                    </ChartMarker>
                    <ChartLegendSettings EnableHighlight="true"></ChartLegendSettings>
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────
     DASHED LINE
     ───────────────────────────────────────────── -->
<Description>
    <Header><h5><b>Dashed Line</b></h5></Header>
    <Content>
        <p>Dashed lines are useful for distinguishing comparison, projection, or secondary datasets within the same chart.</p>
        <p>In the Syncfusion Blazor Toolkit, dashed lines are created by setting the <code>DashArray</code> property in the <code>ChartSeries</code> component. For example, <code>DashArray="4,4"</code> renders a repeating pattern of 4-pixel dashes followed by 4-pixel gaps, providing a clear visual distinction between multiple series.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DashedLineCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Capital Investment as a Share of Exports" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double" Interval="1">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>
            <!-- Y Axis -->
            <ChartPrimaryYAxis Minimum="3"
                               Maximum="21"
                               Interval="3"
                               LabelFormat="{value}%">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>
            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${series.name}"
                                  Format="${point.x} : <b>${point.y}</b>"
                                  EnableHighlight="true">
            </ChartTooltipSettings>
            <!-- Series -->
            
                <ChartSeries DataSource="InvestmentData"
                             XName="X"
                             YName="Y"
                             Name="Singapore"
                             Type="ChartSeriesType.Line"
                             DashArray="4,4">
                    <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                </ChartSeries>

                <ChartSeries DataSource="InvestmentData"
                             XName="X"
                             YName="Y1"
                             Name="Saudi Arabia"
                             Type="ChartSeriesType.Line"
                             DashArray="4,4">
                    <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                </ChartSeries>

                <ChartSeries DataSource="InvestmentData"
                             XName="X"
                             YName="Y2"
                             Name="Spain"
                             Type="ChartSeriesType.Line"
                             DashArray="4,4">
                    <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                </ChartSeries>

                <ChartSeries DataSource="InvestmentData"
                             XName="X"
                             YName="Y3"
                             Name="Portugal"
                             Type="ChartSeriesType.Line"
                             DashArray="4,4">
                    <ChartMarker Visible="true" IsFilled="true"></ChartMarker>
                </ChartSeries>
            
            <ChartLegendSettings EnableHighlight="true"></ChartLegendSettings>
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────
     REFERENCE LINE
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Reference Line</b></h5>
    </Header>
    <Content>
        <p>Reference lines provide visual benchmarks that help compare actual values against targets, thresholds, or key limits.</p>
        <p>In a Blazor Line chart, reference lines are rendered using the <code>ChartStriplines</code> collection. Each <code>ChartStripline</code> can define its position using the <code>Start</code> and <code>End</code> properties, apply dashed styling through <code>DashArray</code>, display descriptive text labels via the <code>Text</code> property, and control visibility and layering within the chart area.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@WeeklySalesCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Weekly sales vs Target" Theme="@_currentTheme">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               Minimum="new DateTime(2024, 3, 27)"
                               Maximum="new DateTime(2024, 6, 26)" Format="MMM dd, yyyy" LabelRotation="-45">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Title="Sales" Minimum="0" RangePadding="ChartRangePadding.None" LabelFormat="{value}K">
                <ChartAxisLineStyle Width="0" />

                <ChartStriplines>
                    <!-- Target dashed line -->
                    <ChartStripline Start="12" End="12.1"
                                    DashArray="10,10"
                                    Color="#79747E"
                                    ZIndex="ZIndexPosition.Over"
                                    Visible="true">
                    </ChartStripline>
                    <!-- Target label -->
                    <ChartStripline Start="12.5" End="12.6"
                                    Text="Weekly sales target"
                                    Color="Transparent"
                                    Visible="true" 
                                    HorizontalAlignment="Anchor.Start">
                        <ChartStriplineTextStyle Size="14px" FontWeight="400" Color="@TextColor" />
                    </ChartStripline>
                </ChartStriplines>
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="WeeklySalesData"
                             XName="Date"
                             YName="Sales"
                             Type="ChartSeriesType.Line">
                    <ChartMarker Visible="true">
                        <ChartDataLabel Visible="true" Format="${value}"
                                        Font="@(new ChartDataLabelFont { Color = TextColor })">
                    <ChartDataLabelBorder Width="2" Color="#0A97B0">
                    </ChartDataLabelBorder>
                </ChartDataLabel>
                </ChartMarker>
                                </ChartSeries>
                              
             <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Sales : <b>${point.y}</b>" EnableHighlight="true" />
                              </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────
     MULTI COLORED LINE
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Multi-Colored Line</b></h5>
    </Header>
    <Content>
        <p>Multi-colored Line charts apply different colors to individual segments of a single line series, making it easier to highlight trends, ranges, or phases within continuous data.</p>
        <p>In the Syncfusion Blazor Toolkit, this behavior is enabled by setting the <code>Type</code> property to <code>ChartSeriesType.MultiColoredLine</code> and mapping a color field from the data source using the <code>PointColorMapping</code> property in the <code>ChartSeries</code> component. This approach is ideal for identifying variations without splitting the data into multiple series.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@MultiColoredLineCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="U.S. Historical Temperature Trends (1895–2025)" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               Minimum="new DateTime(1895, 1, 1)"
                               Maximum="new DateTime(2025, 1, 1)"
                               Interval="20"
                               RangePadding="ChartRangePadding.Normal"
                               Format="yyyy"
                               EdgeLabelPlacement="EdgeLabelPlacement.None">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>
            <ChartPrimaryYAxis Minimum="20"
                               Maximum="40"
                               Interval="4"
                               Title="Mean Temperature (°F)"
                               LabelFormat="{value}°F"
                               EdgeLabelPlacement="EdgeLabelPlacement.Shift">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>
            
                <ChartSeries DataSource="AverageTemperatureData"
                             XName="Date"
                             YName="Value"
                             Type="ChartSeriesType.MultiColoredLine"
                             PointColorMapping="Color"
                             Width="2">
                    <ChartMarker AllowHighlight="false" />
                </ChartSeries>
            
            <ChartTooltipSettings Enable="true"
                                  Header="Year: ${point.x}"
                                  ShowHeaderLine="true"
                                  Format="Average Temperature : ${point.y}" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────────────────────
     SKIP MISSING POINTS
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Skip Missing Points</b></h5>
    </Header>
    <Content>
        <p>Data points with <code>null</code> or missing values are treated as empty points in the line series. You can control how these gaps are rendered to maintain chart readability.</p>
        <p>The <code>ChartEmptyPointSettings</code> component supports multiple modes through the <code>Mode</code> property, including <code>EmptyPointMode.Gap</code>, <code>EmptyPointMode.Zero</code>, <code>EmptyPointMode.Average</code>, and <code>EmptyPointMode.Drop</code>. Each mode defines whether the line breaks, connects, or substitutes values when encountering missing data.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@SkipMissingCode">
    <PreviewSection>
        <div class="mb-3">
            <label class="fw-bold d-block mb-2">Empty Point Mode</label>

            <SfButtonGroup Mode="SelectionMode.Single">
                <Button Selected="@IsSelected(EmptyPointMode.Gap)"
                                   SelectedChanged="@(v => OnModeChanged(v, EmptyPointMode.Gap))">
                    Gap
                </Button>

                <Button Selected="@IsSelected(EmptyPointMode.Zero)"
                                   SelectedChanged="@(v => OnModeChanged(v, EmptyPointMode.Zero))">
                    Zero
                </Button>

                <Button Selected="@IsSelected(EmptyPointMode.Average)"
                                   SelectedChanged="@(v => OnModeChanged(v, EmptyPointMode.Average))">
                    Average
                </Button>

                <Button Selected="@IsSelected(EmptyPointMode.Drop)"
                                   SelectedChanged="@(v => OnModeChanged(v, EmptyPointMode.Drop))">
                    Drop
                </Button>
            </SfButtonGroup>
        </div>
        <!-- CHART -->
        <SfChart @key="@_currentTheme" Title="Sales Analysis" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>
            <ChartPrimaryYAxis>
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@SalesData"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.Line"
                             Fill="@SeriesColor">
                    <ChartEmptyPointSettings Mode="@Mode" />
                    <ChartMarker Visible="true" IsFilled="true" />
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Sales : <b>${point.y} Units</b>" EnableHighlight="true" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────────────────────
     LIVE POINT UPDATE
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Live Point Update</b></h5>
    </Header>
    <Content>
        <p>This sample demonstrates real-time updates in a Line chart, where data points are continuously added while older values are removed to maintain a fixed window.</p>
        <p>In the Syncfusion Blazor Toolkit, the chart automatically re-renders whenever the bound data source (e.g., <code>ObservableCollection</code>) changes. This makes Line Charts well-suited for live monitoring scenarios such as telemetry, system metrics, or streaming sensor data.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@LivePointUpdateCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Live Line Chart" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" LabelFormat="mm:ss" Title="Time (s)">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>
            <ChartArea>
                <ChartAreaBorder Width="0"></ChartAreaBorder>
            </ChartArea>
            <ChartPrimaryYAxis Minimum="0" Maximum="70">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>
            
                <ChartSeries Type="ChartSeriesType.Line" DataSource="@DataPoints"
                             XName="@nameof(ChartDataPointLive.Time)" YName="@nameof(ChartDataPointLive.CPU_Usage)">
                    <ChartSeriesAnimation Enable="true" Duration="500" />
                    <ChartMarker Visible="true" />
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────────────────────
     INVERTED AXES
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Inverted Axes</b></h5>
    </Header>
    <Content>
        <p>An inverted (transposed) Line Chart swaps the positions of the X-axis and Y-axis, presenting the data in a vertical orientation.</p>
        <p>In Blazor charts, this layout is enabled by setting the <code>IsTransposed</code> property of the <code>SfChart</code> component to <code>true</code>. Transposed charts are helpful when working with long category labels or comparing values across a vertical scale.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@InvertedAxesCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Climate Graph in 2024" IsTransposed="true" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
            <!-- X AXIS -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />

            </ChartPrimaryXAxis>

            <!-- Y AXIS -->
            <ChartPrimaryYAxis LabelFormat="{value}°C">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>

            </ChartPrimaryYAxis>

            <!-- SERIES -->
            
                <ChartSeries DataSource="@ClimateData"
                             XName="Month"
                             YName="London"
                             Name="London"
                             Type="ChartSeriesType.Line"
                             Fill="@TwoSeriesColors[0]">
                    <ChartMarker Visible="true" Shape="ChartShape.Circle" IsFilled="true" />
                </ChartSeries>

                <ChartSeries DataSource="@ClimateData"
                             XName="Month"
                             YName="France"
                             Name="France"
                             Type="ChartSeriesType.Line"
                             Fill="@TwoSeriesColors[1]">
                    <ChartMarker Visible="true" Shape="ChartShape.Circle" IsFilled="true" />
                </ChartSeries>
            

            <!-- TOOLTIP -->
            <ChartTooltipSettings Enable="true"
                                  Header="${series.name}" EnableHighlight="true" />
            <ChartLegendSettings EnableHighlight="true"></ChartLegendSettings>

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<!-- ─────────────────────────────────────────────────────────────
     NEGATIVE DATA
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Negative Data</b></h5>
    </Header>
    <Content>
        <p>Line Charts can represent both positive and negative values, making them ideal for visualizing growth, decline, or fluctuations around a baseline.</p>
        <p>When negative values are present in the data source, the line naturally dips below the axis, allowing declines or losses to be easily identified. <code>ChartStriplines</code> can be used alongside the series to highlight significant positive or negative thresholds.</p>
    </Content>
</Description>

