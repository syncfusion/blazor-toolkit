@page "/charts/stepline-chart"
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Buttons

<PageTitle>Syncfusion Blazor Toolkit Stepline Chart Demo</PageTitle>

<!-- ─────────────────────────────────────────────
     OVERVIEW
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        A Stepline Chart displays data using horizontal and vertical segments
        instead of diagonal slopes, clearly highlighting discrete changes
        between consecutive values.

        In the Syncfusion Blazor Toolkit, a Stepline Chart is created by setting
        the <code>Type</code> property of the <code>ChartSeries</code> component to
        <code>ChartSeriesType.Stepline</code>. This Chart supports markers, data
        labels, tooltips, and full axis customization, making it ideal for
        visualizing year‑over‑year or stage‑based progressions.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StepLineOverviewCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Worldwide Best-Selling Albums by Year" Theme="@_currentTheme">
                <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="${point.x}"
                                      Format="Sales : <b>${point.y}M</b>"
                                      EnableHighlight="true" />

                <!-- X Axis -->
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                                   Minimum="2006"
                                   Maximum="2025"
                                   Interval="3">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                    <ChartAxisMinorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis Minimum="0"
                                   Maximum="20"
                                   Interval="4"
                                   Title="Sales in million">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="@StepLineData"
                                 XName="X"
                                 YName="Y"
                                 Width="3"
                                 Fill="#0FAF9C"
                                 Type="ChartSeriesType.StepLine">
                        <ChartMarker IsFilled="true" />
                    </ChartSeries>
                
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     DATA LABEL
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Data Label</b></h5>
    </Header>
    <Content>
        Data labels display the exact value of each data point directly on the
        Stepline, making changes between consecutive levels easy to interpret
        without relying on tooltips.

        In a Step Line Chart, data labels are enabled by setting the
        <code>Visible</code> property of the <code>ChartDataLabel</code> component
        to <code>true</code> inside the <code>ChartMarker</code>. This ensures that
        the value for each step is clearly displayed along the series.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StepLineDataLabelCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Worldwide Best-Selling Albums by Year" Theme="@_currentTheme">
                <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="${point.x}"
                                      Format="Sales : <b>${point.y}M</b>"
                                      EnableHighlight="true" />

                <!-- X Axis -->
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                                   Minimum="2006"
                                   Maximum="2025"
                                   Interval="3">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                    <ChartAxisMinorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis Minimum="0"
                                   Maximum="20"
                                   Interval="4"
                                   Title="Sales in million">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="@StepLineData"
                                 XName="X"
                                 YName="Y"
                                 Width="3"
                                 Fill="#0FAF9C"
                                 Type="ChartSeriesType.StepLine">
                        <ChartMarker IsFilled="true">
                            <ChartDataLabel Visible="true" />
                        </ChartMarker>
                    </ChartSeries>
                
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     SKIP MISSING POINTS
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Skip Missing Points</b></h5>
    </Header>
    <Content>
        Step Line Charts can contain missing or <code>null</code> values, which
        are treated as empty points. You can control how the Stepline behaves
        when it encounters such gaps.

        The Syncfusion Blazor Toolkit supports multiple empty point modes through
        the <code>ChartEmptyPointSettings</code> component:
        <code>Gap</code>, <code>Zero</code>, <code>Average</code>, and
        <code>Drop</code>. Since the Toolkit does not provide a dropdown
        component, an interactive <code>SfButtonGroup</code> is used to switch
        between these modes.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StepLineSkipMissingCode">
        <PreviewSection>
            <!-- EMPTY POINT MODE SELECTOR -->
            <div class="mb-3 text-center">
                <label class="fw-bold d-block mb-2">Empty Point Mode</label>
                <SfButtonGroup Mode="SelectionMode.Single">
                    <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Gap)"
                                       SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Gap))">
                        Gap
                    </Button>

                    <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Zero)"
                                       SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Zero))">
                        Zero
                    </Button>

                    <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Average)"
                                       SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Average))">
                        Average
                    </Button>

                    <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Drop)"
                                       SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Drop))">
                        Drop
                    </Button>
                </SfButtonGroup>

                <!-- CHART -->
                <SfChart @key="@_currentTheme" Title="Worldwide Best-Selling Albums by Year" Theme="@_currentTheme">
                    <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                    <ChartTooltipSettings Enable="true"
                                          Header="${point.x}"
                                          Format="Sales : <b>${point.y}M</b>"
                                          EnableHighlight="true" />

                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                                       Minimum="2006"
                                       Maximum="2025"
                                       Interval="3">
                        <ChartAxisMajorGridLines Width="0" />
                        <ChartAxisMajorTickLines Width="0" />
                        <ChartAxisMinorTickLines Width="0" />
                    </ChartPrimaryXAxis>

                    <ChartPrimaryYAxis Minimum="0"
                                       Maximum="20"
                                       Interval="4"
                                       Title="Sales in million">
                        <ChartAxisLineStyle Width="0" />
                        <ChartAxisMajorTickLines Width="0" />
                    </ChartPrimaryYAxis>

                    
                        <ChartSeries DataSource="@StepLineEmptyData"
                                     XName="X"
                                     YName="Y"
                                     Width="3"
                                     Type="ChartSeriesType.StepLine"
                                     Fill="#0FAF9C">
                            <ChartEmptyPointSettings Mode="@CurrentEmptyPointMode" />
                            <ChartMarker Visible="true" IsFilled="true" />
                        </ChartSeries>
                    
                </SfChart>
            </div>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     INVERTED AXES
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Inverted Axes</b></h5>
    </Header>
    <Content>
        An inverted or transposed Stepline Chart swaps the X‑axis and Y‑axis,
        displaying categories along the vertical axis and values along the
        horizontal axis.

        In the Syncfusion Blazor Toolkit, this layout is enabled by setting the
        <code>IsTransposed</code> property of the <code>SfChart</code> component
        to <code>true</code>. Transposed Stepline Charts are useful when working
        with dense category labels or when comparing multiple series across a
        vertical scale.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StepLineInvertedAxesCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Unemployment rate 1975 - 2010" Theme="@_currentTheme"
                     IsTransposed="true">
                <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>

                <!-- X Axis (Category) -->
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                    <ChartAxisMajorTickLines Width="0" />
                    <ChartAxisMinorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis LabelFormat="{value}%">
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="@StepLineTransposedData"
                                 XName="X"
                                 YName="Y1"
                                 Name="China"
                                 Width="2"
                                 Type="ChartSeriesType.StepLine"
                                 Fill="@ChinaColor">
                        <ChartMarker Visible="true"
                                     Shape="ChartShape.Circle"
                                     IsFilled="true" />
                    </ChartSeries>

                    <ChartSeries DataSource="@StepLineTransposedData"
                                 XName="X"
                                 YName="Y2"
                                 Name="Australia"
                                 Width="2"
                                 Type="ChartSeriesType.StepLine"
                                 Fill="@AustraliaColor">
                        <ChartMarker Visible="true"
                                     Shape="ChartShape.Circle"
                                     IsFilled="true" />
                    </ChartSeries>
                

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="${series.name}"
                                      EnableHighlight="true" />
                <ChartLegendSettings EnableHighlight="true"></ChartLegendSettings>
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     STEP POSITION
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Step Position</b></h5>
    </Header>
    <Content>
        Step position controls how horizontal and vertical segments are aligned
        between consecutive points in a Stepline Chart.

        The Syncfusion Blazor Toolkit supports three step positions:
        <code>Left</code>, <code>Center</code>, and <code>Right</code>. Since the
        Toolkit does not provide a dropdown component, the step position can be
        changed interactively using a <code>SfButtonGroup</code>, providing a
        clean and accessible alternative for selecting step alignment.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StepLineStepPositionCode">
        <PreviewSection>
            <div class="mb-3 text-center">
                <label class="fw-bold d-block mb-2">Empty Point Mode</label>
                <SfButtonGroup Mode="SelectionMode.Single">
                    <Button Selected="@IsStepSelected(StepPosition.Left)"
                                       SelectedChanged="@(v => OnStepChanged(v, StepPosition.Left))">
                        Left
                    </Button>

                    <Button Selected="@IsStepSelected(StepPosition.Center)"
                                       SelectedChanged="@(v => OnStepChanged(v, StepPosition.Center))">
                        Center
                    </Button>

                    <Button Selected="@IsStepSelected(StepPosition.Right)"
                                       SelectedChanged="@(v => OnStepChanged(v, StepPosition.Right))">
                        Right
                    </Button>
                </SfButtonGroup>
            </div>

            <SfChart @key="@_currentTheme" Title="Worldwide Best-Selling Albums by Year" Theme="@_currentTheme">
                <ChartArea>
                    <ChartAreaBorder Width="0" />
                </ChartArea>

                <ChartTooltipSettings Enable="true"
                                      Header="${point.x}"
                                      Format="Sales : <b>${point.y}M</b>"
                                      EnableHighlight="true" />

                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                                   Minimum="2006"
                                   Maximum="2025"
                                   Interval="3">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                    <ChartAxisMinorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <ChartPrimaryYAxis Minimum="0"
                                   Maximum="20"
                                   Interval="4"
                                   Title="Sales in million">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                
                    <ChartSeries DataSource="@StepLineData"
                                 XName="X"
                                 YName="Y"
                                 Width="3"
                                 StepPosition="@CurrentStepPosition"
                                 Type="ChartSeriesType.StepLine"
                                 Fill="#0FAF9C">
                        <ChartMarker Visible="true" IsFilled="true" />
                    </ChartSeries>
                
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     SERIES CUSTOMIZATION
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Series Customization</b></h5>
    </Header>
    <Content>
        Series customization allows you to control the visual appearance of a
        Stepline, including line thickness, dash patterns, opacity, and step
        alignment.

        In the Syncfusion Blazor Toolkit, these options are configured using
        properties such as <code>Width</code>, <code>DashArray</code>,
        <code>Opacity</code>, and <code>StepPosition</code> on the
        <code>ChartSeries</code> component. This provides flexibility to highlight
        trends or differentiate a Stepline from other series.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StepLineSeriesCustomizationCode">
        <PreviewSection>
            <SfChart @key="@_currentTheme" Title="Worldwide Best-Selling Albums by Year" Theme="@_currentTheme">
                <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="${point.x}"
                                      Format="Sales : <b>${point.y}M</b>"
                                      EnableHighlight="true" />

                <!-- X Axis -->
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                                   Minimum="2006"
                                   Maximum="2025"
                                   Interval="3">
                    <ChartAxisMajorGridLines Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                    <ChartAxisMinorTickLines Width="0" />
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis Minimum="0"
                                   Maximum="20"
                                   Interval="4"
                                   Title="Sales in million">
                    <ChartAxisLineStyle Width="0" />
                    <ChartAxisMajorTickLines Width="0" />
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="@StepLineData"
                                 XName="X"
                                 YName="Y"
                                 Width="3"
                                 DashArray="5,6"
                                 Opacity="0.7"
                                 StepPosition="StepPosition.Right"
                                 Fill="@CustomizedSeriesColor"
                                 Type="ChartSeriesType.StepLine">
                        <ChartMarker Visible="true"
                                     Shape="ChartShape.Circle"
                                     IsFilled="true" />
                    </ChartSeries>
                
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

