@page "/charts/overview"
@using Syncfusion.Blazor.Toolkit.Charts

<PageTitle>Blazor Chart Overview | Syncfusion Toolkit</PageTitle>

<div class="container" >
    <h4>Blazor Chart Overview</h4>
    <p>
        The <strong><a href="https://www.syncfusion.com/blazor-components/blazor-charts" target="_blank">Syncfusion Blazor Toolkit Chart</a></strong> is a high-performance data visualization component designed
        for modern <strong>Blazor applications</strong>. It enables developers to represent complex data using
        interactive and customizable Charts. The component works seamlessly with both
        <strong>Blazor Server</strong> and <strong>Blazor WebAssembly</strong>, supporting data binding from
        local collections as well as remote data services.
    </p>

    <p>
        The Blazor Chart component provides smooth rendering, built-in interactivity, and extensive configuration
        options, helping developers build responsive and visually rich data-driven applications using the power
        of .NET and Blazor.
    </p>
</div>
<style>
    .right-panel{
        display:none;
    }

    p {
        margin-bottom: 16px;
    }

</style>

<VirtualizeSection MinHeightPx="600px"></VirtualizeSection>
<CodePreview IsFullWidth="true" CodeSection="@OverviewCode">
    <PreviewSection>
        <div class="row">
            <div class="col-md-6">
                <SfChart Height="300px" Title="Monthly Sales Growth" Theme="@_currentTheme">
                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
                    <ChartPrimaryYAxis Title="Sales in Percentage">
                    </ChartPrimaryYAxis>
                    
                        <ChartSeries DataSource="OverviewData.overviewLineData"
                                     XName="Month"
                                     YName="Growth"
                                     Type="ChartSeriesType.Spline"
                                     Fill="#FF74B0"
                                     Width="2">
                            <ChartMarker Visible="true"></ChartMarker>
                        </ChartSeries>
                    

                    <ChartTooltipSettings Enable="true" Format="Sales : <b>${point.y}</b>%" />
                </SfChart>
            </div>

            <div class="col-md-6">
                <SfChart Height="300px" Title="Total Sales by Product" Theme="@_currentTheme">
                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
                    <ChartPrimaryYAxis Title="Units Sold">
                    </ChartPrimaryYAxis>

                    
                        <ChartSeries DataSource="OverviewData.overviewColumnData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.Column"
                                     Fill="#C08DFF"
                                     ColumnWidth="0.6" />
                    

                    <ChartTooltipSettings Enable="true"
                                          Format="Sales : <b>${point.y} Units</b>" />
                </SfChart>
            </div>
        </div>

        <br />

        <div class="row">
            <div class="col-md-6">
                <SfChart Height="300px" Title="Online vs Retails" Theme="@_currentTheme">
                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
                    <ChartPrimaryYAxis Title="Sales in Units">
                    </ChartPrimaryYAxis>

                    
                        <ChartSeries DataSource="OverviewData.overviewSplineAreaData"
                                     XName="X"
                                     YName="Y"
                                     Type="ChartSeriesType.SplineArea"
                                     Name="Online"
                                     Fill="#00BFFF"
                                     Opacity="0.5" />
                        <ChartSeries DataSource="OverviewData.overviewSplineAreaData"
                                     XName="X"
                                     YName="Y1"
                                     Type="ChartSeriesType.SplineArea"
                                     Name="Retails"
                                     Fill="#FF00CC80"
                                     Opacity="0.5" />
                    
                    <ChartLegendSettings Visible="false"></ChartLegendSettings>
                    <ChartTooltipSettings Enable="true"
                                          Header="${series.name}"
                                          Format="${point.x} : <b>${point.y} Units</b>" />
                </SfChart>
            </div>

            <div class="col-md-6">
                <SfChart Height="300px" Title="Product Performance" Theme="@_currentTheme">
                    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />
                    <ChartPrimaryYAxis Minimum="1" Maximum="5" Title="Performance Rating">
                    </ChartPrimaryYAxis>

                    
                        <ChartSeries DataSource="OverviewData.overviewBubbleData"
                                     XName="X"
                                     YName="Rating"
                                     Size="Size"
                                     Type="ChartSeriesType.Bubble"
                                     TooltipMappingName="ReviewCount"
                                     PointColorMapping="Color"
                                     MinRadius="2"
                                     MaxRadius="6"
                                     Width="2" />
                    
                    <ChartTooltipSettings Enable="true"
                                          Format="Rating : <b>${point.y}</b><br/>Reviews : <b>${point.tooltip}</b>" />
                </SfChart>
            </div>
        </div>
    </PreviewSection>
</CodePreview>

