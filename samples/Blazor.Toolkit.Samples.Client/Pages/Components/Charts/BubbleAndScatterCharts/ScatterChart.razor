    public string dynamicUpdateCode = @"@using Syncfusion.Blazor.Toolkit.Charts
@using System.Collections.ObjectModel
@using System.Timers

<SfChart @key=""@_currentTheme"" Theme=""@_currentTheme"" >
    <ChartTitleStyle Color=""@TextColor"" />
    <ChartPrimaryXAxis ValueType=""Syncfusion.Blazor.Toolkit.ValueType.Double"">
        <ChartAxisLabelStyle Color=""@TextColor"" />
    </ChartPrimaryXAxis>
    <ChartPrimaryYAxis ValueType=""Syncfusion.Blazor.Toolkit.ValueType.Double"" Interval=""10"">
        <ChartAxisLabelStyle Color=""@TextColor"" />
    </ChartPrimaryYAxis>
    
        <ChartSeries DataSource=""@Data""
                     XName=""X""
                     YName=""Y""
                     Type=""ChartSeriesType.Scatter""
                     Fill=""#5853C6""
                     Animation=""ScatterAnimation"">
            <ChartMarker Visible=""true""
                         Width=""10""
                         Height=""10""
                         Shape=""ChartShape.Circle"">
            </ChartMarker>
        </ChartSeries>
    
</SfChart>

@code {
    private Theme _currentTheme = Theme.Fluent;

    public class ScatterDataPoint
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    private ChartSeriesAnimation ScatterAnimation = new ChartSeriesAnimation
    {
        Enable = true,
        Duration = 1000
    };

    private ObservableCollection<ScatterDataPoint> Data = new();
    private System.Timers.Timer? timer;
    private readonly Random random = new();
    private const int START_YEAR = 2017;
    private const int DATA_COUNT = 12;

    protected override void OnInitialized()
    {
        _currentTheme = Theme.Fluent;

        Data = new ObservableCollection<ScatterDataPoint>(GenerateInitialData());

        timer = new System.Timers.Timer(2000);
        timer.Elapsed += (_, _) =>
        {
            InvokeAsync(() => {
                UpdateDataSource();
            });
        };
        timer.Start();
    }

    private List<ScatterDataPoint> GenerateInitialData()
    {
        var data = new List<ScatterDataPoint>();

        for (int i = 0; i < DATA_COUNT; i++)
        {
            data.Add(new ScatterDataPoint
            {
                X = START_YEAR + i,
                Y = random.NextDouble() * 50
            });
        }

        return data;
    }

    private void UpdateDataSource()
    {
        for (int i = 0; i < Data.Count; i++)
        {
            Data[i] = new ScatterDataPoint
            {
                X = START_YEAR + i,
                Y = random.NextDouble() * 50
            };
        }
    }

    public void Dispose()
    {
        timer?.Stop();
        timer?.Dispose();
    }
}";
}

