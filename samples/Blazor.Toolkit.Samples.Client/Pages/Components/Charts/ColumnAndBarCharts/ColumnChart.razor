    private void OnTooltipRender(TooltipRenderEventArgs args)
    {
        var dataPoint = Data.FirstOrDefault(d => d.X == args.Data.PointX.ToString());

        if (dataPoint != null)
        {
            double total = dataPoint.Y1 + dataPoint.Y2 + dataPoint.Y3;

            args.Text = $"{args.Data.PointX}<br/>Total: {total:F1} M";
        }
    }
