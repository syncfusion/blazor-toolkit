            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Interval="1000" Format="{value}TWh">
            </ChartPrimaryYAxis>

            <!-- Stack Labels -->
            <ChartStackLabelSettings Visible="true" Format="{value}TWh" />
            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true" />

            <!-- Series Collection -->
            
                <!-- Wind -->
                <ChartSeries DataSource="StackingBarDataLabel"
                             XName="X"
                             YName="Y1"
                             Name="Wind"
                             Type="ChartSeriesType.StackingBar"
                             Fill="#689B8A"
                             Width="0.6">
                </ChartSeries>

                <!-- Solar -->
                <ChartSeries DataSource="StackingBarDataLabel"
                             XName="X"
                             YName="Y2"
                             Name="Solar"
                             Type="ChartSeriesType.StackingBar"
                             Fill="#B2CD9C"
                             Width="0.6">
                </ChartSeries>

                <!-- Hydro -->
                <ChartSeries DataSource="StackingBarDataLabel"
                             XName="X"
                             YName="Y3"
                             Name="Hydro"
                             Type="ChartSeriesType.StackingBar"
                             Fill="#8D8D87"
                             Width="0.6"
                             CornerRadius="@(new ChartCornerRadius { BottomRight = 4, TopRight = 4 })">
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Stacking Group</h5>
    </Header>
    <Content>
        <p>
            A stacking group allows multiple independent stacks within the same category by grouping series together, enabling side‑by‑side comparison of different stacked datasets. You can group stacked bars by using the <code>StackingGroup</code> property in <code>ChartSeries</code>.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@stackingGroup">
    <PreviewSection>
        <SfChart Title="Steel Production by Countries, Grouped by Continent" Theme="@_currentTheme">
