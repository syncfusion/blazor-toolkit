                    <ChartSeriesBorder Width="1" Color="White" />
                </ChartSeries>

                <ChartSeries DataSource="@ChartData.StackingColumnGroupData"
                             XName="X" YName="Y2"
                             Name="Indonesia"
                             Type="ChartSeriesType.StackingBar"
                             StackingGroup="Asia"
                             Fill="#7E99A3"
                             ColumnSpacing="0.2"
                             TooltipMappingName="Total"
                             CornerRadius="@(new ChartCornerRadius { BottomRight = 10, TopRight = 10 })">
                    <ChartSeriesBorder Width="1" Color="White" />
                </ChartSeries>

                <!-- Europe Group -->
                <ChartSeries DataSource="@ChartData.StackingColumnGroupData"
                             XName="X" YName="Y3"
                             Name="Italy"
                             Type="ChartSeriesType.StackingBar"
                             StackingGroup="Europe"
                             Fill="#67BFA2"
                             ColumnSpacing="0.2"
                             TooltipMappingName="Total">
                    <ChartSeriesBorder Width="1" Color="White" />
                </ChartSeries>

                <ChartSeries DataSource="@ChartData.StackingColumnGroupData"
                             XName="X" YName="Y4"
                             Name="France"
                             Type="ChartSeriesType.StackingBar"
                             StackingGroup="Europe"
                             Fill="#B2CD9C"
                             ColumnSpacing="0.2"
                             TooltipMappingName="Total"
                             CornerRadius="@(new ChartCornerRadius { BottomRight = 10, TopRight = 10 })">
                    <ChartSeriesBorder Width="1" Color="White" />
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>100% Stacking Bar</h5>
    </Header>
    <Content>
        <p>
            A 100% stacking Bar Chart scales each bar to 100%, focusing on percentage contribution rather than absolute values, which is useful for comparing composition across categories. To render a 100% stacking bar chart, set the <code>Type</code> property in <code>ChartSeries</code> to <code>ChartSeriesType.StackingBar100</code>.
        </p>
    </Content>
</Description>

