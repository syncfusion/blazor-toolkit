@page "/charts/bar-chart"
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Inputs.Internal
@namespace Blazor.Toolkit.Samples.Client.Pages.Components.Charts.column_and_bar_charts

<PageTitle>Syncfusion Blazor Toolkit Scatter Chart Demo</PageTitle>


<Description>
    <Header>
        <h5>Overview</h5>
    </Header>
    <Content>
        <p>
            A Bar Chart represents data using rectangular bars to compare values across categories and series, making it easy to visualize differences, trends, and performance at a glance. To render a bar chart, set the <code>Type</code> property in <code>ChartSeries</code> to <code>ChartSeriesType.Bar</code>.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@overViewCode">
    <PreviewSection>
        <SfChart Title="Global Smartphone Sales Trends by Brand (2021-2023)" Theme="@_currentTheme">
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Format="{value}M" Title="Units Sold (in Millions)" Maximum="300">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
            </ChartPrimaryYAxis>

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="<b>${series.name}</b>"
                                  Format="${point.x} : <b>${point.y}</b>">
            </ChartTooltipSettings>

            <!-- Series -->
            
                <ChartSeries DataSource="@SmartPhoneService.AppleData"
                             XName="Year"
                             YName="Count"
                             Type="ChartSeriesType.Bar"
                             Fill="#8AA624"
                             Name="Apple"
                             ColumnSpacing="0.3"
                             CornerRadius="@(new ChartCornerRadius { TopRight = 8, BottomRight = 8 })">
                </ChartSeries>

                <ChartSeries DataSource="@SmartPhoneService.XiaomiData"
                             XName="Year"
                             YName="Count"
                             Type="ChartSeriesType.Bar"
                             Fill="#D25D5D"
                             Name="Xiaomi"
                             ColumnSpacing="0.3"
                             CornerRadius="@(new ChartCornerRadius { TopRight = 8, BottomRight = 8 })">
                </ChartSeries>

                <ChartSeries DataSource="@SmartPhoneService.OppoData"
                             XName="Year"
                             YName="Count"
                             Type="ChartSeriesType.Bar"
                             Fill="#239BA7"
                             Name="Oppo"
                             ColumnSpacing="0.3"
                             CornerRadius="@(new ChartCornerRadius { TopRight = 8, BottomRight = 8 })">
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Data Label</h5>
    </Header>
    <Content>
        <p>
            Data labels display the actual values directly on bars, improving readability and reducing the need to refer to axes while allowing customization of position, format, and visibility. Set the <code>Visible</code> property in <code>ChartDataLabel</code> to <code>true</code> to enable data labels.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@dataLabelCode">
    <PreviewSection>
        <SfChart Title="Global Smartphone Sales Trends by Brand (2021–2023)" Theme="@_currentTheme">
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Format="{value}M" Title="Units Sold (in Millions)" Maximum="300">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <!-- Series Collection -->
            
                <!-- Apple -->
                <ChartSeries DataSource="PaletteData"
                             XName="Year"
                             YName="Apple"
                             Type="ChartSeriesType.Bar"
                             Name="Apple"
                             Fill="#8AA624"
                             ColumnSpacing="0.3">
                    <ChartMarker>
                            <ChartDataLabel Visible="true" Format="{value}M" />
                    </ChartMarker>
                    <ChartCornerRadius BottomRight="8" TopRight="8" />
                </ChartSeries>

                <!-- Xiaomi -->
                <ChartSeries DataSource="PaletteData"
                             XName="Year"
                             YName="Xiaomi"
                             Type="ChartSeriesType.Bar"
                             Name="Xiaomi"
                             Fill="#D25D5D"
                             ColumnSpacing="0.3">
                    <ChartMarker>
                        <ChartDataLabel Visible="true" Format="{value}M" />
                    </ChartMarker>
                    <ChartCornerRadius BottomRight="8" TopRight="8" />
                </ChartSeries>

                <!-- Oppo -->
                <ChartSeries DataSource="PaletteData"
                             XName="Year"
                             YName="Oppo"
                             Type="ChartSeriesType.Bar"
                             Name="Oppo"
                             Fill="#239BA7"
                             ColumnSpacing="0.3">
                    <ChartMarker>
                            <ChartDataLabel Visible="true" Format="{value}M" />
                    </ChartMarker>
                    <ChartCornerRadius BottomRight="8" TopRight="8" />
                </ChartSeries>
            

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${series.name}"
                                  Format="${point.x} : <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<Description>
    <Header>
        <h5>Stacking Bar</h5>
    </Header>
    <Content>
        <p>
            A stacking Bar Chart displays multiple data series as segments within one bar, where each segment represents a part of the total and uses different colors for clarity. To render a stacking bar chart, set the <code>Type</code> property in <code>ChartSeries</code> to <code>ChartSeriesType.StackingBar</code>.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@stackingBar">
    <PreviewSection>
        <SfChart Title="Annual Renewable Energy Generation in China (2020–2023) by Source" Theme="@_currentTheme">
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />

            <ChartPrimaryYAxis Interval="1000" Format="{value}TWh">
            </ChartPrimaryYAxis>

            
                <!-- Wind -->
                <ChartSeries DataSource="@StackingBarData"
                             XName="X"
                             YName="Y1"
                             Type="ChartSeriesType.StackingBar"
                             Name="Wind"
                             Fill="#689B8A"
                             Width="0.6">
                </ChartSeries>

                <!-- Solar -->
                <ChartSeries DataSource="@StackingBarData"
                             XName="X"
                             YName="Y2"
                             Type="ChartSeriesType.StackingBar"
                             Name="Solar"
                             Fill="#B2CD9C"
                             Width="0.6">
                </ChartSeries>

                <!-- Hydro -->
                <ChartSeries DataSource="@StackingBarData"
                             XName="X"
                             YName="Y3"
                             Type="ChartSeriesType.StackingBar"
                             Name="Hydro"
                             Fill="#8D8D87"
                             Width="0.6">
                </ChartSeries>
            

            <ChartTooltipSettings Enable="true"
                                  Header="Renewable Energy Generation" Format="${point.x}: ${point.y}TWh" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Stacking Labels</h5>
    </Header>
    <Content>
        <p>
            Stacking labels show values for individual stacked segments or the total bar, making it easier to understand contributions without interaction or tooltips. To enable stacking labels, set the <code>Visible</code> property in <code>ChartStackLabelSettings</code> to <code>true</code>.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@stackLabel">
    <PreviewSection>
        <SfChart Title="Annual Renewable Energy Generation in China (2020–2023) by Source" Theme="@_currentTheme">
