    </PreviewSection>
</CodePreview>
</VirtualizeSection>
<Description>
    <Header>
        
        <h5>Customizing Bar Spacing And Width</h5>
    </Header>
    <Content>
        <p>Customizing bar spacing and width controls the gap and thickness of bars, improving readability and optimizing the visual balance of the chart layout. You can customize the bar spacing and width using the <code>ColumnSpacing</code> and <code>ColumnWidth</code> properties in <code>ChartSeries</code>.</p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@customizeBarCode">
    <PreviewSection>
        <div style="padding:15px; display:flex; gap:25px; margin-bottom:20px;">
            <!-- Column Spacing -->
            <div>
                <label>
                    <b>Column Spacing:</b> @ColumnSpacing.ToString("0.00")
                </label><br />
                <input type="range"
                       min="0.1"
                       max="1"
                       step="0.01"
                       @bind="ColumnSpacing" />
            </div>

            <!-- Column Width -->
            <div>
                <label>
                    <b>Column Width:</b> @ColumnWidth.ToString("0.00")
                </label><br />
                <input type="range"
                       min="0.1"
                       max="1"
                       step="0.01"
                       @bind="ColumnWidth" />
            </div>
        </div>

        <SfChart Title="Global Smartphone Sales Trends by Brand (2021–2023)" Theme="@_currentTheme">
            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Format="${point.x} : <b>${point.y}M</b>" />

            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Maximum="300" Title="Units Sold (in Millions)" Format="{value}M">
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="PaletteData"
                             XName="Year"
                             YName="Apple"
                             Type="ChartSeriesType.Bar"
                             Fill="#8AA624"
                             ColumnSpacing="ColumnSpacing"
                             ColumnWidth="ColumnWidth"
                             Name="Apple">
                </ChartSeries>

                <ChartSeries DataSource="PaletteData"
                             XName="Year"
                             YName="Xiaomi"
                             Type="ChartSeriesType.Bar"
                             Fill="#D25D5D"
                             ColumnSpacing="ColumnSpacing"
                             ColumnWidth="ColumnWidth"
                             Name="Xiaomi">
                </ChartSeries>

                <ChartSeries DataSource="PaletteData"
                             XName="Year"
                             YName="Oppo"
                             Type="ChartSeriesType.Bar"
                             Fill="#239BA7"
                             ColumnSpacing="ColumnSpacing"
                             ColumnWidth="ColumnWidth"
                             Name="Oppo">
                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Bar Width In Pixels</h5>
    </Header>
    <Content>
        <p>Bar width in pixels allows precise control over the thickness of bars, ensuring consistent appearance across different screens and layouts. You can set the bar width in pixels using the <code>ColumnWidthInPixel</code> property in <code>ChartSeries</code>.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@BarWidth">
    <PreviewSection>
        <div class="property-pane">
            <div style="display:flex; align-items:center; gap:20px; padding:15px; border-radius:8px; margin-bottom:20px">
                <div style="min-width:160px">
                    <label style="display:block; margin-bottom:5px; font-weight:500">
                        Column Width (Pixels): @ColumnWidthInPixel
                    </label>

                    <input type="range"
                           min="5"
                           max="100"
                           step="1"
                           value="@ColumnWidthInPixel"
                           @oninput="OnColumnWidthChange"
