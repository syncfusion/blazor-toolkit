            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" Interval="1" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Maximum="60" Interval="10" Format="{value} Mmt">
            </ChartPrimaryYAxis>

            <!-- Legend & Tooltip -->
            <ChartLegendSettings Visible="true" />
            <ChartTooltipSettings Enable="true" />

            <!-- Series -->
            
                <!-- Asia Group -->
                <ChartSeries DataSource="@ChartData.StackingColumnGroupData"
                             XName="X" YName="Y1"
