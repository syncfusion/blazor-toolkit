<Description>
    <Header>
        <h5>Negative Data</h5>
    </Header>
    <Content>
        <p>Negative data values are represented by bars extending in the opposite direction of the baseline, clearly visualizing losses, reductions, or below‑zero performance. The <code>SfChart</code> will automatically plot negative values based on the data provided.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@negativeDataCode">
    <PreviewSection>
        <SfChart Title="Global Ocean Temperature Anomalies" Theme="@_currentTheme">
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                               Minimum="1880"
                               Maximum="2022"
                               Interval="20" Title="Year" LabelIntersectAction="LabelIntersectAction.Trim">
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Minimum="-0.5"
                               Maximum="0.8"
                               Interval="0.2" Title="Temperature Anomaly (°C)" Format="{value}°C">
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="rectSeriesNegativeData"
                             XName="Year"
                             YName="Anomaly"
                             Type="ChartSeriesType.Bar"
                             PointColorMapping="Color">
                    <ChartCornerRadius BottomRight="5" TopRight="5" />
                </ChartSeries>
            

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Anomaly: <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<Description>
    <Header>
       
        <h5>Bar With Track</h5>
    </Header>
    <Content>
        <p>A bar with track includes a background bar indicating the total or target value, while the foreground bar shows the actual progress or achievement. To enable the track, set the <code>EnableSideBySidePlacement</code> property in <code>SfChart</code> to <code>false</code>.</p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@barWithTrackCode">
    <PreviewSection>
        <SfChart Height="450px" Title="Gross Revenue by Region" Width="100%" EnableSideBySidePlacement="false" Theme="@_currentTheme">
            <!-- X Axis -->
            <ChartPrimaryXAxis Title="Region" ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                <ChartAxisMajorTickLines Width="1"></ChartAxisMajorTickLines>
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Format="$ {value}" Minimum="0" Maximum="12000000" Interval="2000000">
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <!-- Track / Target Revenue -->
                <ChartSeries DataSource="@BarWithTrackData"
                             XName="Region"
                             YName="TargetRevenue"
                             Type="ChartSeriesType.Bar"
                             Fill="#B2CD9C"
                             Opacity="0.9"
                             ColumnWidth="0.4">
                    <ChartSeriesBorder Width="1" Color="#689B8A"></ChartSeriesBorder>
                    <ChartCornerRadius TopRight="20" BottomRight="20"></ChartCornerRadius>
                </ChartSeries>

                <!-- Actual Revenue -->
                <ChartSeries DataSource="@BarWithTrackData"
                             XName="Region"
                             YName="Revenue"
                             Type="ChartSeriesType.Bar"
