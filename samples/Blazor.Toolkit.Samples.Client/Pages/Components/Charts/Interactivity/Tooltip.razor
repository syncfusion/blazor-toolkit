                                 Name="Online"
                                 Fill="#799EFF"
                                 ColumnWidth="0.45"
                                 ColumnSpacing="0.1">
                        <ChartCornerRadius TopLeft="4" TopRight="4"></ChartCornerRadius>
                    </ChartSeries>

                    <!-- Retail -->
                    <ChartSeries DataSource="@appearanceTooltipData"
                                 XName="Period"
                                 YName="Percentage2"
                                 Type="ChartSeriesType.Column"
