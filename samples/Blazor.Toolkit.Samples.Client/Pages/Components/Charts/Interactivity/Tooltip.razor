@page "/charts/interactivity/tooltip"

@using Syncfusion.Blazor.Toolkit.Charts;

<PageTitle>Tooltip Chart</PageTitle>
<Description>
    <Header>
        <h5>Default Tooltip</h5>
    </Header>
    <Content>
        <p>
            By default, tooltips are disabled in the Chart. To enable them and display data details when hovering over data points, set the <code>Enable</code> property to <code>true</code> in the <code>ChartTooltipSettings</code> component. Once enabled, the tooltip displays the X and Y values of the corresponding data point.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DefaultCode">
        <PreviewSection>
            
            <SfChart Theme="@_currentTheme" Background="Transparent" >
                <!-- Primary X Axis -->
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                    <ChartAxisLineStyle Width="1" Color="black"></ChartAxisLineStyle>
                </ChartPrimaryXAxis>
                <!-- Primary Y Axis -->
                <ChartPrimaryYAxis Title="kW of public charging per electric LDV" Minimum="0" Maximum="5.4" Interval="0.9">
                    <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                </ChartPrimaryYAxis>
                <!-- Secondary Y Axis -->
                <ChartAxis Title="Number of Electric LDVs per charging point" Name="secondaryAxis"
                            OpposedPosition="true"
                            Minimum="0"
                            Maximum="90"
                            Interval="15">
                    <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                </ChartAxis>
                <!-- Series -->
                
                    <!-- Bar Series -->
                    <ChartSeries DataSource="@evChargingData"
                                 Type="ChartSeriesType.Bar"
                                 XName="Country"
                                 YName="PublicChargingPerEV"
                                 Fill="#799EFF">
                    </ChartSeries>
                    <!-- Scatter Series -->
                    <ChartSeries DataSource="@evChargingData"
                                 Type="ChartSeriesType.Scatter"
                                 XName="Country"
                                 YName="EvPerChargingPoint"
                                 YAxisName="secondaryAxis"
                                 Fill="#FF5850">
                        <ChartMarker Visible="true"
                                     Shape="ChartShape.Circle"
                                     Width="10"
                                     Height="10">
                        </ChartMarker>
                    </ChartSeries>
                
                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"></ChartTooltipSettings>
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Shared Tooltip</h5>
    </Header>
    <Content>
        <p>
            The shared tooltip displays information from all visible series at a single X‑value. To enable this behavior, set the <code>Shared</code> property to <code>true</code> in the <code>ChartTooltipSettings</code> component. This is useful when comparing values across multiple series in the same category.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@SharedToolTipCode">
        <PreviewSection>

            <SfChart Theme="@_currentTheme" Background="Transparent" Title="Population Distribution of the Top 5 Most Populous Countries (2024)" EnableSideBySidePlacement="false" >
                <ChartPrimaryXAxis LabelRotation="0" ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                </ChartPrimaryXAxis>
                <ChartPrimaryYAxis Format="{value}M" Title="Inhabitants (Millions)" Interval="300">
                    <ChartAxisLineStyle Width="0"/>
                </ChartPrimaryYAxis>
                
                    <ChartSeries DataSource="populationData"
                                 XName="Country"
                                 YName="Population"
                                 Name="Total"
                                 Type="ChartSeriesType.Column"
                                 Fill="#7A4BFD"
                                 Width="0.4"
                                 ColumnSpacing="0.4">
                        <ChartCornerRadius TopLeft="4" TopRight="4"/>
                    </ChartSeries>
                    <ChartSeries DataSource="populationData"
                                 XName="Country"
                                 YName="Male"
                                 Name="Male"
                                 Type="ChartSeriesType.Column"
                                 Fill="#FE825C"
                                 Width="0.3"
                                 ColumnSpacing="0.4">
                        <ChartCornerRadius TopLeft="4" TopRight="4"/>
                    </ChartSeries>
                    <ChartSeries DataSource="populationData"
                                 XName="Country"
                                 YName="Female"
                                 Name="Female"
                                 Type="ChartSeriesType.Column"
                                 Fill="#FFDE63"
                                 Width="0.2"
                                 ColumnSpacing="0.4">
                        <ChartCornerRadius TopLeft="4" TopRight="4"/>
                    </ChartSeries>
                
                <ChartTooltipSettings Enable="true" Shared="true"/>
            </SfChart>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Custom Tooltip Content</h5>
    </Header>
    <Content>
        <p>
            Custom tooltip content allows you to define your own layout and text using a tooltip format. By using the <code>Format</code> property in <code>ChartTooltipSettings</code>, additional data fields and custom labels can be included inside the tooltip, providing more meaningful information to users.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@CustomToolTipCode">
        <PreviewSection>

            <SfChart Theme="@_currentTheme" Background="Transparent" Title="World Countries Details">

                <!-- Chart Area -->
                <ChartArea>
                    <ChartAreaBorder Width="1" Color="#E7E3F0"></ChartAreaBorder>
                </ChartArea>

                <ChartPrimaryXAxis Title="Literacy Rate" Minimum="65" Maximum="102" Interval="5">
                    <ChartStripline Visible="true"
                                    Start="70"
                                    End="70.1"
                                    Color="Gray"
                                    DashArray="3,10"
                                    Opacity="0.8">
                    </ChartStripline>
                </ChartPrimaryXAxis>
                <ChartPrimaryYAxis Format="n1" Title="GDP Annual Growth Rate" Minimum="-1" Maximum="10" Interval="2.5">
                    <ChartStriplines>
                        <ChartStripline Visible="true"
                                        Start="1.5"
                                        End="1.6"
                                        Color="Gray"
                                        DashArray="3,10"
                                        Opacity="0.8">
                        </ChartStripline>
                    </ChartStriplines>
                </ChartPrimaryYAxis>

                <!-- Bubble Series -->
                
                    <ChartSeries DataSource="bubbleData"
                                 Type="ChartSeriesType.Bubble"
                                 XName="X"
                                 YName="Y"
                                 Size="Size"
                                 MinRadius="3"
                                 MaxRadius="6"
                                 Opacity="0.6"
                                 PointColorMapping="TooltipColor"
                                 TooltipMappingName="ToolTipMappingName">

                        <ChartMarker>
                            <ChartDataLabel Visible="true"
                                            Name="Text"
                                            Position="ChartLabelPosition.Middle">
                            </ChartDataLabel>
                        </ChartMarker>

                    </ChartSeries>
                

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Format="Literacy Rate : <b>${point.x}%</b><br/>
                GDP Growth Rate : <b>${point.y}</b><br/>
                Population : <b>${point.size} Billion</b>">
                </ChartTooltipSettings>

            </SfChart>

        </PreviewSection>  
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Format The Tooltip</h5>
    </Header>
    <Content>
        <p>
            The tooltip content can be formatted using predefined placeholder values in the <code>Format</code> property. These placeholders help customize how data values are displayed without using a full template, making it easier to control the tooltip text format.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@FormatTooltipCode">
        <PreviewSection>

            <SfChart Theme="@_currentTheme" Background="Transparent" Title="U.S. Agricultural Trade"  >

                <ChartArea Border="@(new ChartAreaBorder { Width = 0 })"></ChartArea>

                <ChartTooltipSettings Enable="true"
                                      EnableMarker="false"
                                      Format="Trade Type : <b>${series.name}</b><br/>
                                  Calendar Year : <b>${point.x}</b><br/>
                                  Amount : <b>$${point.y}</b>">
                </ChartTooltipSettings>

                <ChartPrimaryXAxis Minimum="1990" Maximum="2020"></ChartPrimaryXAxis>

                <ChartPrimaryYAxis Title="USD" Format="{value}B" Minimum="0" Maximum="180" Interval="30">
                </ChartPrimaryYAxis>

                

                    <ChartSeries DataSource="@ExportData"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Line"
                                 Width="3"
                                 Fill="#FF8225"
                                 Name="Exports">
                    </ChartSeries>

                    <ChartSeries DataSource="@ImportData"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Line"
                                 Width="3"
                                 Fill="#0A97B080"
                                 Name="Imports">
                    </ChartSeries>

                

            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Tooltip Header</h5>
    </Header>
    <Content>
        <p>
            The tooltip header allows you to display a title above the tooltip content. By enabling <code>ShowHeaderLine</code> in <code>ChartTooltipSettings</code>, you can show a separating line for the header. This is commonly used to show the X‑axis value, providing better context for the displayed data points and improving readability.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@TooltipHeaderCode">
        <PreviewSection>

            <SfChart Theme="@_currentTheme" Background="Transparent" Title="Household Consumption Expenditure Per Capita"  >

                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                                   Interval="5">
                </ChartPrimaryXAxis>

                <ChartPrimaryYAxis LineStyle="new ChartAxisLineStyle { Width = 0 }"
                                   Maximum="15">
                </ChartPrimaryYAxis>

                

                    <ChartSeries DataSource="@tooltipHeaderData"
                                 XName="X"
                                 YName="UnitedStates"
                                 Type="ChartSeriesType.Spline"
                                 Name="United States"
                                 Fill="#99CC00">
                    </ChartSeries>

                    <ChartSeries DataSource="@tooltipHeaderData"
                                 XName="X"
                                 YName="Italy"
                                 Type="ChartSeriesType.Spline"
                                 Name="Italy"
                                 Fill="#66CCFF">
                    </ChartSeries>

                

                <ChartTooltipSettings Enable="true"
                                      ShowHeaderLine="true"
                                      Format="${point.x} : <b>${point.y}%</b>">
                </ChartTooltipSettings>

            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Render Custom Visuals</h5>
    </Header>
    <Content>
        <p>
            Custom visuals such as icons, images, or styled elements can be rendered inside the tooltip using the <code>Template</code> property in <code>ChartTooltipSettings</code>. This enables visually rich tooltips and helps in presenting data more effectively in dashboards and reports.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@customRenderCode">
        <PreviewSection>
            <SfChart Theme="@_currentTheme" Background="Transparent" Title="Top 5 Countries by Population in 2025"  >
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"/>
                <ChartPrimaryYAxis LabelFormat="{value}M"
                                   Title="Population (Millions)"/>
                <ChartTooltipSettings Enable="true">
                    <Template>
                        @{
                            var data = context as ChartTooltipInfo;
                            CountryMap.TryGetValue(data?.X?.ToString(), out var country);

                            if (country != null)
                            {
                                <div style="
                                width:260px;
                                padding:12px;
                                border-radius:12px;
                                background:linear-gradient(135deg,#ff9ad5,#e8ddff);
                                box-shadow:0 4px 8px rgba(0,0,0,0.2);">

                                    <div style="font-size:18px;font-weight:bold;margin-bottom:8px;">
                                        @country.Country
                                    </div>

                                    <table style="width:100%;font-size:14px;">
                                        <tr>
                                            <td>
                                                <b>Capital</b>
                                            </td>
                                            <td>: @country.Capital</td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <b>Population</b>
                                            </td>
                                            <td>: @country.Population.ToString("N0")</td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <b>Area</b>
                                            </td>
                                            <td>: @country.Area</td>
                                        </tr>
                                    </table>
                                </div>
                            }
                        }
                    </Template>
                </ChartTooltipSettings>

                <!-- Series -->
                
                    <ChartSeries DataSource="@Countries"
                                 XName="Country"
                                 YName="Population"
                                 Type="ChartSeriesType.Column">
                    </ChartSeries>
                

            </SfChart>
            <style>
                .custom-tooltip {
                    background: linear-gradient(135deg, #ff80cf, #e6d8ff);
                    color: #000;
                    padding: 12px;
                    border-radius: 12px;
                    width: 260px;
                }
            
                .tooltip-header {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    font-size: 16px;
                    margin-bottom: 8px;
                }
            
                .tooltip-body p {
                    margin: 2px 0;
                    font-size: 14px;
                }
            </style>
        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Customize Tooltip Appearance</h5>
    </Header>
    <Content>
        <p>
            The appearance of the tooltip can be customized using available styling properties. You can control background color, text style, border, and opacity using properties like <code>Fill</code>, <code>ChartTooltipTextStyle</code>, and <code>ChartTooltipBorder</code> in <code>ChartTooltipSettings</code> to match the application theme and enhance the overall user experience.
        </p>
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@customTooltipRenderCode">
        <PreviewSection>

            <SfChart Theme="@_currentTheme" Background="Transparent" Title="Sales - Yearly Performance"  >
