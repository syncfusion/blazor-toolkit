                    <ChartTooltipTextStyle Color="black"
                                           FontFamily="Arial, Helvetica, sans-serif"
                                           FontWeight="Bold"
                                           Opacity="0.7">
                    </ChartTooltipTextStyle>
                </ChartTooltipSettings>

                <!-- X Axis -->
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
