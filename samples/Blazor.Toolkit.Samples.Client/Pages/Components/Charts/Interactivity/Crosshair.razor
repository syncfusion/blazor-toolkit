@page "/charts/interactivity/crosshair"
@using Syncfusion.Blazor.Toolkit.Buttons
@using Syncfusion.Blazor.Toolkit.Charts;
@using static System.Runtime.InteropServices.JavaScript.JSType
@using static System.Net.WebRequestMethods
@inject HttpClient Http

<PageTitle>Blazor Chart Crosshair Demo | Syncfusion Toolkit</PageTitle>
<Description>
    <Header>
        <h5>Enable Crosshair</h5>
    </Header>
    <Content>
        <p>
            The crosshair feature displays horizontal and vertical reference lines that follow the mouse pointer or touch interaction across the chart area. To enable this feature, set the <code>Enable</code> property in <code>ChartCrosshairSettings</code> to <code>true</code>. This helps users easily track the exact position of data points.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@CrosshairCode">
        <PreviewSection>

          
            <SfChart @key="@_currentTheme" Title="Angular Major Versions by Release Date" Theme="@_currentTheme">

              
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                                   IntervalType="IntervalType.Years"
                                   LabelFormat="dd MMM yyyy">
                    <ChartAxisMajorGridLines Width="0.5"/>
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis Title="Major Version" Interval="5">
                    <ChartAxisMajorGridLines Width="0.5"/>
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="@ChartData.Releases"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Area"
                                 Opacity="0.6"
                                 Fill="rgba(98, 0, 238, 1)">

                        <ChartMarker Visible="true" IsFilled="false">
                            <ChartMarkerBorder Width="2" Color="#6200EE"></ChartMarkerBorder>
                        </ChartMarker>
                    </ChartSeries>
                

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="<b>${point.x}</b>"
                                      Format="Version: <b>${point.y}</b>"/>

                <!-- Crosshair -->
                <ChartCrosshairSettings Enable="true"/>

                <!-- Legend -->
                <ChartLegendSettings Visible="false"/>

            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Highlight Category</h5>
    </Header>
    <Content>
        <p>
            The highlight category option emphasizes the entire category that aligns with the crosshair position. To enable this feature, set the <code>HighlightCategory</code> property in <code>ChartCrosshairSettings</code> to <code>true</code>. When enabled, the corresponding X-axis or Y-axis category is visually highlighted, making it easier to identify related data points across series.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@HighlightCode">
        <PreviewSection>
          
            <SfChart @key="@_currentTheme" Title="Corn vs Wheat Estimated Production, 2023" Width="100%" Height="400px" Theme="@_currentTheme">
              
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"
                                   RangePadding="ChartRangePadding.Normal" LabelIntersectAction="LabelIntersectAction.Rotate90">
                </ChartPrimaryXAxis>

                <ChartPrimaryYAxis Interval="100000" Title="Production (metric tons)">
                </ChartPrimaryYAxis>

                
                    <ChartSeries DataSource="CrosshairData.CornData"
                                 XName="X"
                                 YName="Y"
                                 Name="Corn"
                                 Type="ChartSeriesType.Column"
                                 Fill="#82C100"
                                 LegendShape="LegendShape.Circle">
                    </ChartSeries>

                    <ChartSeries DataSource="CrosshairData.WheatData"
                                 XName="X"
                                 YName="Y"
                                 Name="Wheat"
                                 Type="ChartSeriesType.Column"
                                 Fill="#E77A16"
                                 LegendShape="LegendShape.Circle">
                    </ChartSeries>
                

                <!-- Crosshair -->
                <ChartCrosshairSettings Enable="true"
                                        LineType="LineType.Vertical"
                                        HighlightCategory="true">
                    <ChartCrosshairLine Color="#EADDFF"></ChartCrosshairLine>
                </ChartCrosshairSettings>

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Shared="true"
                                      Header="<b>${point.x}</b>"
                                      Format="${series.name}: <b>${point.y} MT</b>">
                </ChartTooltipSettings>

            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>
<Description>
    <Header>
        <h5>Label</h5>
    </Header>
    <Content>
        <p>
            The crosshair label displays the corresponding axis value at the intersection point of the crosshair lines. To display the crosshair label, set the <code>Enable</code> property in <code>ChartAxisCrosshairTooltip</code> within the axis configuration to <code>true</code>. This provides precise information about the data position and improves readability during data inspection.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@LabelCode">
        <PreviewSection>
            
            <SfChart @key="@_currentTheme" Title="Global Market Capitalization (Current US$)" Theme="@_currentTheme">

                <!-- Legend -->
                <ChartLegendSettings Visible="false"></ChartLegendSettings>

                <!-- Crosshair -->
                <ChartCrosshairSettings Enable="true" DashArray="2,3" LineType="LineType.Both">

                    <ChartCrosshairLine Width="1.5"></ChartCrosshairLine>
                </ChartCrosshairSettings>

                <!-- X Axis -->
              
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                    <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                    <ChartAxisCrosshairTooltip Enable="true"></ChartAxisCrosshairTooltip>
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis Title="Market Cap (Billions of US$)" Interval="40000">
                    <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                    <ChartAxisCrosshairTooltip Enable="true"></ChartAxisCrosshairTooltip>
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="Data"
                                 XName="Year"
                                 YName="ValueB"
                                 Type="ChartSeriesType.SplineArea"
                                 Name="Market Cap"
                                 Width="2"
                                 Opacity="0.6"
                                 Fill="#38BE09">
                        <ChartSeriesBorder Width="2" Color="#38BE09"></ChartSeriesBorder>
                    </ChartSeries>
                

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true"
                                      Header="<b>${point.x}</b>"
                                      Format="${series.name}: <b>${point.y} B US$</b>">
                </ChartTooltipSettings>
            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>
<Description>
    <Header>
        <h5>Line Type</h5>
    </Header>
    <Content>
        <p>
            The crosshair line type determines the direction of the crosshair lines. It can be customized to appear as vertical, horizontal, or both using the <code>LineType</code> property in <code>ChartCrosshairSettings</code>. You can also customize it as solid, dashed, or dotted lines using the <code>DashArray</code> property, allowing better visual distinction based on chart requirements.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@LineTypeCode">
        <PreviewSection>
            <div class="property-pane">
                <div style="display:flex; align-items:center; gap:10px;">
                    <label style="font-weight:700;">Crosshair Line Type:</label>
                   
                    <SfButtonGroup Mode="SelectionMode.Single">
                        <Button Selected="IsSelected(LineType.None)" SelectedChanged="@(v => OnModeChanged(v, LineType.None))">None</Button>
                        <Button Selected="IsSelected(LineType.Vertical)" SelectedChanged="@(v => OnModeChanged(v, LineType.Vertical))">Vertical</Button>
                        <Button Selected="IsSelected(LineType.Horizontal)" SelectedChanged="@(v => OnModeChanged(v, LineType.Horizontal))">Horizontal</Button>
                        <Button Selected="IsSelected(LineType.Both)" SelectedChanged="@(v => OnModeChanged(v, LineType.Both))">Both</Button>
                    </SfButtonGroup>
                </div>
            </div>

          
            <SfChart @key="@_currentTheme" Title="India — Top Export Products (USD Billions, OEC 2022)" Theme="@_currentTheme">
                <ChartLegendSettings Visible="false"/>

                <ChartCrosshairSettings Enable="true"
                                        LineType="@Mode"
                                        DashArray="2,3">
                    <ChartCrosshairLine Width="1.5"></ChartCrosshairLine>
                </ChartCrosshairSettings>

              
                <ChartPrimaryXAxis Title="Export Value (USD Billions)" Format="${value}B" LabelIntersectAction="LabelIntersectAction.Rotate90" Minimum="0" ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">

                </ChartPrimaryXAxis>

                
                    <ChartSeries DataSource="Items"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Column"
                                 Fill="#05B3DA"
                                 ColumnSpacing="0.2">
                        <ChartCornerRadius TopLeft="6" TopRight="6"/>
                    </ChartSeries>
                

                <ChartTooltipSettings Enable="true"
                                      Shared="true"
                                      Header="Product: <b>${point.x}</b>"
                                      Format="Export value: <b>$${point.y} Billion</b>"/>
            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>
<Description>
    <Header>
        <h5>Snap</h5>
    </Header>
    <Content>
        <p>
            The snap feature aligns the crosshair directly to the nearest data point instead of following free mouse movement. You can disable this behavior by setting the <code>SnapToData</code> property in <code>ChartCrosshairSettings</code> to <code>false</code>. This ensures accurate value representation, especially when dealing with dense or closely plotted data points.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@SnapCode">
        <PreviewSection>

            <SfChart @key="@_currentTheme" Title="United States GDP (Current US$)" SubTitle="Manual Data (Example)" Theme="@_currentTheme">
                <!-- X Axis -->
                
                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                                   IntervalType="IntervalType.Years"
                                   LabelFormat="yyyy">
                </ChartPrimaryXAxis>

                <!-- Y Axis -->
                <ChartPrimaryYAxis Title="GDP (US$, trillions)" Minimum="0" Format="$ {value}B">

                    <ChartAxisMajorGridLines Width="0.5"/>
                </ChartPrimaryYAxis>

                <!-- Series -->
                
                    <ChartSeries DataSource="GdpData"
                                 XName="X"
                                 YName="Y"
                                 Type="ChartSeriesType.Area"
                                 Fill="#38BE09"
                                 Opacity="0.6"
                                 Name="GDP">
                        <ChartMarker Visible="true">
                            <ChartMarkerBorder Width="2" Color="#38BE09"/>
                        </ChartMarker>
                    </ChartSeries>
                

                <!-- Tooltip -->
                <ChartTooltipSettings Enable="true" Shared="true"
                                      Header="<b>${point.x}</b>"
                                      Format="GDP: <b>${point.y}</b>"/>

                <!-- Crosshair -->
                <ChartCrosshairSettings Enable="true" SnapToData="false"/>

                <!-- Legend -->
                <ChartLegendSettings Visible="false"/>
            </SfChart>

        </PreviewSection>
    </CodePreview>
</VirtualizeSection>

<Description>
    <Header>
        <h5>Style</h5>
    </Header>
    <Content>
        <p>
            The appearance of the crosshair can be customized using styling properties. You can modify attributes such as line color and width using the <code>ChartCrosshairLine</code> component, and the label text opacity using the <code>ChartCrosshairTextStyle</code> component to match the chart theme and improve visual clarity.
        </p>
    </Content>
</Description>
<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@StyleCode">
