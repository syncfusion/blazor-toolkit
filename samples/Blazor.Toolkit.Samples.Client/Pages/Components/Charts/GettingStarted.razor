    private string CompleteChartExample = @"@using Syncfusion.Blazor.Toolkit.Charts

<SfChart Title=""Sales Analysis"" Theme=""@_currentTheme"" Background=""transparent"">
    <ChartPrimaryXAxis Title=""Month"" ValueType=""Syncfusion.Blazor.Toolkit.ValueType.Category""></ChartPrimaryXAxis>
    <ChartPrimaryYAxis Title=""Sales in Dollar""></ChartPrimaryYAxis>
    <ChartLegendSettings Visible=""true""></ChartLegendSettings>
    
        <ChartSeries DataSource=""@Sales"" Name=""Sales"" XName=""Month"" YName=""SalesValue"" Type=""ChartSeriesType.Column"">
        </ChartSeries>
    
</SfChart>
