            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                               Interval="3" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Interval="20">
                <ChartAxisTitle Text="% Annual Exchange Rate" />
                <ChartAxisLineStyle Width="0" />

                <!-- Strip Lines -->
                <ChartStriplines>

                    <!-- Highest Growth Line -->
                    <ChartStripline Start="20"
                                    End="20.5"
                                    Visible="true"
                                    Color="#79747E"
                                    DashArray="10,10"
                                    ZIndex="@ZIndexPosition.Over" />

                    <ChartStripline Start="21"
                                    End="21.5"
                                    Visible="true"
                                    Color="transparent"
                                    DashArray="4,4"
                                    Text="Highest Annual Growth"
                                    HorizontalAlignment="Anchor.End"
                                    ZIndex="@ZIndexPosition.Over"
                                    Rotation="0">
                        <ChartStriplineTextStyle Color="@HighestTextColor" />
                    </ChartStripline>

                    <!-- Lowest Growth Line -->
                    <ChartStripline Start="-25"
                                    End="-24.5"
                                    Visible="true"
                                    Color="#79747E"
                                    DashArray="10,10"
                                    ZIndex="@ZIndexPosition.Over" />

                    <ChartStripline Start="-28.5"
                                    End="-28"
                                    Visible="true"
                                    Color="transparent"
                                    DashArray="4,4"
                                    Text="Lowest Annual Growth"
                                    HorizontalAlignment="Anchor.End"
                                    ZIndex="@ZIndexPosition.Over"
                                    Rotation="0">
                        <ChartStriplineTextStyle Color="@LowestTextColor" />
                    </ChartStripline>

                </ChartStriplines>
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="NegativeData"
                             XName="X"
                             YName="USD"
                             Type="ChartSeriesType.Area"
                             Width="2"
                             Opacity="0.4"
                             Fill="#3CFFD2"
                             Border="@NegativeSeriesBorder">
                    <ChartMarker Visible="true" IsFilled="true" />
                </ChartSeries>
            

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Annual Growth : <b>${point.y}</b>" />

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

