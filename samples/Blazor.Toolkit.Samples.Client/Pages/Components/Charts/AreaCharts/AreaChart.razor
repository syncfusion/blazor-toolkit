<!-- ─────────────────────────────────────────────────────────────
     DATASOURCE UPDATE
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>DataSource Update</b></h5>
    </Header>
    <Content>
        The Chart automatically re-renders when the bound data source is updated, providing a seamless user experience. Smooth transitions between data updates are handled automatically by setting the <code>Enable</code> property to <code>true</code> in <code>ChartSeriesAnimation</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DatasourceUpdateCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Auto-Updating Area Chart" Width="100%" Height="400px" Theme="@_currentTheme">
           
            <!-- X Axis -->
            <ChartPrimaryXAxis Minimum="1"
                               Maximum="7"
                               Interval="1" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Minimum="0"
                               Maximum="100"
                               Interval="20">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorGridLines Width="1" />
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="@ChartData"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.Area"
                             Opacity="0.4"
                             Fill="#3CFFD2"
                             Border="@(new ChartSeriesBorder
                                     {
                                         Width = 2,
                                         Color = "#008264"
                                     })"
                             Animation="@(new ChartSeriesAnimation
                                     {
                                         Enable = true,
                                         Duration = 1500
                                     })" />
            
        </SfChart>
        
    </PreviewSection>
</CodePreview>
</VirtualizeSection>


 
@code {
    [CascadingParameter]
    private Theme CurrentTheme { get; set; } = Theme.Fluent;
    private bool IsDarkTheme => _currentTheme.ToString().Contains("Dark") || _currentTheme.ToString().Contains("HighContrast");
    private string TextColor => IsDarkTheme ? "#ffffff" : "#000000";
   
    private Theme _currentTheme = Theme.Fluent;

    /* =========================
       Model
       ========================= */
    public class ChartPoint
    {
        public int X { get; set; }
        public double Y { get; set; }
    }

    /* =========================
       Data Source
       ========================= */
    private ObservableCollection<ChartPoint> ChartData = new();
    private System.Timers.Timer? timer;
    private readonly Random random = new();

    protected override void OnInitialized()
    {
        _currentTheme = CurrentTheme;
        
        // ─────────────────────────────────────────
        // DATASOURCE UPDATE - Initial load
        // ─────────────────────────────────────────
        ChartData = new ObservableCollection<ChartPoint>(GenerateInitialData());

        // Update data every 2 seconds
        timer = new System.Timers.Timer(2000);
        timer.Elapsed += (_, _) =>
        {
            InvokeAsync(() => {
                UpdateDataSource();
            });
        };
        timer.Start();

        // ─────────────────────────────────────────
        // LIVE POINT UPDATE - Initialize and start timer
        // ─────────────────────────────────────────
        LiveData = new ObservableCollection<LivePoint>(
            Enumerable.Range(0, 20)
                .Select(i => new LivePoint
                {
                    X = DateTime.Now.AddSeconds(i),
                    Y = Random.Shared.Next(30, 60)
                })
        );

        updateLivePointTimer = new System.Timers.Timer(400);
        updateLivePointTimer.Elapsed += async (_, _) =>
        {
            await InvokeAsync(UpdateLivePointData);
        };
        updateLivePointTimer.Start();
    }

    protected override void OnParametersSet()
    {
        _currentTheme = CurrentTheme;
    }

    public void Dispose()
    {
        timer?.Stop();
        timer?.Dispose();
        updateLivePointTimer?.Stop();
        updateLivePointTimer?.Dispose();
    }

    private List<ChartPoint> GenerateInitialData()
    {
        var data = new List<ChartPoint>();
        for (int i = 1; i <= 7; i++)
        {
            data.Add(new ChartPoint
            {
                X = i,
                Y = random.Next(15, 90)
            });
        }
        return data;
    }

    private void UpdateDataSource()
    {
        // Update datasource values in-place (same X, new Y)
        for (int i = 0; i < ChartData.Count; i++)
        {
            ChartData[i] = new ChartPoint
            {
                X = ChartData[i].X,
                Y = 10 + random.NextDouble() * 85
            };
        }
    }

    private void UpdateLivePointData()
    {
        if (LiveData.Count == 0)
            return;

        var lastTime = LiveData[^1].X;

        // Remove the oldest data point
        LiveData.RemoveAt(0);

        // Add a new data point with sequential time
        LiveData.Add(new LivePoint
        {
            X = lastTime.AddSeconds(1),
            Y = Random.Shared.Next(30, 60)
        });
    }

