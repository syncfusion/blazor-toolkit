                                  Format="<b>${series.name}</b><br />Year: <b>${point.x}</b><br />Share: <b>${point.y}B</b>" />
            
            <!-- Legend -->
            <ChartLegendSettings Visible="true" Position="LegendPosition.Bottom" />

            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               RangePadding="ChartRangePadding.Normal"
                               Interval="2"
                               IntervalType="IntervalType.Years"
                               LabelFormat="yyyy">
            </ChartPrimaryXAxis>

            <!-- ✅ Y Axis (FIXED) -->
            <ChartPrimaryYAxis Minimum="0"
                               Maximum="70"
                               Interval="10"
                               LabelFormat="${value}B">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            

                <ChartSeries DataSource="WheatData"
                             XName="X"
                             YName="Y"
                             Name="Wheat"
                             Type="ChartSeriesType.StackingArea"
                             Fill="#38BE09"
                             Opacity="0.9"
                             Border="@(new ChartSeriesBorder { Width = 2 })"
                             LegendShape="LegendShape.Circle" />

                <ChartSeries DataSource="CornAreaData"
                             XName="X"
                             YName="Y"
                             Name="Corn"
                             Type="ChartSeriesType.StackingArea"
                             Fill="#B1212D"
                             Opacity="0.9"
                             Border="@(new ChartSeriesBorder { Width = 2 })"
                             LegendShape="LegendShape.Circle" />

                <ChartSeries DataSource="TreeNutsData"
                             XName="X"
                             YName="Y"
                             Name="Tree Nuts"
                             Type="ChartSeriesType.StackingArea"
                             Fill="#E77A16"
                             Opacity="0.9"
                             Border="@(new ChartSeriesBorder { Width = 2 })"
                             LegendShape="LegendShape.Circle" />

                <ChartSeries DataSource="SoybeansData"
                             XName="X"
                             YName="Y"
                             Name="Soybeans"
                             Type="ChartSeriesType.StackingArea"
                             Fill="#82C100"
                             Opacity="0.9"
                             Border="@(new ChartSeriesBorder { Width = 2 })"
                             LegendShape="LegendShape.Circle" />

            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     100% STACKING AREA
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>100% Stacking Area</b></h5>
    </Header>
    <Content>
        The 100% Stacking Area Chart shows the relative percentage of multiple data series, where the total area always sums to 100%. Set the <code>Type</code> property of <code>ChartSeries</code> to <code>ChartSeriesType.StackingArea100</code> to enable this feature.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
