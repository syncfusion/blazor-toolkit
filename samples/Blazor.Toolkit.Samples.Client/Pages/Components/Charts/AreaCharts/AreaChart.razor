            <!-- Y Axis (100% scale) -->
            <ChartPrimaryYAxis Minimum="0"
                               Maximum="100"
                               Interval="20"
                               LabelFormat="{value}%">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <!-- Series -->
            

