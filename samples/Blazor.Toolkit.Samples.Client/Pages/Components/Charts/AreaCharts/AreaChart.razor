@page "/charts/area/area-chart"
@using Syncfusion.Blazor.Toolkit.Charts
@using Syncfusion.Blazor.Toolkit.Buttons
@using System.Collections.ObjectModel
@using System.Timers
@inject System.Net.Http.HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Blazor Area Chart Demo | Syncfusion Toolkit</PageTitle>

<!-- ─────────────────────────────────────────────────────────────
     OVERVIEW
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        The <code>Area Chart</code> visually represents quantitative data by shading the area between the line and the axis.
        It is ideal for showing trends over time and emphasizing the magnitude of change. This is achieved by setting the <code>Type</code> property of <code>ChartSeries</code> to <code>ChartSeriesType.Area</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@OverviewCode">
    <PreviewSection>
        
        <SfChart @key="@_currentTheme" Title="Global Primary Energy Consumption by Source" Width="100%" Height="400px" Theme="@_currentTheme">
            <ChartTitleStyle Color="@TextColor" />
            
            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${series.name}"
                                  Format="${point.x} : <b>${point.y}</b>" />
            
            <!-- Legend -->
           
            <ChartLegendSettings Visible="true" Position="LegendPosition.Bottom" />

            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"
                               Interval="1">
                <ChartAxisLabelStyle Color="@TextColor" />
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Maximum="3200"
                               Interval="800"
                               LabelFormat="{value}TWh">
                <ChartAxisLabelStyle Color="@TextColor" />
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <!-- Other Renewable -->
            <ChartSeries DataSource="EnergyData"
                            XName="X"
                            YName="Y1"
                            Name="Other Renewable"
                            Type="ChartSeriesType.Area"
                            Opacity="0.5"
                            Fill="#3CFFD2"
                            Border="@(new ChartSeriesBorder
                                    {
                                        Width = 2,
                                        Color = "#008264"
                                    })" />

            <!-- Modern Biofuels -->
            <ChartSeries DataSource="EnergyData"
                            XName="X"
                            YName="Y2"
                            Name="Modern biofuels"
                            Type="ChartSeriesType.Area"
                            Opacity="0.5"
                            Fill="#DCFF89"
                            Border="@(new ChartSeriesBorder
                                    {
                                        Width = 2,
                                        Color = "#5A8100"
                                    })" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     DATA LABEL
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Data Labels</b></h5>
    </Header>
    <Content>
        Data labels provide direct information about data points, making it easier for users to read exact values without referring to the axes. You can enable them by setting the <code>Visible</code> property to <code>true</code> in <code>ChartDataLabel</code> within the <code>ChartMarker</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelCode">
    <PreviewSection>
        
        <SfChart @key="@_currentTheme" Title="Annual Corn Exports 2015 - 2024" Width="100%" Height="400px" Theme="@_currentTheme">

            <ChartTooltipSettings Enable="true"
                                  Header="Export of Corn"
                                  Format="${point.x} : <b>${point.y}</b>" />

            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"
                               Interval="3">
                <ChartAxisLabelStyle />
            </ChartPrimaryXAxis>

            <ChartPrimaryYAxis Maximum="24"
                               Interval="8"
                               LabelFormat="{value}B">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="CornExports"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.Area"
                             Opacity="0.5"
                             Fill="#3CFFD2"
                             Border="@(new ChartSeriesBorder { Width = 2, Color = "#008264" })">

                    <ChartMarker Visible="false">
                        <ChartDataLabel Visible="true"
                                        Position="ChartLabelPosition.Top"
                                            Format="{value}B" 
                                            Font="@(new ChartDataLabelFont { Color = TextColor })">
                        </ChartDataLabel>
                    </ChartMarker>

                </ChartSeries>
            

        </SfChart>

    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     STACKING AREA
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Stacking Area</b></h5>
    </Header>
    <Content>
        Stacking Area Charts allow multiple series to be stacked on top of each other, showing the cumulative total of the data points. This is configured by setting the <code>Type</code> property of <code>ChartSeries</code> to <code>ChartSeriesType.StackingArea</code>.
    </Content>
</Description>

