                <ChartSeries DataSource="CreditCard"
                             XName="X"
                             YName="Y"
                             Name="Credit Card"
                             Type="ChartSeriesType.StackingArea100"
                             Fill="#E77A16"
                             Opacity="1"
                             Border="@(new ChartSeriesBorder { Width = 0.5, Color = "#ffffff" })"
                             LegendShape="LegendShape.Circle" />

                <ChartSeries DataSource="DebitCard"
                             XName="X"
                             YName="Y"
                             Name="Debit Card"
                             Type="ChartSeriesType.StackingArea100"
                             Fill="#6200EE"
                             Opacity="1"
                             Border="@(new ChartSeriesBorder { Width = 0.5, Color = "#ffffff" })"
                             LegendShape="LegendShape.Circle" />

                <ChartSeries DataSource="Cash"
                             XName="X"
                             YName="Y"
                             Name="Cash"
                             Type="ChartSeriesType.StackingArea100"
                             Fill="#05B3DA"
                             Opacity="1"
                             Border="@(new ChartSeriesBorder { Width = 0.5, Color = "#ffffff" })"
                             LegendShape="LegendShape.Circle" />

            

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     MULTI-COLORED AREA
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Multi-Colored Area</b></h5>
    </Header>
    <Content>
        Visualize data trends with varying colors for different segments or data points, allowing for clear distinction between market phases or categories. You can achieve this by setting the <code>Type</code> property of <code>ChartSeries</code> to <code>ChartSeriesType.MultiColoredArea</code> and mapping colors using the <code>PointColorMapping</code> property.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@MultiColoredAreaCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Samsung Smartphone Shipments (2013-2024)" SubTitle="Trend Analysis: From Peak Sales to Recent Market Share" Width="100%" Height="400px" Theme="@_currentTheme">
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"
                               Interval="1"
                               LabelIntersectAction="LabelIntersectAction.Rotate45"
                               EdgeLabelPlacement="EdgeLabelPlacement.Shift">
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
                <ChartPrimaryYAxis Title="Shipments (Million Units)" Minimum="0"
                               Maximum="500"
                               Interval="100"
                               LabelFormat="{value}M">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="@SalesData"
                             XName="Year"
                             YName="Sales"
                             Type="ChartSeriesType.MultiColoredArea"
                             PointColorMapping="Color">
                </ChartSeries>
            

            <!-- Annotations -->
                    <ChartAnnotations>

                <ChartAnnotation X="@("2013")" Y="460" CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        <div style="color:#0B4F4F;font-weight:bold;font-size:14px;">Peak</div>
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@("2017")" Y="345" CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        <div style="color:#26A69A;font-weight:bold;font-size:14px;">Moderate</div>
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@("2021")" Y="290" CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        <div style="color:#B2DFDB;font-weight:bold;font-size:14px;">Low</div>
                    </ContentTemplate>
                </ChartAnnotation>

                <ChartAnnotation X="@("2024")" Y="245" CoordinateUnits="Units.Point">
                    <ContentTemplate>
                        <div style="color:#1F77B4;font-weight:bold;font-size:14px;">Current</div>
                    </ContentTemplate>
                </ChartAnnotation>

            </ChartAnnotations>

        </SfChart>
</PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     SKIP MISSING POINTS
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Skip Missing Points</b></h5>
    </Header>
    <Content>
        Handle null or missing data points gracefully using <code>ChartEmptyPointSettings</code>. You can control the behavior of empty points using the <code>Mode</code> property, with options like <code>Gap</code>, <code>Zero</code>, <code>Drop</code>, and <code>Average</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@MissingPointsCode">
    <PreviewSection>
        <div class="mb-3">
            <label class="fw-bold d-block mb-2">Empty Point Mode</label>

            <SfButtonGroup Mode="SelectionMode.Single">
                <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Gap)"
                                   SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Gap))">
                    Gap
                </Button>

                <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Zero)"
                                   SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Zero))">
                    Zero
                </Button>

                <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Average)"
                                   SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Average))">
                    Average
                </Button>

                <Button Selected="@IsEmptyModeSelected(EmptyPointMode.Drop)"
                                   SelectedChanged="@(v => OnEmptyModeChanged(v, EmptyPointMode.Drop))">
                    Drop
                </Button>
            </SfButtonGroup>
        </div>
       
        <SfChart @key="@_currentTheme" Title="Skip Missing Points" Width="100%" Height="400px" Theme="@_currentTheme">

            
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Interval="100">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="AreaData"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.Area"
                             Width="2"
                             Opacity="0.5"
                             Fill="#3CFFD2"
                             Border="@(new ChartSeriesBorder { Width = 2, Color = "#008264" })">

                    <!-- Empty Point Settings -->
                    <ChartEmptyPointSettings Mode="@SelectedEmptyPointMode" />

                    <!-- Marker -->
                    <ChartMarker Visible="true"
                                 Fill="#008264"
                                 Border="@(new ChartMarkerBorder { Width = 2, Color = "#008264" })" />
                </ChartSeries>
            

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Sales : <b>${point.y} Units</b>" />

        </SfChart>


    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     LIVE POINT UPDATE
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Live Point Update</b></h5>
    </Header>
    <Content>
        The Chart component supports dynamic data updates, allowing you to visualize real-time data streams efficiently. The Chart automatically re-renders when data points are added or removed from the data source bound to the <code>DataSource</code> property.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@LiveUpdateCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Live Update" Width="100%" Height="400px" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
 
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime" 
                               LabelFormat="mm:ss" 
                               Title="Time (s)">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Minimum="0" Maximum="70">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries Type="ChartSeriesType.Area" 
                             DataSource="@LiveData"
                             XName="@nameof(LivePoint.X)" 
                             YName="@nameof(LivePoint.Y)"
                             Opacity="0.4"
                             Fill="#3CFFD2"
                             Border="@(new ChartSeriesBorder { Width = 2, Color = "#008264" })">
                    <ChartSeriesAnimation Enable="true" Duration="500" />
                    <ChartMarker Visible="true" 
                                 Fill="#008264"
                                 Border="@(new ChartMarkerBorder { Width = 2, Color = "#008264" })" />
                </ChartSeries>
            

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     INVERTED AXES
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Inverted Axes</b></h5>
    </Header>
    <Content>
        Transpose the Chart axes to swap the X and Y positions using the <code>IsTransposed</code> property in the <code>SfChart</code> component. This is useful for displaying data that is easier to read horizontally.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@InvertedAxesCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Inverted Axes" Width="100%" Height="400px" IsTransposed="true" Theme="@_currentTheme">    
            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="${series.name} : <b>${point.y}</b>" />

            <!-- X Axis (Category, becomes vertical when transposed) -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category"
                               Interval="3">
                <ChartAxisMajorGridLines Width="1" DashArray="10,10" />
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis LabelFormat="${value}M">
                <ChartAxisLineStyle Width="0" />
            </ChartPrimaryYAxis>

            <!-- Series -->
            

                <!-- Amazon -->
                <ChartSeries DataSource="AmazonData"
                             XName="X"
                             YName="Y"
                             Name="Amazon"
                             Type="ChartSeriesType.Area"
                             Opacity="0.5"
                             Fill="#3CFFD2"
                             Border="@(new ChartSeriesBorder { Width = 2, Color = "#008264" })">
                    <ChartMarker Visible="true"
                                 Shape="ChartShape.Circle" />
                </ChartSeries>

                <!-- Tencent -->
                <ChartSeries DataSource="TencentData"
                             XName="X"
                             YName="Y"
                             Name="Tencent"
                             Type="ChartSeriesType.Area"
                             Opacity="0.5"
                             Fill="#DCFF89"
                             Border="@(new ChartSeriesBorder { Width = 2, Color = "#5A8100" })">
                    <ChartMarker Visible="true"
                                 Shape="ChartShape.Circle" />
                </ChartSeries>

            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     NEGATIVE DATA
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Negative Data</b></h5>
    </Header>
    <Content>
        Area Charts can effectively display data points with negative values, useful for representing losses, decreases, or sub-zero measurements. The area is filled downwards from the zero line for negative values mapped to the <code>YName</code> property.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@NegativeDataCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Annual Gold Price (2009-2023) in USD" Width="100%" Height="400px" Theme="@_currentTheme">
