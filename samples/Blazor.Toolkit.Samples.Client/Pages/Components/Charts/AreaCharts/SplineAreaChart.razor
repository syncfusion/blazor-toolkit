        liveTimer.Elapsed += (s, e) =>
        {
            InvokeAsync(() =>
            {
                if (liveData.Count > 8) liveData.RemoveAt(0);
                liveData.Add(new CategoryPoint { X = DateTime.Now.ToString("HH:mm:ss"), Y = Math.Round(10 + rnd.NextDouble() * 40, 1) });
            });
        };
        liveTimer.Start();
    }
    
    private void UpdateData(object state)
    {
        InvokeAsync(() =>
        {
            for (int i = 0; i < AutoUpdateData.Count; i++)
            {
                AutoUpdateData[i] = new AutoUpdatePoint 
                { 
                    X = AutoUpdateData[i].X, 
                    Y = 10 + rnd.NextDouble() * 85 
                };
            }
        });
    }

    private List<AutoUpdatePoint> GenerateInitialData()
    {
        var list = new List<AutoUpdatePoint>();
        for (int i = 1; i <= 7; i++)
        {
            list.Add(new AutoUpdatePoint { X = i, Y = Math.Floor(rnd.NextDouble() * 75 + 15) });
        }
        return list;
    }

    public void Dispose() => Timer?.Dispose();

    private void StopLive()
    {
        liveTimer?.Stop();
        liveTimer?.Dispose();
        liveTimer = null;
    }
    
