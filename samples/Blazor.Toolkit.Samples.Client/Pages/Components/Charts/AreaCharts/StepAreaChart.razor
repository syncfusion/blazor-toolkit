@page "/charts/area/step-area-chart"
@using Syncfusion.Blazor.Toolkit.Charts
@inject System.Net.Http.HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Syncfusion Blazor Toolkit Step Area Chart Demo</PageTitle>

<!-- ─────────────────────────────────────────────────────────────
     OVERVIEW
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Overview</b></h5>
    </Header>
    <Content>
        The Step Area Chart uses vertical and horizontal lines to connect data points, forming a step-like structure with the area below shaded. This visualization is ideal for representing data that changes at discrete intervals, such as production shifts or price levels. This is achieved by setting the <code>Type</code> property of <code>ChartSeries</code> to <code>ChartSeriesType.StepArea</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
<CodePreview IsFullWidth="true" CodeSection="@OverviewCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Global Electricity Production" Width="100%" Height="400px" Theme="@_currentTheme">
          
            <ChartArea>
                <ChartAreaBorder Width="0" />
            </ChartArea>

            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double" />

            <ChartPrimaryYAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double">
                
                <ChartPrimaryYAxis Format="{value}B" />
            </ChartPrimaryYAxis>

            
                <ChartSeries Type="ChartSeriesType.StepArea"
                             DataSource="@(Renewable.Cast<object>())"
                             XName="X"
                             YName="Y"
                             Name="Renewable"
                             Opacity="0.7"
                             Width="2"
                             Fill="#38BE09"
                             LegendShape="LegendShape.Rectangle">
                    <ChartSeriesBorder Width="2" Color="#38BE09" />
                </ChartSeries>
          


            <ChartSeries Type="ChartSeriesType.StepArea"
                             DataSource="@(NonRenewable.Cast<object>())"
                         XName="X"
                         YName="Y"
                         Name="Non-Renewable"
                         Opacity="0.7"
                         Width="2"
                         Fill="#E77A16"
                             LegendShape="LegendShape.Rectangle">
                    <ChartSeriesBorder Width="2" Color="#E77A16" />
                </ChartSeries>
                         


        

        <ChartTooltipSettings Enable="true"
                              ShowNearestTooltip="true"
                              Header="<b>${series.name}</b>"
                              Format="${point.x}: <b>${point.y}</b>" />
    </SfChart>
</PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     DATA LABEL
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Data Labels</b></h5>
    </Header>
    <Content>
        Enhance readability by displaying data labels at each step of the Chart. You can enable them by setting the <code>Visible</code> property to <code>true</code> in the <code>ChartDataLabel</code> component within the <code>ChartMarker</code>. Customizations such as font and borders can be done using the <code>ChartDataLabelFont</code> and <code>ChartDataLabelBorder</code> components.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DataLabelCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Global Corn Exports (Billions of Tons)" Width="100%" Height="400px" Theme="@_currentTheme">
          
            <!-- Chart Area -->
            <ChartArea>
                <ChartAreaBorder Width="0" />
            </ChartArea>

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header=""
                                  Format="Year: <b>${point.x}</b><br/>Exports: <b>${point.y}</b>" />

            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category">
                <ChartAxisLabelStyle />
            </ChartPrimaryXAxis>

            <!-- Y Axis -->
            <ChartPrimaryYAxis Maximum="24" Interval="6">
                <ChartAxisLineStyle Width="0" />
                <ChartPrimaryYAxis Format="{value}B" />
            </ChartPrimaryYAxis>

            
                <ChartSeries DataSource="@ExportData"
                             XName="X"
                             YName="Y"
                             Type="ChartSeriesType.StepArea"
                             StepPosition="StepPosition.Center"
                             Opacity="0.6"
                             Fill="#6200EE"
                             Width="2">

                    <!-- Series Border -->
                    <ChartSeriesBorder Width="2" Color="#6200EE" />

                    <!-- Marker -->
                    <ChartMarker Visible="true"
                                 Width="8"
                                 Height="8"
                                 Fill="#6200EE">

                        <ChartMarkerBorder Width="1" Color="#6200EE" />

                        <!-- ✅ Data Label -->
                        <ChartDataLabel Visible="true"
                                        Position="ChartLabelPosition.Outer"
                                        Fill="#FFFFFF">
                            <ChartDataLabelBorder Width="1" Color="#6200EE" />
                            <ChartDataLabelFont FontWeight="600" Color="#333333" />
                        </ChartDataLabel>

                    </ChartMarker>

                </ChartSeries>
            
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     INVERTED AXES
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Inverted Axes</b></h5>
    </Header>
    <Content>
        The Step Area Chart supports transposition, swapping the horizontal and vertical axes for different perspectives. Transpose the Chart axes by setting the <code>IsTransposed</code> property to <code>true</code> in the <code>SfChart</code> component.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@InvertedAxesCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Population by Age and Gender (Percent)" Width="100%" Height="400px" IsTransposed="true" Theme="@_currentTheme">
            
    <ChartArea Border="new ChartAreaBorder { Width = 0 }" />

    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />

    <ChartPrimaryYAxis Minimum="-6" Maximum="6" Interval="1">
        <ChartAxisMajorGridLines Width="1" />
    </ChartPrimaryYAxis>

    
        <!-- Male -->
        <ChartSeries DataSource="@PopulationData"
                     XName="Age"
                     YName="MalePercentValue"
                     Type="ChartSeriesType.StepArea"
                     Name="Male"
                     Opacity="0.6"
                     LegendShape="LegendShape.Rectangle"
        >
                     <ChartSeriesBorder Width="2" Color="#0765e0ff" />

        </ChartSeries>

        <!-- Female -->
        <ChartSeries DataSource="@PopulationData"
                     XName="Age"
                     YName="FemalePercentValue"
                     Type="ChartSeriesType.StepArea"
                     Name="Female"
                     Opacity="0.6"
                     LegendShape="LegendShape.Rectangle">
                     <ChartSeriesBorder Width="2" Color="#e007a6ff" />

        </ChartSeries>
    

    <ChartTooltipSettings Enable="true"
                          Header="Age: <b>${point.x}</b>"
                          Format="Gender Share: <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     NEGATIVE DATA
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Negative Data</b></h5>
    </Header>
    <Content>
        Gracefully handle and visualize negative values within the step area series. The area is filled downwards from the zero line for negative values mapped to the <code>YName</code> property. Significant thresholds and regions can be highlighted using the <code>ChartStripline</code> component within the axis, utilizing properties like <code>Start</code>, <code>End</code>, and <code>Text</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@NegativeDataCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Annual Gold Price (2009-2023) in USD" Width="100%" Height="400px" Theme="@_currentTheme">
            <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
          
            <!-- X Axis -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Double"
                               Interval="3" />

            <!-- Y Axis -->
            <ChartPrimaryYAxis Interval="20">
                <ChartAxisTitle Text="% Annual Exchange Rate" />
                <ChartAxisLineStyle Width="0" />

                <!-- Strip Lines -->
                <ChartStriplines>

                    <!-- Highest Growth Line -->
                    <ChartStripline Start="20"
                                    End="20.5"
                                    Visible="true"
                                    Color="#79747E"
                                    DashArray="10,10"
                                    ZIndex="@ZIndex.Over" />

                    <ChartStripline Start="21"
                                    End="21.5"
                                    Visible="true"
                                    Color="transparent"
                                    DashArray="4,4"
                                    Text="Highest Annual Growth"
                                    HorizontalAlignment="Anchor.End"
                                    ZIndex="@ZIndex.Over"
                                    Rotation="0">
                        <ChartStriplineTextStyle Color="@HighestTextColor" />
                    </ChartStripline>

                    <!-- Lowest Growth Line -->
                    <ChartStripline Start="-25"
                                    End="-24.5"
                                    Visible="true"
                                    Color="#79747E"
                                    DashArray="10,10"
                                    ZIndex="@ZIndex.Over" />

                    <ChartStripline Start="-28.5"
                                    End="-28"
                                    Visible="true"
                                    Color="transparent"
                                    DashArray="4,4"
                                    Text="Lowest Annual Growth"
                                    HorizontalAlignment="Anchor.End"
                                    ZIndex="@ZIndex.Over"
                                    Rotation="0">
                        <ChartStriplineTextStyle Color="@LowestTextColor" />
                    </ChartStripline>

                </ChartStriplines>
            </ChartPrimaryYAxis>

            <!-- Series -->
            
                <ChartSeries DataSource="NegativeData"
                             XName="X"
                             YName="USD"
                             Type="ChartSeriesType.StepArea"
                             Width="2"
                             Opacity="0.4"
                             Fill="#3CFFD2">
                     <ChartSeriesBorder Width="2" Color="@SeriesBorderColor" />
                </ChartSeries>
            

            <!-- Tooltip -->
            <ChartTooltipSettings Enable="true"
                                  Header="${point.x}"
                                  Format="Annual Growth : <b>${point.y}</b>" />

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────────────────────
     SERIES CUSTOMIZATION
     ───────────────────────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Series Customization</b></h5>
    </Header>
    <Content>
        Apply custom colors, opacity levels, and step positions to match your application's design guidelines. You can fine-tune the appearance using properties like <code>Fill</code>, <code>Opacity</code>, <code>Width</code>, and <code>StepPosition</code> in the <code>ChartSeries</code>, and customize borders using the <code>ChartSeriesBorder</code> component.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@CustomizationCode">
    <PreviewSection>
        <SfChart @key="@_currentTheme" Title="Monthly Active Users (Web vs Mobile)" Width="100%" Height="400px" Theme="@_currentTheme">
             <ChartArea>
        <ChartAreaBorder Width="0" />
    </ChartArea>

    <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.Category" />

    <ChartPrimaryYAxis>
        <ChartPrimaryYAxis Format="{value}k" />
    </ChartPrimaryYAxis>

    

        <ChartSeries DataSource="@WebUsers"
                     XName="X"
                     YName="Y"
                     Type="ChartSeriesType.StepArea"
                     Name="Web"
                     Opacity="0.6"
                     Fill="#05B3DA"
                     StepPosition="StepPosition.Center"
                     LegendShape="LegendShape.Rectangle">
            <ChartSeriesBorder Width="2"
                               Color="#05B3DA"/>

        </ChartSeries>

        <ChartSeries DataSource="@MobileUsers"
                     XName="X"
                     YName="Y"
                     Type="ChartSeriesType.StepArea"
                     Name="Mobile"
                     Opacity="0.6"
                     Fill="#82C100"
                     StepPosition="StepPosition.Center"
                     LegendShape="LegendShape.Rectangle">
            <ChartSeriesBorder Width="2"
                               Color="#82C100" />

        </ChartSeries>

    

    <ChartTooltipSettings Enable="true"
                          ShowNearestTooltip="true"
                          Header="<b>${series.name}</b>"
                          Format="${point.x}: <b>${point.y}</b>" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

