        new() { X = "Feb", AverageTemperatureF = (42 + 29) / 2.0, PrecipitationInch = 2.95 },
        new() { X = "Mar", AverageTemperatureF = (50 + 35) / 2.0, PrecipitationInch = 4.06 },
