        new() { X = "Jun", AverageTemperatureF = (79 + 64) / 2.0, PrecipitationInch = 3.50 },
        new() { X = "Jul", AverageTemperatureF = (85 + 70) / 2.0, PrecipitationInch = 4.53 },
        new() { X = "Aug", AverageTemperatureF = (83 + 69) / 2.0, PrecipitationInch = 4.13 },
        new() { X = "Sep", AverageTemperatureF = (76 + 61) / 2.0, PrecipitationInch = 3.98 },
