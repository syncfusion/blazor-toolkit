                    <ChartMarker>
                        <ChartDataLabel Visible=""true""
                                        Format=""{value}""
                                        Font=""@(new ChartDataLabelFont { Color = DataLabelTextColor })"" />
                    </ChartMarker>
                </ChartSeries>

            

            <!-- TOOLTIP -->
            <ChartTooltipSettings Enable=""true""
                                  ShowNearestTooltip=""false""
