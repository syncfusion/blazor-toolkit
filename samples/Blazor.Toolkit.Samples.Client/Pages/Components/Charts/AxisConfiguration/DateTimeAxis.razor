@page "/charts/datetime-axis"
@using Syncfusion.Blazor.Toolkit.Buttons
@using Syncfusion.Blazor.Toolkit.Charts

<PageTitle>Blazor Chart DateTime Axis Demo | Syncfusion Toolkit</PageTitle>

<!-- ─────────────────────────────────────────────
     DATETIME AXIS
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>DateTime Axis</b></h5>
    </Header>
    <Content>
        A DateTime axis is used to plot data points that occur at specific
        moments in time. It supports automatic interval calculation and
        formatted date labels for improved temporal readability.

        In the Syncfusion Blazor Toolkit, the DateTime axis is enabled by setting
        the <code>ValueType</code> property to <code>ValueType.DateTime</code>.
        You can further control formatting using <code>IntervalType</code> and
        <code>LabelFormat</code> to display values such as months, years, or
        custom date representations.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview IsFullWidth="true" CodeSection="@DateTimeAxisCode">
    <PreviewSection>
        <!-- CHART -->
        <SfChart @key="@_currentTheme" Title="USD to INR Performance" Theme="@_currentTheme">
            <ChartArea>
                <ChartAreaBorder Width="0"></ChartAreaBorder>
            </ChartArea>

            <!-- X AXIS -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               IntervalType="IntervalType.Months"
                               LabelFormat="yyyy MMM"
                               EdgeLabelPlacement="EdgeLabelPlacement.Shift">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <!-- Y AXIS -->
            <ChartPrimaryYAxis Minimum="79"
                               Maximum="85"
                               Interval="1.5"
                               LabelFormat="₹{value}">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryYAxis>

            <!-- SERIES -->
            
                <ChartSeries DataSource="@SynchronizedData"
                             XName="USD"
                             YName="INR"
                             Type="ChartSeriesType.Line"
                             Width="2"
                             Fill="#5433FF">
                </ChartSeries>
            

            <!-- TOOLTIP -->
            <ChartTooltipSettings Enable="true"
                                  Format="${point.x} : <b>${point.y}</b>"
                                  EnableHighlight="true" />
        </SfChart>

    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     RANGE (DATETIME AXIS)
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Range</b></h5>
    </Header>
    <Content>
        Range configuration allows you to explicitly control the visible start
        and end values of an axis. This is especially useful for DateTime axes
        when focusing on a specific time window within a larger dataset.

        In the Syncfusion Blazor Toolkit, the <code>Minimum</code> and
        <code>Maximum</code> properties of a DateTime axis define the visible
        range, while properties such as <code>IntervalType</code> and
        <code>LabelFormat</code> improve temporal readability.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview CodeSection="@DateTimeRangeCode" IsFullWidth="true">
    <PreviewSection>
        <!-- CHART -->
        <SfChart @key="@_currentTheme" Title="USD to EURO Performance" Theme="@_currentTheme">
            <ChartArea>
                <ChartAreaBorder Width="0"></ChartAreaBorder>
            </ChartArea>

            <!-- X AXIS (DATETIME RANGE) -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               IntervalType="IntervalType.Months"
                               Minimum="@(new DateTime(2023, 6, 18))"
                               Maximum="@(new DateTime(2023, 12, 18))"
                               LabelFormat="yyyy MMM"
                               EdgeLabelPlacement="EdgeLabelPlacement.Shift">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <!-- Y AXIS -->
            <ChartPrimaryYAxis Minimum="0.86"
                               Maximum="0.96"
                               Interval="0.025"
                               LabelFormat="€{value}">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryYAxis>

            <!-- SERIES -->
            
                <ChartSeries DataSource="@SynchronizedData"
                             XName="USD"
                             YName="EUR"
                             Type="ChartSeriesType.Line"
                             Width="2"
                             Fill="#006BFF">
                </ChartSeries>
            

            <!-- TOOLTIP -->
            <ChartTooltipSettings Enable="true"
                                  Format="${point.x} : <b>${point.y}</b>"
                                  EnableHighlight="true" />

        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     INTERVAL AND RANGE CUSTOMIZATION
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Interval and Range Customization</b></h5>
    </Header>
    <Content>
        Interval and range customization allows fine‑grained control over how
        DateTime values are segmented and padded on an axis.

        In the Syncfusion Blazor Toolkit, the axis interval behavior is controlled
        using the <code>IntervalType</code> property, while whitespace around the
        plotted range is managed using <code>RangePadding</code>.
        Since dropdown components are not available in the Blazor Toolkit,
        interactive selection is achieved using <code>ButtonGroup</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview CodeSection="@IntervalRangeCode" IsFullWidth="true">
    <PreviewSection>
        <!-- PROPERTY PANEL -->
        <div class="mb-4">

            <div class="mb-3">
                <label class="fw-bold d-block mb-2">Interval Type</label>

                <SfButtonGroup Mode="SelectionMode.Single">
                    <Button Selected="@IsIntervalSelected(IntervalType.Auto)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Auto))">
                        Auto
                    </Button>
                    <Button Selected="@IsIntervalSelected(IntervalType.Years)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Years))">
                        Years
                    </Button>
                    <Button Selected="@IsIntervalSelected(IntervalType.Months)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Months))">
                        Months
                    </Button>
                    <Button Selected="@IsIntervalSelected(IntervalType.Days)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Days))">
                        Days
                    </Button>
                    <Button Selected="@IsIntervalSelected(IntervalType.Hours)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Hours))">
                        Hours
                    </Button>
                    <Button Selected="@IsIntervalSelected(IntervalType.Minutes)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Minutes))">
                        Minutes
                    </Button>
                    <Button Selected="@IsIntervalSelected(IntervalType.Seconds)"
                                       SelectedChanged="@(v => SetInterval(v, IntervalType.Seconds))">
                        Seconds
                    </Button>
                </SfButtonGroup>
            </div>

            <div>
                <label class="fw-bold d-block mb-2">Range Padding</label>

                <SfButtonGroup Mode="SelectionMode.Single">
                    <Button Selected="@IsPaddingSelected(ChartRangePadding.None)"
                                       SelectedChanged="@(v => SetPadding(v, ChartRangePadding.None))">
                        None
                    </Button>
                    <Button Selected="@IsPaddingSelected(ChartRangePadding.Round)"
                                       SelectedChanged="@(v => SetPadding(v, ChartRangePadding.Round))">
                        Round
                    </Button>
                    <Button Selected="@IsPaddingSelected(ChartRangePadding.Additional)"
                                       SelectedChanged="@(v => SetPadding(v, ChartRangePadding.Additional))">
                        Additional
                    </Button>
                </SfButtonGroup>
            </div>
        </div>

        <!-- CHART -->
        <SfChart @key="@_currentTheme" Title="USD vs Yen Performance" Theme="@_currentTheme">
            <ChartArea>
                <ChartAreaBorder Width="0"></ChartAreaBorder>
            </ChartArea>

            <!-- X AXIS -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               IntervalType="@IntervalType"
                               RangePadding="@RangePadding"
                               EdgeLabelPlacement="EdgeLabelPlacement.Shift">
                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryXAxis>

            <!-- Y AXIS -->
            <ChartPrimaryYAxis Minimum="120"
                               Maximum="152"
                               LabelFormat="¥{value}">
                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
            </ChartPrimaryYAxis>

            <!-- SERIES -->
            
                <ChartSeries DataSource="@SynchronizedData"
                             XName="USD"
                             YName="JPY"
                             Type="ChartSeriesType.Line"
                             Width="2"
                             Fill="#8B5DFF">
                </ChartSeries>
            

            <!-- TOOLTIP -->
            <ChartTooltipSettings Enable="true"
                                  Format="${point.x} : <b>${point.y}</b>"
                                  EnableHighlight="true" />
        </SfChart>
    </PreviewSection>
</CodePreview>
</VirtualizeSection>

<!-- ─────────────────────────────────────────────
     LABEL FORMAT (DATETIME AXIS)
     ───────────────────────────────────────────── -->
<Description>
    <Header>
        <h5><b>Label Format</b></h5>
    </Header>
    <Content>
        Label formatting controls how DateTime values are rendered on the axis,
        allowing dates and times to be displayed in different patterns such as
        weekdays, months, or time values.

        In the Syncfusion Blazor Toolkit, DateTime label formats are applied using
        the <code>LabelFormat</code> property of the axis. Since dropdown controls
        are not available, format selection is handled using a
        <code>ButtonGroup</code>.
    </Content>
</Description>

<VirtualizeSection MinHeightPx="600px">
    <CodePreview CodeSection="@LabelFormatCode" IsFullWidth="true">
    <PreviewSection>
        <!-- PROPERTY PANEL -->
        <div class="mb-4">
            <label class="fw-bold d-block mb-2">Label Format</label>

            <SfButtonGroup Mode="SelectionMode.Single">
                <Button Selected="@IsFormatSelected("dddd")"
                                   SelectedChanged="@(v => SetFormat(v, "dddd"))">
                    dddd
                </Button>

                <Button Selected="@IsFormatSelected("yyyy/M/d")"
                                   SelectedChanged="@(v => SetFormat(v, "yyyy/M/d"))">
                    y/M/d
                </Button>

                <Button Selected="@IsFormatSelected("MMM")"
                                   SelectedChanged="@(v => SetFormat(v, "MMM"))">
                    MMM
                </Button>

                <Button Selected="@IsFormatSelected("h:mm")"
                                   SelectedChanged="@(v => SetFormat(v, "h:mm"))">
                    h:mm
                </Button>

                <Button Selected="@IsFormatSelected("h:mm:ss")"
                                   SelectedChanged="@(v => SetFormat(v, "h:mm:ss"))">
                    h:mm:ss
                </Button>

                <Button Selected="@IsFormatSelected("yyyy MMM")"
                                   SelectedChanged="@(v => SetFormat(v, "yyyy MMM"))">
                    y MMM
                </Button>
            </SfButtonGroup>
        </div>

        <!-- CHART -->
        <SfChart @key="@_currentTheme" Title="USD to SGD Performance" Theme="@_currentTheme">
            <ChartArea>
                <ChartAreaBorder Width="0"></ChartAreaBorder>
            </ChartArea>

            <!-- X AXIS -->
            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Toolkit.ValueType.DateTime"
                               Minimum="@(new DateTime(2023, 6, 18))"
                               Maximum="@(new DateTime(2023, 12, 18))"
                               LabelIntersectAction="LabelIntersectAction.Rotate45"
                               LabelFormat="@LabelFormat"
                               EdgeLabelPlacement="EdgeLabelPlacement.Shift">
                <ChartAxisMajorGridLines Width="0" />
                <ChartAxisMajorTickLines Width="0" />
                <ChartAxisMinorTickLines Width="0" />
            </ChartPrimaryXAxis>

            <!-- Y AXIS -->
            <ChartPrimaryYAxis Minimum="1.30"
                               Maximum="1.37"
                               Interval="0.0175"
                               LabelFormat="${value}">
                <ChartAxisLineStyle Width="0" />
                <ChartAxisMajorTickLines Width="0" />
            </ChartPrimaryYAxis>

            <!-- SERIES -->
            
                <ChartSeries DataSource="@SynchronizedData"
                             XName="USD"
                             YName="SGD"
                             Type="ChartSeriesType.Line"
                             Width="2"
                             Fill="#E82561">
                </ChartSeries>
            

            <!-- TOOLTIP -->
            <ChartTooltipSettings Enable="true"
                                  Format="${point.x} : <b>${point.y}</b>"
                                  EnableHighlight="true" />
        </SfChart>
    </PreviewSection>

</CodePreview>
</VirtualizeSection>

