@page "/buttons/button-group"

@using Syncfusion.Blazor.Toolkit.Buttons
@using Blazor.Toolkit.Samples.Client.Services
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Button Group | ASP.NET Core Blazor OSS Components</PageTitle>

<Description>
    <Header>
        <h4><b>Blazor ButtonGroup Component</b></h4>
    </Header>
    <Content>
        Add the ButtonGroup component to your application as shown in the below code example.
    </Content>
</Description>

<CodePreview CodeSection="@BasicsCode">
    <PreviewSection>
        <SfButtonGroup>
            <Button>One</Button>
            <Button>Two</Button>
            <Button>Three</Button>
        </SfButtonGroup>
    </PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5><b>Vertical Orientation</b></h5>
    </Header>
    <Content>
        Set the ButtonGroup orientation to vertical by using the property <code>IsVertical="true"</code>. This stacks the buttons vertically and can be combined with variants such as <code>e-flat</code> and <code>e-outline</code>.
    </Content>
</Description>

<CodePreview CodeSection="@VerticalCode">
    <PreviewSection>
         <div class="e-section">
        <!-- Default (filled/standard) vertical group -->
        <SfButtonGroup IsVertical="true">
            <Button>ONE</Button>
            <Button>TWO</Button>
            <Button>THREE</Button>
        </SfButtonGroup>

        <!-- Vertical + flat -->
            <SfButtonGroup IsVertical="true">
            <Button CssClass="e-flat">ONE</Button>
            <Button CssClass="e-flat">TWO</Button>
            <Button CssClass="e-flat">THREE</Button>
        </SfButtonGroup>

        <!-- Vertical + outlined -->
            <SfButtonGroup IsVertical="true">
            <Button CssClass="e-outline">ONE</Button>
            <Button CssClass="e-outline">TWO</Button>
            <Button CssClass="e-outline">THREE</Button>
        </SfButtonGroup>
        </div>
    </PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5><b>Selection Type</b></h5>
    </Header>
    <Content>
        ButtonGroup can behave like a segmented control with single or multiple selection using the built-in selection model.
    </Content>
</Description>

<CodePreview CodeSection="@SelectionCode">
    <PreviewSection>
        <div class="e-section">
            <label class="e-label">Single selection</label>

            <!-- Single selection via Selected + SelectedChanged -->
            <SfButtonGroup Mode="SelectionMode.Single">
                <Button Selected="@isLeft"
                                   SelectedChanged='@(v => OnAlignmentChanged(v, "Left"))'
                                   CssClass='@GetActive("Left")'
                                   aria-pressed="@isLeft">
                    Left
                </Button>

                <Button Selected="@isCenter"
                                   SelectedChanged='@(v => OnAlignmentChanged(v, "Center"))'
                                   CssClass='@GetActive("Center")'
                                   aria-pressed="@isCenter">
                    Center
                </Button>

                <Button Selected="@isRight"
                                   SelectedChanged='@(v => OnAlignmentChanged(v, "Right"))'
                                   CssClass='@GetActive("Right")'
                                   aria-pressed="@isRight">
                    Right
                </Button>
            </SfButtonGroup>

            <div class="e-note">Selected: @alignment</div>
        </div>

        <div class="e-section" style="margin-top:12px">
            <label class="e-label">Multiple selection</label>

            <!-- Multiple selection via Selected + SelectedChanged -->
            <SfButtonGroup Mode="SelectionMode.Multiple">
                <Button Selected='@tags.Contains("News")'
                                   SelectedChanged='@(v => OnTagChanged("News", v))'
                                   CssClass='@GetTagClass("News")'
                                   aria-pressed='@tags.Contains("News")'>
                    News
                </Button>

                <Button Selected='@tags.Contains("Blog")'
                                   SelectedChanged='@(v => OnTagChanged("Blog", v))'
                                   CssClass='@GetTagClass("Blog")'
                                   aria-pressed='@tags.Contains("Blog")'>
                    Blog
                </Button>

                <Button Selected='@tags.Contains("Updates")'
                                   SelectedChanged='@(v => OnTagChanged("Updates", v))'
                                   CssClass='@GetTagClass("Updates")'
                                   aria-pressed='@tags.Contains("Updates")'>
                    Updates
                </Button>
            </SfButtonGroup>

            <div class="e-note">Tags: @string.Join(", ", tags)</div>
        </div>
    </PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5><b>Rounded Buttons</b></h5>
    </Header>
    <Content>
        Apply the <code>e-round-corner</code> style to get rounded corners on grouped buttons.
    </Content>
</Description>

<CodePreview CodeSection="@RoundedCode">
    <PreviewSection>
        <SfButtonGroup CssClass="e-round-corner">
            <Button>Day</Button>
            <Button>Week</Button>
            <Button>Month</Button>
        </SfButtonGroup>
    </PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5><b>Color Variants</b></h5>
    </Header>
    <Content>
        Use semantic styles to represent intent—Primary, Success, Warning, Info, and Error—within a group.
    </Content>
</Description>

<CodePreview CodeSection="@ColorCode">
    <PreviewSection>
        <SfButtonGroup>
            <Button CssClass="e-primary">Primary</Button>
            <Button CssClass="e-success">Success</Button>
            <Button CssClass="e-warning">Warning</Button>
            <Button CssClass="e-info">Info</Button>
            <Button CssClass="e-danger">Error</Button>
        </SfButtonGroup>
    </PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5><b><b>Icons</b></b></h5>
    </Header>
    <Content>
        Use icon-only or icon-with-text buttons inside a group. Provide an <code>aria-label</code> for icon-only groups for accessibility.
    </Content>
</Description>

<CodePreview CodeSection="@IconsCode">
    <PreviewSection>
        <div id="icons" class="e-section">
            <label class="e-label">Icon-only</label>
            <SfButtonGroup>
                <Button aria-label="Bold"><span class="sb-icons e-bold"></span></Button>
                <Button aria-label="Italic"><span class="sb-icons e-italic"></span></Button>
                <Button aria-label="Underline"><span class="sb-icons e-underline"></span></Button>
            </SfButtonGroup>
        </div>

        <div id="icons-text" class="e-section" style="margin-top:12px">
            <label class="e-label">Icon with text</label>
            <SfButtonGroup>
                <Button><span class="sb-icons e-align-left"></span>&nbsp;Left</Button>
                <Button><span class="sb-icons e-align-center"></span>&nbsp;Center</Button>
                <Button><span class="sb-icons e-align-right"></span>&nbsp;Right</Button>
            </SfButtonGroup>
        </div>
    </PreviewSection>
</CodePreview>

<Description>
    <Header>
        <h5><b>States</b></h5>
    </Header>
    <Content>
        Showcase disabled and active states inside a ButtonGroup.
    </Content>
</Description>

<CodePreview CodeSection="@StatesCode">
    <PreviewSection>
        <div class="e-section">
            <label class="e-label">Disabled group</label>
            <SfButtonGroup>
                <Button Disabled="true">One</Button>
                <Button Disabled="true">Two</Button>
                <Button Disabled="true">Three</Button>
            </SfButtonGroup>
        </div>

        <div class="e-section" style="margin-top:12px">
            <label class="e-label">Active (Selected) state</label>

            <SfButtonGroup Mode="SelectionMode.Multiple">
                <Button Selected='@textStyles.Contains("Bold")'
                                   SelectedChanged='@(v => ToggleStyle("Bold", v))'
                                   CssClass='@GetActive("Bold")'
                                   aria-pressed='@textStyles.Contains("Bold")'>
                    Bold
                </Button>

                <Button Selected='@textStyles.Contains("Italic")'
                                   SelectedChanged='@(v => ToggleStyle("Italic", v))'
                                   CssClass='@GetActive("Italic")'
                                   aria-pressed='@textStyles.Contains("Italic")'>
                    Italic
                </Button>

                <Button Selected='@textStyles.Contains("Underline")'
                                   SelectedChanged='@(v => ToggleStyle("Underline", v))'
                                   CssClass='@GetActive("Underline")'
                                   aria-pressed='@textStyles.Contains("Underline")'>
                    Underline
                </Button>
            </SfButtonGroup>

            <div class="e-note">Active: @string.Join(", ", textStyles)</div>
        </div>
    </PreviewSection>
</CodePreview>

