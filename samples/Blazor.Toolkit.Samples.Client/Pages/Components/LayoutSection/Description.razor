<div class="description-wrapper">
    <div class="header-class">
        @Header
    </div>
    <div class="content-class">
        <p>
            @Content
        </p>
    </div>
</div>


@code {
    [Parameter]
    public RenderFragment Header { get; set; } = default!;

    [Parameter]
    public RenderFragment Content { get; set; } = default!;
}

<style>
    .description-wrapper {
        padding: 10px 10px 0 10px;
        background-color: transparent;
        color: var(--text-color);
        transition: color .18s ease, background-color .18s ease;
    }

    .header-class h3,
    .header-class h4,
    .header-class h5 {
        letter-spacing: 0;
        font-weight: 500;
        line-height: 26px;
        color: var(--text-color);
    }

    .header-class h3 {
        font-size: 1.25rem;
    }

    .header-class h4 {
        font-size: 1.125rem;
    }

    .header-class h5 {
        font-size: 1rem;
    }

    .content-class p {
        letter-spacing: .24px;
        margin-top: .9rem;
        margin-bottom: 1rem;
        font-size: 1rem;
        line-height: 24px;
        color: var(--text-color);
    }

    .header-class,
    .content-class {
        font-family: Segoe UI,Segoe UI Variable Text,-apple-system,BlinkMacSystemFont,Helvetica Neue,Helvetica,Arial,sans-serif;
        text-wrap-mode: nowrap;
    }

        .content-class p,
        .header-class h5 {
            white-space: normal;
            word-break: break-word;
        }

    .page-rtl .description-wrapper .content-class {
        direction: ltr;
    }
</style>