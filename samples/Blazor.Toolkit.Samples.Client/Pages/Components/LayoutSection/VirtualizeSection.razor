@using Microsoft.JSInterop
@inject IJSRuntime JS

<div @ref="_sectionRef"></div>
@if (_isVisible)
{
    @ChildContent
}
else
{
    <div class="virtualize-spinner-container" style="min-height:@MinHeightPx;">
        <div class="virtualize-spinner" aria-label="Loading">
            <div class="spinner-circle"></div>
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;
    [Parameter] public string MinHeightPx { get; set; } = "400px";

    private bool _isVisible;
    private ElementReference _sectionRef;
    private DotNetObjectReference<VirtualizeSection>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("virtualizeSection.observe", _sectionRef, _dotNetRef);
        }
    }

    [JSInvokable]
    public void OnVisible()
    {
        _isVisible = true;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef != null)
        {
            await JS.InvokeVoidAsync("virtualizeSection.unobserve", _sectionRef);
            _dotNetRef.Dispose();
        }
    }
}

<style>
    .virtualize-spinner-container {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }
    .virtualize-spinner {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 48px;
        width: 48px;
    }
    .spinner-circle {
        width: 36px;
        height: 36px;
        border: 4px solid var(--accent, #6366f1);
        border-top: 4px solid var(--spinner-bg, #e5e7eb);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        box-sizing: border-box;
    }
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* Fluent theme-aware colors */
    :root {
        --accent: #6366f1; /* Fluent primary accent */
        --spinner-bg: #e5e7eb;
    }
    .dark {
        --accent: #a5b4fc;
        --spinner-bg: #23272f;
    }
</style>