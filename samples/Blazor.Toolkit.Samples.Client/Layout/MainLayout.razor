<Syncfusion.Blazor.Toolkit.Popups.SfDialogProvider/>

@code {
    // Injected services
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;

    // Theme support
    private bool IsDarkTheme = false;
    private bool IsRtl = false;

    // Search dialog state (existing)
    private SfDialog DialogObj = default!;
    private bool isSearchVisible = false;
    private bool isPredefinedList = true;
    private bool PreferencesPopupOpen = false;

    // Responsive state: overlay left nav open and current screen size
    private bool OverlayLeftIsOpen = false; // controls the mobile overlay sidebar

    // Define breakpoints consistent with many responsive patterns: mobile <=640, tablet <=1024
    private enum ScreenSize { Mobile, Tablet, Desktop }
    private ScreenSize CurrentScreen { get; set; } = ScreenSize.Desktop;

    // Distinguish mobile vs tablet for layout differences
    private bool IsMobile => CurrentScreen == ScreenSize.Mobile;
    private bool IsTablet => CurrentScreen == ScreenSize.Tablet;

    // Compute the current Chart theme based on dark/light mode
    private Theme CurrentChartTheme => IsDarkTheme ? Theme.FluentDark : Theme.Fluent;

    // Keep a DotNetObjectReference for JS callbacks and ensure we dispose it
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    // Search page lists
    public List<SearchItem> PredefinedPages { get; set; } = new()
    {
        new("Browser Support", "browser-support"),
        new("Blazor Web App", "blazor-web-app"),
        new("Blazor WebAssembly App", "blazor-webassembly-app"),
        new("Button", "buttons/button"),
        new("Calendar", "calendars/calendar"),
        new("Charts", "charts/overview")
    };

    public List<SearchItem> FilteredPages { get; set; } = new();

    // Lifecycle: register resize callback once after first render and initialize theme
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Create a DotNetObjectReference so JS can call back into this instance
            _dotNetRef = DotNetObjectReference.Create(this);

            // Ensure mainlayout.js is loaded and the responsive helper is available
            await JS.InvokeVoidAsync("mainLayout.ensureResponsive");

            // Register this instance with the helper
            await JS.InvokeVoidAsync("responsiveBlazor.register", _dotNetRef);

            // Initialize device detection immediately
            try
            {
                bool isDevice = await JS.InvokeAsync<bool>("isDevice");
                UpdateDeviceMode(isDevice);
            }
            catch { }

            try
            {
                var currentTheme = await JS.InvokeAsync<string>("mainLayout.initTheme");
                IsDarkTheme = currentTheme == "dark";
                await InvokeAsync(StateHasChanged);
            }
            catch { }

            try
            {
                var currentDir = await JS.InvokeAsync<string>("mainLayout.initDir");
                // Ensure the Syncfusion service is configured to match persisted direction on initial load
                IsRtl = string.Equals(currentDir, "rtl", StringComparison.OrdinalIgnoreCase);
                SyncfusionService.EnableRtl(IsRtl);
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }
    }

    // JSInvokable: receives device mode and tablet status updates from JavaScript
    [JSInvokable]
    public void UpdateDeviceMode(bool isDevice)
    {
        SampleService.IsDevice = isDevice;

        // Update screen size based on device detection
        var newSize = isDevice ? ScreenSize.Mobile : ScreenSize.Desktop;
    
        if (newSize != CurrentScreen)
        {
            CurrentScreen = newSize;
            if (CurrentScreen == ScreenSize.Desktop)
            {
                OverlayLeftIsOpen = false;
            }
            InvokeAsync(StateHasChanged);
        }
    }

    // JSInvokable: receives width and updates internal screen size state.
    [JSInvokable]
    public Task NotifyResize(int width)
    {
        bool isDevice = width <= 640;
        SampleService.IsDevice = isDevice;
        // Determine new logical screen size
        var newSize = width <= 640 ? ScreenSize.Mobile : (width <= 1024 ? ScreenSize.Tablet : ScreenSize.Desktop);
        // Only trigger a render when the logical size changes to minimize re-renders
        if (newSize != CurrentScreen)
        {
            CurrentScreen = newSize;
            // When moving to desktop, ensure overlays are closed
            if (CurrentScreen == ScreenSize.Desktop)
            {
                OverlayLeftIsOpen = false;
            }
            // Request a render on the UI thread
            InvokeAsync(StateHasChanged);
        }
        return Task.CompletedTask;
    }

    // Toggle overlay left nav (called from hamburger button)
    private void ToggleLeftOverlay()
    {
        OverlayLeftIsOpen = !OverlayLeftIsOpen;
    }

    // Close handler for SfSidebar
    private void OnLeftSidebarClose()
    {
        OverlayLeftIsOpen = false;
    }

    // Handle keydown events inside the overlay sidebar (Escape to close)
    private void OnSidebarKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            OverlayLeftIsOpen = false;
        }
    }

    // Keyboard support for hamburger: Enter/Space toggle, Escape closes
    private void OnHamburgerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            ToggleLeftOverlay();
        }
        else if (e.Key == "Escape")
        {
            OverlayLeftIsOpen = false;
        }
    }

    // Existing search helpers (unchanged semantics)
    private void ToggleSearchPopup()
    {
        isSearchVisible = true;
    }

    private void OnOverlayClick()
    {
        isSearchVisible = false;
        isPredefinedList = true;
    }

    private void OnInput(InputEventArgs args)
    {
        isPredefinedList = args.Value is null ? true : false;
        if (!string.IsNullOrEmpty(args.Value))
        {
            FilteredPages = SearchIndex.Items.Where(item => item.Title.Contains(args.Value, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        else
        {
            FilteredPages = new();
        }
    }

    private async Task Navigate(string url)
    {
        Nav.NavigateTo(url);
        await Task.Delay(200);
        isSearchVisible = false;
        isPredefinedList = true;
    }

    private void TogglePreferencesPopup()
    {
        PreferencesPopupOpen = !PreferencesPopupOpen;
    }

    private void ClosePreferencesPopup()
    {
        PreferencesPopupOpen = false;
    }

    private async Task SetRTL(bool rtl)
    {
        IsRtl = rtl;
        PreferencesPopupOpen = false;
        // Update Syncfusion RTL mode immediately so components will be configured
        SyncfusionService.EnableRtl(IsRtl);
        var dir = IsRtl ? "rtl" : "ltr";
        try
        {
            await JS.InvokeVoidAsync("mainLayout.setDir", dir);
        }
        catch { }
        await InvokeAsync(StateHasChanged);
        try
        {
            Nav.NavigateTo(Urihelper.BaseUri, forceLoad: true);
        }
        catch { }
    }

    // Toggle dark/light theme: update localStorage, document class and Syncfusion theme link
    private async Task ToggleTheme()
    {
        IsDarkTheme = !IsDarkTheme;
        var theme = IsDarkTheme ? "dark" : "light";
        try
        {
            await JS.InvokeVoidAsync("mainLayout.setTheme", theme);
        }
        catch { }
        await InvokeAsync(StateHasChanged);
    }

    private void OnDialogClose(BeforeCloseEventArgs args)
    {
        args.PreventFocus = true;
    }

    // Ensure we clean up the JS listeners and DotNetObjectReference
    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("responsiveBlazor.dispose");
        }
        catch
        {
            // ignore errors during dispose
        }

        _dotNetRef?.Dispose();
    }
}

<style>
    :root {
        /* Core Colors */
        --bg-color: #ffffff;
        --text-color: #1f2937;
        --text-color-secondary: #6b7280;
        --top-bg: #ffffff;
        --top-text: #1f2937;
        --sidebar-bg: #ffffff;
        --panel-bg: #f9fafb;
        --scroll-bg: #ffffff;
        --accent: #6750a4;
        --accent-foreground: #ffffff;
        --li-hover: #f1f5f9;
        --topsidebar-color: rgba(245,245,245,1);
        
        /* Typography Scale */
        --font-family: "Inter", "Segoe UI", Roboto, system-ui, -apple-system, sans-serif;
        --font-right-sidebar: 13px;
        --font-left-sidebar: 14px;
        --font-page-title: 26px;
        --font-section-header: 18px;
        --font-body: 15px;
        --font-line-height: 1.6;
    }
    .dark {
        --bg-color: #0b1020;
        --text-color: #e5e7eb;
        --text-color-secondary: #9ca3af;
        --top-bg: #071028;
        --top-text: #e5e7eb;
        --sidebar-bg: #071028;
        --panel-bg: #0f172a;
        --scroll-bg: #071028;
        --accent: #a78bfa;
        --accent-foreground: #001223;
        --li-hover: #1e293b;
        --topsidebar-color: rgba(21,21,33,1);
    }

    /* RTL helper: document root will receive `dir=rtl` and `.rtl` class */
    .rtl {
        direction: rtl;
    }

    /* Page-level colors */
    .page {
        background-color: var(--bg-color);
        color: var(--text-color);
        min-height: 100vh;
        transition: background-color .2s ease, color .2s ease;
    }

    /* Top layout */
    .top-layout-custom {
        background-color: var(--top-bg);
        color: var(--top-text);
        transition: background-color .2s ease, color .2s ease;
    }
    .top-layout-custom .brand-name,
    .top-layout-custom .github a,
    .e-sidebar .github a,
    .e-top-sidebar .github a {
        color: var(--top-text);
        font-weight: bold;
        margin-top: 7px;
    }
    /* Ensure brand-icon SVG follows the current color (light/dark) */
    .brand-icon svg,
    .brand-icon svg rect,
    .brand-icon svg path,
    .brand-icon svg circle,
    .brand-icon svg polyline,
    .brand-icon svg line {
        fill: currentColor;
    }

    /* Sidebars */
    .sidebar,
    .mobile-sidebar {
        background-color: var(--sidebar-bg);
        color: var(--text-color);
        transition: background-color .2s ease, color .2s ease;
    }
    .mobile-sidebar-backdrop {
        position: fixed;
        inset: 0;
        z-index: 998;
        background: rgba(0, 0, 0, 0.28);
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s ease;
    }
    .dark .mobile-sidebar-backdrop {
        background: rgba(0, 0, 0, 0.45);
    }
    .mobile-sidebar-backdrop.open {
        opacity: 1;
        pointer-events: auto;
    }
    .mobile-sidebar {
        position: fixed;
        top: 0;
        bottom: 0;
        left: 0;
        width: 260px;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
        overflow-y: auto;
        border-inline-end: 1px solid rgba(0, 0, 0, 0.08);
    }
    .mobile-sidebar.open {
        transform: translateX(0);
    }
    .mobile-sidebar.rtl {
        left: auto;
        right: 0;
        transform: translateX(100%);
        border-inline-end: 0;
        border-inline-start: 1px solid rgba(0, 0, 0, 0.08);
    }
    .mobile-sidebar.rtl.open {
        transform: translateX(0);
    }

    /* Navigation links */
    .sidebar .nav-link,
    .sidebar .menu-summary {
        color: var(--text-color);
    }

    .content-row {
        display: flex;
        min-height: calc(100vh - 64px);
    }

    .sidebar {
        min-width: 280px;
