            </div>
            <SfButton IconCss="e-toolkit-icons e-close" CssClass="close-btn" aria-label="Close navigation" @onclick="OnLeftSidebarClose"></SfButton>
        </div>
        <div class="mobile-nav-wrapper" tabindex="0" @onkeydown="@OnSidebarKeyDown">
            <NavMenu />
        </div>
