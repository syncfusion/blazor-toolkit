@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Blazor.Toolkit.Samples.Client.Services
@inject SampleService SampleService

@using Microsoft.AspNetCore.Components.Web
@using Syncfusion.Blazor.Toolkit.Buttons
@using Syncfusion.Blazor.Toolkit.Popups
@using Syncfusion.Blazor.Toolkit.Inputs

@inject Syncfusion.Blazor.Toolkit.SyncfusionBlazorToolkitService SyncfusionService
@inject NavigationManager Urihelper

<div class="page">
    <header class="top-layout-custom">
        @if (IsMobile)
        {
            <div class="top-layout-title">
                <a href="https://www.syncfusion.com" target="_blank" rel="noreferrer noopener" class="brand-link" aria-label="Syncfusion home">
                    <div class="brand-icon">
                        <div class="syncfusion-logo"></div>
                    </div>
                </a>
                <a href="https://www.syncfusion.com/blazor-toolkit" target="_blank" rel="noreferrer noopener" class="brand-link" aria-label="Blazor Toolkit product page">
                    <div class="brand-name">Blazor Toolkit</div>
                </a>
            </div>
        }
        <div class="top-layout-inner">
            @{
                string topClass = IsTablet ? "top-left tablet" : "top-left";
            }
            <div class="@topClass">
                @* Top-left of the top-right area: render a hamburger button on tablet/mobile to open the nav overlay. *@
                @if (IsMobile || IsTablet)
                {
                    <SfButton CssClass="e-outline icon-button hamburger-button" IconCss="sb-icons e-menu" aria-label="Open menu" aria-controls="leftSidebar" aria-expanded="@OverlayLeftIsOpen.ToString().ToLower()" OnClick="@ToggleLeftOverlay" @onkeydown="@OnHamburgerKeyDown">
                    </SfButton>
                }
                <div class="brand-section">
                    @if (!IsMobile)
                    {
                        <a href="https://www.syncfusion.com" target="_blank" rel="noreferrer noopener" class="brand-link" aria-label="Syncfusion home">
                            <div class="brand-icon">
                                <div class="syncfusion-logo"></div>
                            </div>
                        </a>
                        <a href="https://www.syncfusion.com/blazor-toolkit" target="_blank" rel="noreferrer noopener" class="brand-link" aria-label="Blazor Toolkit product page">
                            <div class="brand-name">Blazor Toolkit</div>
                        </a>
                    }
                </div>
            </div>
            <div class="top-right">
                <div class="action-buttons">
                    <SfButton CssClass="e-outline search icon-button theme-toggle" IconCss="sb-icons e-search" aria-label="Search Components" OnClick="@ToggleSearchPopup"></SfButton>
                </div>
                
                <SfDialog @ref="@DialogObj" Width="750px" IsModal="true" @bind-Visible="@isSearchVisible" CssClass="search-popup" OnOverlayModalClick="@OnOverlayClick" OnClose="OnDialogClose">
                    <DialogTemplates>
                        <Content>
                            <SfTextBox Width="100%" Placeholder="Search" ShowClearButton="true" OnInput="@OnInput"></SfTextBox>
                            <hr/>
                            <div>
                                <h6><b>Search docs</b></h6>
                                <div class="search-list-wrapper">
                                    @if (isPredefinedList)
                                    {
                                        @foreach (var item in PredefinedPages)
                                        {
                                            <div class="result-item" @onclick="() => Navigate(item.Url)">
                                                <span class="sb-icons e-file-format"></span>@item.Title
                                            </div>
                                        }
                                    } 
                                    else
                                    {
                                        @foreach (var item in FilteredPages)
                                        {
                                            <div class="result-item" @onclick="() => Navigate(item.Url)">
                                                <span class="sb-icons e-file-format"></span>@item.Title
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </Content>
                    </DialogTemplates>
                    <DialogPositionData X="center" Y="top"></DialogPositionData>
                </SfDialog>

                <div class="action-buttons preferences-wrapper">
                    <button type="button" class="icon-button theme-toggle preferences-button" aria-label="Preferences" aria-haspopup="dialog" aria-expanded="@PreferencesPopupOpen" aria-controls="preferences-popup" @onclick="TogglePreferencesPopup">
                        <span class="sb-icons e-settings" aria-hidden="true"></span>
                    </button>

                    @if (PreferencesPopupOpen)
                    {
                        <div class="preferences-popup-backdrop" @onclick="ClosePreferencesPopup"></div>
                        <div id="preferences-popup" class="preferences-popup" role="dialog" aria-label="Preferences" @onclick:stopPropagation="true">
                            <div class="preferences-container">
                                <div>
                                    <div class="preferences-header">Preferences</div>
                                    <hr />
                                    <div>
                                        <div class="preferences-label">Mode Selection</div>
                                        <div class="btn-group mode-toggle-group">
                                            <SfButtonGroup Mode="SelectionMode.Single">
                                                <Button IconCss="sb-icons e-align-left" Selected="@(!IsRtl)" @onclick="@(() => SetRTL(false))">LTR</Button>
                                                <Button IconCss="sb-icons e-align-right" Selected="@(IsRtl)" @onclick="@(() => SetRTL(true))">RTL</Button>
                                            </SfButtonGroup>
                                        </div>
                                    </div>
                                </div>
                                <div class="render-mode-section">
                                    <ModeSwitcher isRenderModeSwitcher="true"/>
                                </div>
                                <div class="render-mode-section">
                                    <ModeSwitcher isRenderModeSwitcher="false" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!IsMobile && !IsTablet)
                {
                    <div class="action-buttons github">
                        <NavLink class="icon-button theme-toggle source-icon-button" href="https://github.com/syncfusion/blazor-toolkit" target="_blank">
                            <svg width="23" height="23" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1C5.923 1 1 5.923 1 12c0 4.867 3.149 8.979 7.521 10.436.55.096.756-.233.756-.522 0-.262-.013-1.128-.013-2.049-2.764.509-3.479-.674-3.699-1.292-.124-.317-.66-1.293-1.127-1.554-.385-.207-.936-.715-.014-.729.866-.014 1.485.797 1.691 1.128.99 1.663 2.571 1.196 3.204.907.096-.715.385-1.196.701-1.471-2.448-.275-5.005-1.224-5.005-5.432 0-1.196.426-2.186 1.128-2.956-.111-.275-.496-1.402.11-2.915 0 0 .921-.288 3.024 1.128a10.193 10.193 0 0 1 2.75-.371c.936 0 1.871.123 2.75.371 2.104-1.43 3.025-1.128 3.025-1.128.605 1.513.221 2.64.111 2.915.701.77 1.127 1.747 1.127 2.956 0 4.222-2.571 5.157-5.019 5.432.399.344.743 1.004.743 2.035 0 1.471-.014 2.654-.014 3.025 0 .289.206.632.756.522C19.851 20.979 23 16.854 23 12c0-6.077-4.922-11-11-11Z"></path></svg>
                        </NavLink>
                    </div>
                    <div class="action-buttons">
                        <SfButton CssClass="e-outline" class="icon-button theme-toggle" aria-label="Toggle theme" OnClick="@ToggleTheme">
                            @if (IsDarkTheme)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="presentation"><circle cx="12" cy="12" r="4"></circle><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="presentation"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                            }
                        </SfButton>
                    </div>
                }
            </div>
        </div>
    </header>
    <div class="content-row">
        <div class="loader-class">
            <div class="overlay"></div>
            <div class="brand-loader">
                <div class="syncfusion-logo-large" aria-hidden="true"></div>
            </div>
        </div>
        @if (!IsMobile && !IsTablet)
        {
            <aside class="sidebar">
                <NavMenu />
            </aside>
        }

        <main class="main-area">
            <article class="page-content">
                <CascadingValue Value="@SampleService.IsDevice">
                    <CascadingValue Value="CurrentChartTheme">
                        @Body
                    </CascadingValue>
                </CascadingValue>
            </article>
        </main>

        @* Right panel is visible only on desktop. On tablet/mobile it's hidden for better space usage. *@
        @if (!IsMobile && !IsTablet)
        {
            <aside class="right-panel">
                <RightToc />
            </aside>
        }
    </div>
</div>

@if (IsMobile || IsTablet)
{
    <div class="mobile-sidebar-backdrop @(OverlayLeftIsOpen ? "open" : string.Empty)" @onclick="OnLeftSidebarClose"></div>
    <aside id="leftSidebar" class="mobile-sidebar @(OverlayLeftIsOpen ? "open" : string.Empty) @(IsRtl ? "rtl" : string.Empty)" aria-hidden="@(!OverlayLeftIsOpen).ToString().ToLower()">
        <div class="e-top-sidebar">
            <div style="display: flex;">
                <div class="action-buttons github">
                    <NavLink class="icon-button theme-toggle source-icon-button" href="https://gitea.syncfusion.com/essential-studio/blazor-toolkit" target="_blank">
                        <svg width="23" height="23" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1C5.923 1 1 5.923 1 12c0 4.867 3.149 8.979 7.521 10.436.55.096.756-.233.756-.522 0-.262-.013-1.128-.013-2.049-2.764.509-3.479-.674-3.699-1.292-.124-.317-.66-1.293-1.127-1.554-.385-.207-.936-.715-.014-.729.866-.014 1.485.797 1.691 1.128.99 1.663 2.571 1.196 3.204.907.096-.715.385-1.196.701-1.471-2.448-.275-5.005-1.224-5.005-5.432 0-1.196.426-2.186 1.128-2.956-.111-.275-.496-1.402.11-2.915 0 0 .921-.288 3.024 1.128a10.193 10.193 0 0 1 2.75-.371c.936 0 1.871.123 2.75.371 2.104-1.43 3.025-1.128 3.025-1.128.605 1.513.221 2.64.111 2.915.701.77 1.127 1.747 1.127 2.956 0 4.222-2.571 5.157-5.019 5.432.399.344.743 1.004.743 2.035 0 1.471-.014 2.654-.014 3.025 0 .289.206.632.756.522C19.851 20.979 23 16.854 23 12c0-6.077-4.922-11-11-11Z"></path></svg>
                    </NavLink>
                </div>
                <div class="action-buttons">
                    <SfButton CssClass="e-outline" class="icon-button theme-toggle" aria-label="Toggle theme" OnClick="@ToggleTheme">
                        @if (IsDarkTheme)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="presentation"><circle cx="12" cy="12" r="4"></circle><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="presentation"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                        }
                    </SfButton>
