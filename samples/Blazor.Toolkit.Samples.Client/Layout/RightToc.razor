@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="right-toc">
    <div class="toc-inner">
        <h6 class="toc-heading"><b>On this page</b></h6>
        @if (headings is null)
        {
            <div class="toc-loading">Loading...</div>
        }
        else if (!headings.Any())
        {
            <div class="toc-empty">No headings</div>
        }
        else
        {
            <ul class="toc-list">
                @foreach (var h in headings)
                {
                    var isVisible = !string.IsNullOrEmpty(activeHeadingId) && h.Id == activeHeadingId;
                    <li class="toc-item level-@h.Level @(isVisible ? "visible" : "")"><a class="toc-link" href="#@h.Id" @onclick="@(async (e) => await ScrollTo(h.Id))" @onclick:preventDefault="true">@h.Text</a></li>
                }
            </ul>
        }
    </div>
</div>

@code {
    private List<HeadingItem>? headings;
    private string? activeHeadingId;
    private DotNetObjectReference<RightToc>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await UpdateHeadingsAsync(false);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await UpdateHeadingsAsync(true);
        }
    }

    private async Task UpdateHeadingsAsync(bool firstRender)
    {
        try
        {   
            var result = await JS.InvokeAsync<HeadingItem[]?>("toc.getHeadings", ".page-content");
            headings = result?.ToList() ?? new List<HeadingItem>();
            // Re-register observer for the new set of headings so visible-heading detection works
            try
            {
                // ensure we have a DotNetObjectReference
                if (_dotNetRef == null) _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("toc.disconnectObserver");
                await JS.InvokeVoidAsync("toc.observeVisibleHeading", ".page-content", _dotNetRef);
                
                // update currently visible heading
                var vid = await JS.InvokeAsync<string?>("toc.getVisibleHeading", ".page-content");
                if (!string.IsNullOrEmpty(vid)) activeHeadingId = vid;
            }
            catch { }

            if (firstRender) StateHasChanged();
            if (Nav.Uri.Contains("#"))
            {
                string id = Nav.Uri.Split('#').Last();
                await ScrollTo(id);
            }
        }
        catch
        {
            headings = new List<HeadingItem>();
        }
    }

    private async Task ScrollTo(string id)
    {
        try
        {
            await JS.InvokeVoidAsync("toc.scrollToId", id);
        }
        catch { }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        try { JS.InvokeVoidAsync("toc.disconnectObserver"); } catch { }
        _dotNetRef?.Dispose();
    }

    [JSInvokable]
    public Task NotifyVisibleHeading(string id)
    {
        activeHeadingId = id;
        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private class HeadingItem
    {
        public string Id { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
        public string Tag { get; set; } = string.Empty;
        public int Level { get; set; }
    }
}

<style>
    
    .right-toc {
        font-family: var(--font-family);
        font-size: var(--font-right-sidebar);
        color: var(--text-color-secondary);
        padding-top: 8px;
        position: sticky;
    }

    .toc-inner {
        padding: 0;
    }

    .toc-heading {
        /* Small caps / uppercase styling */
        text-transform: uppercase;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.8px;
        line-height: 1.5;
        padding: 0 0 12px 0;
        color: var(--text-color-secondary);
        margin-bottom: 8px;
    }

    .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .toc-item {
        list-style: none;
        border-left: 2px solid transparent;
        transition: border-color .2s ease;
    }
    
    html:not(.page-rtl) .toc-item:hover {
        border-left-color: var(--accent);
    }
    
    .page-rtl .toc-item:hover {
        border-right: 2px solid var(--accent);
    }

    .toc-item.level-2,
    .toc-item.level-3 {
        padding-left: 0;
    }
    
    .toc-item.level-4 {
        padding-left: 0.5rem;
    }
    
    .toc-item.level-5,
    .toc-item.level-6 {
        padding-left: 1rem;
    }

    .toc-item.visible { 
        border-left-color: var(--accent); 
    }
    
    .page-rtl .toc-item.visible { 
        border-right: 2px solid var(--accent); 
        border-left-color: transparent; 
    }

    a.toc-link {
        /* Smaller, lighter font for secondary navigation */
        color: var(--text-color-secondary);
        white-space: normal;
        word-break: break-word;
        letter-spacing: 0.2px;
        padding: 5px 12px;
        font-size: 14px;
        font-weight: 400;
        line-height: 18px;
        text-decoration: none;
        transition: color .2s ease;
        display: block;
        border-radius: 4px;
    }

    a.toc-link:hover {
        color: var(--text-color);
        text-decoration: none;
    }

    .toc-item.visible a.toc-link {
        color: var(--accent);
        font-weight: 500;
    }

    .toc-loading,
    .toc-empty {
        padding-left: 12px;
        font-size: 12px;
        color: var(--text-color-secondary);
    }
</style>